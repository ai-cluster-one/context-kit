def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="contextkit", add_help=False)
    sub = parser.add_subparsers(dest="command")

    sub.add_parser("help", add_help=False).set_defaults(func=lambda _args: _emit(HELP))
    p = sub.add_parser("update", help="check or update the installed ContextKit distribution")
    update_mode = p.add_mutually_exclusive_group(required=True)
    update_mode.add_argument("--check", action="store_true", help="compare installed and available releases without writing")
    update_mode.add_argument("--apply", action="store_true", help="install the available release")
    p.add_argument("--yes", action="store_true", help="approve installation without an interactive prompt")
    p.add_argument("--json", action="store_true", help="emit a machine-readable result")
    p.set_defaults(func=cmd_update)

    p = sub.add_parser("bootstrap")
    p.add_argument("--target", choices=["codex", "claude"], action="append")
    p.add_argument("--with-template", action="store_true")
    p.add_argument("--yes", action="store_true")
    p.add_argument("--json", action="store_true")
    p.set_defaults(func=cmd_bootstrap)

    p = sub.add_parser("doctor")
    p.add_argument("--json", action="store_true")
    p.set_defaults(func=cmd_doctor)

    p = sub.add_parser("init")
    init_group = p.add_mutually_exclusive_group()
    init_group.add_argument("--with-layers", action="store_true")
    init_group.add_argument("--with-template", action="store_true")
    p.add_argument("--binding-only", action="store_true", help=argparse.SUPPRESS)
    p.add_argument("--json", action="store_true")
    p.set_defaults(func=cmd_init, adopt=False, binding_only=False)

    p = sub.add_parser("adopt")
    adopt_group = p.add_mutually_exclusive_group()
    adopt_group.add_argument("--with-layers", action="store_true")
    adopt_group.add_argument("--with-template", action="store_true")
    p.add_argument("--json", action="store_true")
    p.set_defaults(func=cmd_init, adopt=True, binding_only=False)

    p = sub.add_parser("global-context", help="initialize user-level context shared by opted-in projects")
    global_context_sub = p.add_subparsers(dest="global_context_command", required=True)
    global_context_init = global_context_sub.add_parser("init", help="create a global-context source from the shipped starter")
    global_context_init.add_argument("path", help="destination directory for the global-context source")
    global_context_init.add_argument("--json", action="store_true", help="emit a machine-readable result")
    global_context_init.set_defaults(func=cmd_global_context_init)

    p = sub.add_parser("install-hooks")
    p.add_argument("--target", choices=["codex", "claude"], action="append", required=True)
    p.add_argument("--json", action="store_true")
    p.set_defaults(func=cmd_install_hooks)

    p = sub.add_parser("build")
    p.add_argument("--target", choices=["codex", "claude", "all"], default="codex")
    p.add_argument("--json", action="store_true")
    p.set_defaults(func=cmd_build)

    p = sub.add_parser("memory", help="capture and inspect provider-neutral project memory")
    memory_sub = p.add_subparsers(dest="memory_command", required=True)

    memory = memory_sub.add_parser("add", help="append one note to the current daily memory file")
    memory.add_argument("text", nargs="?", help="note text; quote multi-word text")
    memory.add_argument("--stdin", action="store_true", help="read note text from standard input")
    memory.add_argument("--title", help="optional entry heading")
    memory.add_argument("--json", action="store_true", help="emit a machine-readable result")
    memory.set_defaults(func=cmd_memory_add)

    memory = memory_sub.add_parser("context", help="render the complete block used by context builds")
    memory.add_argument("--json", action="store_true", help="include source paths and the block in JSON")
    memory.set_defaults(func=cmd_memory_context)

    memory = memory_sub.add_parser("search", help="find case-insensitive text matches across memory")
    memory.add_argument("query", help="text to find")
    memory.add_argument("--json", action="store_true", help="emit machine-readable matches")
    memory.set_defaults(func=cmd_memory_search)

    memory = memory_sub.add_parser("status", help="report memory presence, size, and source files")
    memory.add_argument("--json", action="store_true", help="emit a machine-readable report")
    memory.set_defaults(func=cmd_memory_status)

    memory = memory_sub.add_parser("import", help="copy Markdown from an existing memory store")
    memory.add_argument("source", help="Markdown file or directory to inspect")
    memory.add_argument("--provider", required=True, help="stable source label used under memory/imports")
    mode = memory.add_mutually_exclusive_group(required=True)
    mode.add_argument("--plan", action="store_true", help="report destinations without writing")
    mode.add_argument("--apply", action="store_true", help="copy the accepted non-conflicting plan")
    memory.add_argument("--json", action="store_true", help="emit a machine-readable plan or result")
    memory.set_defaults(func=cmd_memory_import)

    p = sub.add_parser("audit")
    p.add_argument("--write", action="store_true")
    p.add_argument("--json", action="store_true")
    p.set_defaults(func=cmd_audit)

    p = sub.add_parser("audit-file")
    p.add_argument("path")
    p.add_argument("--json", action="store_true")
    p.set_defaults(func=cmd_audit_file)

    p = sub.add_parser("groom")
    group = p.add_mutually_exclusive_group(required=True)
    group.add_argument("--plan", action="store_true")
    group.add_argument("--apply", action="store_true")
    p.set_defaults(func=cmd_groom)

    p = sub.add_parser("migrate")
    group = p.add_mutually_exclusive_group(required=True)
    group.add_argument("--plan", action="store_true")
    group.add_argument("--apply", action="store_true")
    p.add_argument("--json", action="store_true")
    p.set_defaults(func=cmd_migrate)

    p = sub.add_parser("guide")
    p.add_argument("topic", nargs="?")
    p.set_defaults(func=cmd_guide)

    sub.add_parser("templates").set_defaults(func=cmd_templates)
    return parser


def main(argv: list[str] | None = None) -> int:
    argv = list(sys.argv[1:] if argv is None else argv)
    if not argv:
        argv = ["help"]
    parser = build_parser()
    args = parser.parse_args(argv)
    if not hasattr(args, "func"):
        _emit(HELP)
        return 0
    try:
        args.func(args)
        return 0
    except ContextKitError as exc:
        sys.stderr.write(str(exc) + "\n")
        return exc.exit_code
    except BrokenPipeError:
        return 0


if __name__ == "__main__":
    raise SystemExit(main())
