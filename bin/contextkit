#!/usr/bin/env python3
"""contextkit — manager for repo-backed agent project bodies."""

from __future__ import annotations

import argparse
import datetime as _dt
import json
import os
import re
import shutil
import stat
import subprocess
import sys
import tempfile
import urllib.error
import urllib.request
from dataclasses import dataclass
from pathlib import Path
from typing import Any

try:
    import tomllib
except ModuleNotFoundError:  # pragma: no cover - Python < 3.11
    tomllib = None


VERSION = 1
CONFIG_REL = Path(".contextkit") / "config.toml"
README_REL = Path(".contextkit") / "README.md"
DEFAULT_SOURCES = {
    "context": "context",
    "assets": "assets",
    "routines": "routines",
    "capabilities": "capabilities",
}
DEFAULT_TARGETS = {
    "codex": Path(".codex") / "generated" / "context.md",
    "claude": Path(".claude") / "rules" / "CONTEXT.md",
}
CAP_HOME = Path(os.environ.get("CAPABILITIES_HOME") or (Path.home() / ".capabilities"))
BUNDLE_REL = Path("bundle")
LEGACY_DOCTRINE_REL = Path("doctrine")
GUIDE_TOPICS = [
    "bootstrap",
    "authoring",
    "validation",
    "assets",
    "routines",
    "audit",
    "destructive",
    "migration",
    "hooks",
    "capabilities",
]
DEFAULT_RAW_BASE = "https://raw.githubusercontent.com/ai-cluster-one/context-kit"

REQUIRED_GITIGNORE_BASE_LINES = [
    ".env",
    ".env.local",
    ".env.*.local",
    ".codex/generated/",
    ".claude/rules/CONTEXT.md",
    "__pycache__/",
    "*.pyc",
    ".DS_Store",
]

ENV_LOCAL_BODY = """# Local machine-only environment for this agent project.
# Keep secrets and machine-local overrides here. This file is ignored by git.
#
# Examples:
# CAPABILITIES_HOME=/Users/you/.capabilities
# CONTEXTKIT_ENV=local
"""


class ContextKitError(Exception):
    def __init__(self, message: str, exit_code: int = 1) -> None:
        super().__init__(message)
        self.exit_code = exit_code


@dataclass(frozen=True)
class ContextFile:
    path: Path
    rel: Path
    title: str
    description: str
    load: str
    order: int
    body: str
    raw_frontmatter: dict[str, str]


@dataclass
class Finding:
    severity: str
    code: str
    path: str
    message: str
    hint: str = ""
    rule_source: str = ""

    def as_dict(self) -> dict[str, str]:
        out = {
            "severity": self.severity,
            "code": self.code,
            "path": self.path,
            "message": self.message,
        }
        if self.rule_source:
            out["rule_source"] = self.rule_source
        if self.hint:
            out["hint"] = self.hint
        return out


@dataclass
class MigrationStep:
    title: str
    action: str
    status: str
    detail: str
    command: str = ""

    def as_dict(self) -> dict[str, str]:
        out = {
            "title": self.title,
            "action": self.action,
            "status": self.status,
            "detail": self.detail,
        }
        if self.command:
            out["command"] = self.command
        return out


def _die(message: str, exit_code: int = 1) -> None:
    raise ContextKitError(message, exit_code)


def _emit(value: Any, as_json: bool = False) -> None:
    if as_json:
        sys.stdout.write(json.dumps(value, ensure_ascii=False, indent=2) + "\n")
    elif isinstance(value, str):
        sys.stdout.write(value if value.endswith("\n") else value + "\n")
    else:
        sys.stdout.write(json.dumps(value, ensure_ascii=False, indent=2) + "\n")


def _script_path() -> Path:
    try:
        return Path(sys.argv[0]).resolve()
    except OSError:
        return Path(__file__).resolve()


def _bundle_candidates() -> list[Path]:
    candidates: list[Path] = []
    env = os.environ.get("CONTEXTKIT_BUNDLE_DIR")
    if env:
        candidates.append(Path(env).expanduser())
    legacy_env = os.environ.get("CONTEXTKIT_DOCTRINE_DIR")
    if legacy_env:
        candidates.append(Path(legacy_env).expanduser())

    script = _script_path()
    # Repo checkout: <repo>/bin/contextkit -> <repo>/bundle.
    # Installed manager: ~/.contextkit/.manager/contextkit -> ~/.contextkit/bundle.
    # Local bundle fallback: <dir>/contextkit -> <dir>/bundle.
    # Legacy doctrine paths are compatibility bridges, not canonical product layout.
    candidates += [
        script.parent.parent / BUNDLE_REL,
        script.parent / BUNDLE_REL,
        Path.home() / ".contextkit" / BUNDLE_REL,
        script.parent.parent / LEGACY_DOCTRINE_REL,
        script.parent / LEGACY_DOCTRINE_REL,
        Path.home() / ".contextkit" / LEGACY_DOCTRINE_REL,
    ]
    out: list[Path] = []
    seen: set[str] = set()
    for candidate in candidates:
        key = str(candidate)
        if key not in seen:
            out.append(candidate)
            seen.add(key)
    return out


def _remote_ref() -> str:
    return os.environ.get("CONTEXTKIT_REF") or os.environ.get("CONTEXTKIT_TAG") or "main"


def _remote_base() -> str:
    return os.environ.get("CONTEXTKIT_RAW_BASE", DEFAULT_RAW_BASE).rstrip("/")


def _fetch_bundle(rel: Path) -> str | None:
    url = f"{_remote_base()}/{_remote_ref()}/{BUNDLE_REL.as_posix()}/{rel.as_posix()}"
    try:
        with urllib.request.urlopen(url, timeout=8) as response:
            return response.read().decode("utf-8")
    except (OSError, UnicodeError, urllib.error.URLError):
        return None


def _read_bundle(rel: str) -> str:
    path = Path(rel)
    for base in _bundle_candidates():
        source = base / path
        try:
            return source.read_text()
        except OSError:
            continue

    fetched = _fetch_bundle(path)
    if fetched is not None:
        return fetched

    searched = ", ".join(str(path) for path in _bundle_candidates())
    _die(
        f"ContextKit bundle source not found: {BUNDLE_REL / path}\n"
        f"Searched: {searched}\n"
        "Set CONTEXTKIT_BUNDLE_DIR, install ContextKit bundle globally, or run from the ContextKit checkout.",
        6,
    )


def _run(args: list[str], root: Path, env: dict[str, str] | None = None,
         timeout: int = 30) -> subprocess.CompletedProcess[str]:
    merged_env = dict(os.environ)
    if env:
        merged_env.update(env)
    return subprocess.run(
        args,
        cwd=str(root),
        env=merged_env,
        text=True,
        capture_output=True,
        timeout=timeout,
    )


def _git_root(start: Path) -> Path | None:
    try:
        proc = _run(["git", "rev-parse", "--show-toplevel"], start)
    except (OSError, subprocess.TimeoutExpired):
        return None
    if proc.returncode != 0:
        return None
    return Path(proc.stdout.strip()).resolve()


def _find_project_root(start: Path | None = None) -> Path:
    here = (start or Path.cwd()).resolve()
    home = Path.home().resolve()
    for directory in (here, *here.parents):
        if (directory / CONFIG_REL).exists():
            return directory
        if (directory / "context").is_dir():
            return directory
        if (directory / ".git").is_dir():
            return directory
        if directory == home:
            break
    return _git_root(here) or here


def _load_toml(path: Path) -> dict[str, Any]:
    if not path.exists():
        return {}
    if tomllib is None:
        _die("Python 3.11+ is required to read .contextkit/config.toml", 6)
    try:
        return tomllib.loads(path.read_text())
    except Exception as exc:  # noqa: BLE001 - config error should be concise
        _die(f"invalid config TOML at {path}: {exc}", 6)


def _config(root: Path) -> dict[str, Any]:
    raw = _load_toml(root / CONFIG_REL)
    sources = dict(DEFAULT_SOURCES)
    sources.update((raw.get("sources") or {}) if isinstance(raw.get("sources"), dict) else {})
    for name, rel in sources.items():
        rel_path = Path(rel)
        allowed_dot_capabilities = name == "capabilities" and rel_path.as_posix() == ".capabilities"
        if rel_path.parts and rel_path.parts[0].startswith(".") and not allowed_dot_capabilities:
            _die(
                f"invalid source path for {name}: {rel}\n"
                "ContextKit project-body folders are visible: context/, assets/, routines/, capabilities/.\n"
                "Only `sources.capabilities = \".capabilities\"` is allowed as a legacy compatibility override.\n"
                "Use `contextkit migrate --plan` for legacy dot-folder projects.",
                6,
            )

    targets: dict[str, Path] = dict(DEFAULT_TARGETS)
    raw_targets = raw.get("targets") if isinstance(raw.get("targets"), dict) else {}
    for name, entry in raw_targets.items():
        if isinstance(entry, dict) and isinstance(entry.get("output"), str):
            targets[name] = Path(entry["output"])

    return {
        "version": raw.get("version", VERSION),
        "type": raw.get("type", "agent-project"),
        "sources": sources,
        "targets": targets,
        "raw": raw,
    }


def _capabilities_dir_from_sources(sources: dict[str, str]) -> Path:
    return Path(sources.get("capabilities") or DEFAULT_SOURCES["capabilities"])


def _configured_capabilities_dir(root: Path) -> Path:
    try:
        return _capabilities_dir_from_sources(_config(root)["sources"])
    except ContextKitError:
        return Path(DEFAULT_SOURCES["capabilities"])


def _required_gitignore_lines(capabilities_dir: Path | None = None) -> list[str]:
    cap_dir = capabilities_dir or Path(DEFAULT_SOURCES["capabilities"])
    cap_state_guard = cap_dir / "*" / "state"
    return [
        *REQUIRED_GITIGNORE_BASE_LINES[:5],
        cap_state_guard.as_posix() + "/",
        *REQUIRED_GITIGNORE_BASE_LINES[5:],
    ]


def _legacy_dot_layers(root: Path, sources: dict[str, str] | None = None) -> list[str]:
    allowed: set[str] = set()
    if sources and _capabilities_dir_from_sources(sources).as_posix() == ".capabilities":
        allowed.add(".capabilities")
    return [
        rel for rel in [".context", ".assets", ".routines", ".capabilities"]
        if rel not in allowed and (root / rel).exists()
    ]


def _rel(root: Path, path: Path) -> str:
    try:
        return path.resolve().relative_to(root.resolve()).as_posix()
    except ValueError:
        return str(path)


def _parse_frontmatter(text: str) -> tuple[dict[str, str], str]:
    if not text.startswith("---\n"):
        return {}, text
    end = text.find("\n---", 4)
    if end == -1:
        return {}, text
    fm_text = text[4:end]
    body_start = end + len("\n---")
    if body_start < len(text) and text[body_start] == "\n":
        body_start += 1
    fm: dict[str, str] = {}
    for raw_line in fm_text.splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#"):
            continue
        if ":" not in line:
            continue
        key, value = line.split(":", 1)
        key = key.strip()
        value = value.strip()
        if len(value) >= 2 and value[0] == value[-1] and value[0] in ("'", '"'):
            value = value[1:-1]
        fm[key] = value
    return fm, text[body_start:]


def _read_context_file(root: Path, path: Path) -> tuple[ContextFile | None, list[str]]:
    rel = Path(_rel(root, path))
    try:
        text = path.read_text()
    except OSError as exc:
        return None, [f"cannot read {rel}: {exc}"]
    fm, body = _parse_frontmatter(text)
    errors: list[str] = []
    title = fm.get("title", "").strip()
    description = fm.get("description", "").strip()
    load = fm.get("load", "").strip()
    order_raw = fm.get("order", "").strip()
    if not title:
        errors.append(f"Missing frontmatter title: {rel}")
    if not description:
        errors.append(f"Missing frontmatter description: {rel}")
    if load not in {"inline", "stub"}:
        if not load:
            errors.append(f"Missing frontmatter load: {rel}")
        else:
            errors.append(f"Invalid frontmatter load in {rel}: {load}")
    try:
        order = int(order_raw)
    except ValueError:
        order = 0
        errors.append(f"Invalid frontmatter order in {rel}: {order_raw or '<missing>'}")
    if errors:
        return None, errors
    return ContextFile(path, rel, title, description, load, order, body, fm), []


def _collect_context(root: Path, context_dir: Path) -> tuple[list[ContextFile], list[str]]:
    base = root / context_dir
    if not base.is_dir():
        legacy = root / f".{context_dir.as_posix()}"
        if not context_dir.as_posix().startswith(".") and legacy.is_dir():
            _die(
                f"context source directory not found: {context_dir}\n"
                f"Legacy `{legacy.name}/` exists. Rename it to `{context_dir.as_posix()}/` before building with ContextKit.",
                6,
            )
        _die(
            f"context source directory not found: {context_dir}\n"
            "Run `contextkit init --with-layers` to create empty project layers, or `contextkit init --with-template` to add starter context files.",
            6,
        )
    files: list[ContextFile] = []
    errors: list[str] = []
    for path in sorted(base.rglob("*.md")):
        ctx, ctx_errors = _read_context_file(root, path)
        if ctx:
            files.append(ctx)
        errors.extend(ctx_errors)
    if errors:
        _die("\n".join(errors), 6)
    files.sort(key=lambda item: (item.order, item.rel.as_posix()))
    return files, errors


def _runtime_block() -> str:
    return _read_bundle("runtime.md")


def _guide_rule_sources() -> str:
    return "; ".join(f"`contextkit guide {topic}`" for topic in GUIDE_TOPICS)


def _generated_block(target: str) -> str:
    return f"""<!-- Generated by ContextKit. Do not edit by hand. -->
Context manager: `{CONFIG_REL.as_posix()}`
Bootstrap: `contextkit bootstrap`
Rebuild: `contextkit build --target {target}`
Doctor: `contextkit doctor`
Help: `contextkit help`
Rule sources: {_guide_rule_sources()}
"""


def _one_line(value: str) -> str:
    return re.sub(r"\s+", " ", value).strip()


def _visible_project_terms(value: str, capabilities_dir: Path | None = None) -> str:
    replacements = {
        "`.context`": "`context/`",
        "`.context/`": "`context/`",
        "`.assets`": "`assets/`",
        "`.assets/`": "`assets/`",
        "`.routines`": "`routines/`",
        "`.routines/`": "`routines/`",
    }
    if (capabilities_dir or Path(DEFAULT_SOURCES["capabilities"])).as_posix() != ".capabilities":
        replacements.update({
            "`.capabilities`": "`capabilities/`",
            "`.capabilities/`": "`capabilities/`",
        })
    for old, new in replacements.items():
        value = value.replace(old, new)
    return value


def _frontmatter_name_description(path: Path) -> tuple[str, str]:
    try:
        fm, _body = _parse_frontmatter(path.read_text())
    except OSError:
        return "", ""
    return fm.get("name", "").strip(), fm.get("description", "").strip()


def _routine_index(root: Path, routines_dir: Path, warnings: list[str]) -> str:
    if not (root / routines_dir).is_dir():
        warnings.append(f"routine layer not present; add `{routines_dir.as_posix()}/` or run `contextkit guide routines`")
        return ""
    routines: list[tuple[str, str, Path]] = []
    for path in sorted((root / routines_dir).rglob("*.md")):
        name, description = _frontmatter_name_description(path)
        rel = Path(_rel(root, path))
        if not name:
            warnings.append(f"routine missing frontmatter name: {rel.as_posix()}")
            continue
        if not description:
            warnings.append(f"routine missing frontmatter description: {rel.as_posix()}")
            continue
        if name != path.stem:
            warnings.append(f"routine name `{name}` does not match filename stem `{path.stem}`: {rel.as_posix()}")
        routines.append((name, _one_line(description), rel))
    lines = [
        "# Routines (repeatable procedures)",
        "",
        "Each is a self-contained recipe. Load its file when you need to run that procedure.",
        "",
    ]
    if not routines:
        lines += ["No routines are declared in this project.", ""]
    else:
        for name, description, rel in routines:
            lines.append(f"- **[{name}]({rel.as_posix()})** - {description}")
        lines.append("")
    return "\n".join(lines)


def _load_capability_snapshots(name: str) -> tuple[str | None, dict[str, Any] | None]:
    reg = CAP_HOME / name
    stub = None
    try:
        stub = (reg / "stub").read_text().strip()
    except OSError:
        pass
    manifest = _read_json(reg / "manifest.json")
    return stub, manifest if isinstance(manifest, dict) else None


def _capability_gate(root: Path, capabilities_dir: Path) -> dict[str, Any]:
    gate = _read_json(root / capabilities_dir / "settings.json")
    if gate is None or not isinstance(gate, dict) or not isinstance(gate.get("capabilities"), dict):
        return {"capabilities": {}}
    return gate


def _capability_ids_summary(envdir: Path, name: str) -> str | None:
    ids = _read_json(envdir / "identifiers.json")
    if isinstance(ids, dict) and ids:
        return f"- Identifiers ({len(ids)}): inspect `capabilities/{name}/identifiers.json` for the full labelled list"
    if ids is not None:
        return f"- Identifiers file present but not a JSON object - fix `capabilities/{name}/identifiers.json`"
    return None


def _capability_connections_summary(envdir: Path) -> str | None:
    conns = _read_json(envdir / "connections.json")
    valid = (isinstance(conns, dict)
             and isinstance(conns.get("connections"), dict)
             and conns["connections"])
    if valid:
        default = conns.get("default")
        items = "; ".join(
            cid + ("*" if cid == default else "")
            + (" (read-only)" if isinstance(entry, dict)
               and entry.get("allow_write") is False else "")
            for cid, entry in sorted(conns["connections"].items())
        )
        return f"- Connections (`--connection <id>`; * = default): {items}"
    if conns is not None:
        return "- Connections file present but not a valid envelope - fix `connections.json`"
    return None


def _capability_references(root: Path, envdir: Path) -> list[str]:
    refs: list[str] = []
    refdir = envdir / "reference"
    if not refdir.is_dir():
        return refs
    for md in sorted(refdir.glob("*.md")):
        name, description = _frontmatter_name_description(md)
        if not name:
            continue
        rel = _rel(root, md)
        suffix = f" - {_one_line(description)}" if description else ""
        refs.append(f"- `{rel}`{suffix}")
    return refs


def _capability_index(root: Path, capabilities_dir: Path, warnings: list[str]) -> str:
    if not (root / capabilities_dir).is_dir():
        warnings.append(f"capability layer not present; add `{capabilities_dir.as_posix()}/` or run `contextkit guide capabilities`")
        return ""
    gate = _capability_gate(root, capabilities_dir)
    enabled = sorted(
        name for name, entry in gate["capabilities"].items()
        if isinstance(entry, dict) and entry.get("enabled") is True
    )
    lines = ["# Capabilities", "", "<!-- capabilities:begin - generated by ContextKit; do not edit -->", ""]
    if not enabled:
        gate_rel = (capabilities_dir / "settings.json").as_posix()
        lines += [
            f"No capabilities are enabled in this project. Install and enable capabilities, then record the gate in `{gate_rel}`.",
            "",
        ]
    else:
        lines += [
            "Each enabled capability is a CLI on PATH. `<name> help` is the full contract; `<name> doctor` proves readiness.",
            "Exit 4 is policy - a disabled capability or a read-only connection; ask the user, never lift a gate yourself.",
            "",
        ]
    for name in enabled:
        stub, manifest = _load_capability_snapshots(name)
        envdir = root / capabilities_dir / name
        lines += [f"## {name}", ""]
        if stub is None:
            lines += [f"Enabled but not installed - run `capabilities install {name}`.", ""]
            continue
        lines += [_visible_project_terms(_one_line(stub), capabilities_dir), ""]
        bullet: list[str] = []
        conn_summary = _capability_connections_summary(envdir)
        if conn_summary:
            bullet.append(conn_summary)
        ids_summary = _capability_ids_summary(envdir, name)
        if ids_summary:
            bullet.append(ids_summary)
        topics = ((manifest or {}).get("docs") or {}).get("topics") or []
        if topics:
            bullet.append(f"- Guides (`{name} guide <topic>`): " + ", ".join(sorted(topics)))
        refs = _capability_references(root, envdir)
        if refs:
            if bullet:
                bullet.append("")
            bullet += ["**References** (load on demand):", "", *refs]
        if bullet:
            lines += bullet + [""]
    lines += ["<!-- capabilities:end -->", ""]
    return "\n".join(lines)


def _compose_context(root: Path, target: str) -> tuple[str, list[str]]:
    cfg = _config(root)
    sources = cfg["sources"]
    context_dir = Path(sources["context"])
    routines_dir = Path(sources["routines"])
    capabilities_dir = Path(sources["capabilities"])
    files, _ = _collect_context(root, context_dir)
    warnings: list[str] = []
    inline = [item for item in files if item.load == "inline"]
    stubs = [item for item in files if item.load == "stub"]
    routine_index = _routine_index(root, routines_dir, warnings)
    capability_index = _capability_index(root, capabilities_dir, warnings)

    title = "Codex" if target == "codex" else "Claude"
    out: list[str] = [f"# {title} Context", "", _generated_block(target), ""]
    out += [
        "Compiled source directories:",
        "",
        f"- `{context_dir.as_posix()}`",
        "",
        "Context load modes:",
        "",
        f"- Inline files: {len(inline)}",
        f"- Stub files: {len(stubs)}",
        "",
    ]
    if warnings:
        out += ["Generation warnings:", ""]
        out += [f"- {warning}" for warning in warnings]
        out.append("")

    out += ["---", "", _runtime_block().strip(), "", "---", "", "# Inline Context", ""]
    if inline:
        for item in inline:
            out += ["---", "", f"## Source: `{item.rel.as_posix()}`", "", item.body.strip(), ""]
    else:
        out += ["No inline context files.", ""]

    out += ["---", "", "# Context Stubs", "",
            "These context files are visible by metadata only. Load the path when the task needs that doctrine.",
            ""]
    if stubs:
        for item in stubs:
            out.append(f"- **{item.title}** (`{item.rel.as_posix()}`) - {item.description}")
        out.append("")
    else:
        out += ["No stub context files.", ""]

    if routine_index:
        out += ["---", "", f"<!-- Routine index - generated from {routines_dir.as_posix()} front matter. -->", "",
                routine_index.strip(), ""]
    if capability_index:
        out += ["---", "", "<!-- Capability index - generated by `capabilities context` from the live registry. -->", "",
                capability_index.strip(), ""]
    return "\n".join(out).rstrip() + "\n", warnings


def cmd_build(args: argparse.Namespace) -> None:
    root = _find_project_root()
    written, warnings_by_target = _build_targets(root, args.target)
    _emit({"project": str(root), "written": written, "warnings": warnings_by_target}, args.json)


def _build_targets(root: Path, target: str) -> tuple[dict[str, str], dict[str, list[str]]]:
    cfg = _config(root)
    targets = ["codex", "claude"] if target == "all" else [target]
    written: dict[str, str] = {}
    warnings_by_target: dict[str, list[str]] = {}
    for item in targets:
        text, warnings = _compose_context(root, item)
        output = root / cfg["targets"][item]
        output.parent.mkdir(parents=True, exist_ok=True)
        with tempfile.NamedTemporaryFile("w", delete=False, dir=str(output.parent)) as tmp:
            tmp.write(text)
            tmp_path = Path(tmp.name)
        tmp_path.replace(output)
        output.chmod(0o644)
        written[item] = str(output)
        warnings_by_target[item] = warnings
    return written, warnings_by_target


def _write_if_missing(path: Path, body: str, created: list[str], skipped: list[str]) -> None:
    if path.exists():
        skipped.append(str(path))
        return
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(body)
    created.append(str(path))


def _ensure_gitignore(root: Path, created: list[str], changed: list[str]) -> None:
    path = root / ".gitignore"
    required = _required_gitignore_lines(_configured_capabilities_dir(root))
    if not path.exists():
        path.write_text("# ContextKit local and generated files\n" + "\n".join(required) + "\n")
        created.append(str(path))
        return
    text = path.read_text()
    existing = {line.strip() for line in text.splitlines() if line.strip() and not line.strip().startswith("#")}
    missing = [line for line in required if line not in existing]
    if not missing:
        return
    addition = "\n# ContextKit local and generated files\n" + "\n".join(missing) + "\n"
    path.write_text(text.rstrip("\n") + "\n" + addition)
    changed.append(str(path))


def _ensure_env_local(root: Path, created: list[str], skipped: list[str]) -> None:
    path = root / ".env.local"
    if path.exists():
        skipped.append(str(path))
        return
    path.write_text(ENV_LOCAL_BODY)
    created.append(str(path))


def _context_file(title: str, description: str, load: str, order: int, body: str) -> str:
    return (
        "---\n"
        f"title: {title}\n"
        f"description: {description}\n"
        f"load: {load}\n"
        f"order: {order}\n"
        "---\n\n"
        f"# {title}\n\n"
        f"{body.rstrip()}\n"
    )


SKELETON_FILES = {
    "context/identity/MISSION.md": _context_file(
        "Mission", "The agent's mission, operating scope, and north star.", "inline", 10,
        "State what this agent exists to do, what good work looks like, and what is out of scope.",
    ),
    "context/identity/AGENT.md": _context_file(
        "Agent", "The agent identity, voice, operating posture, and boundaries.", "inline", 20,
        "Describe who the agent is inside this project, including voice and operating posture.",
    ),
    "context/identity/OWNER.md": _context_file(
        "Owner", "The owner or supervisor relationship and command authority.", "inline", 30,
        "Name the owner role, supervision model, and escalation triggers.",
    ),
    "context/identity/PEOPLE.md": _context_file(
        "People", "Project people, roles, authority, and durable communication facts.", "stub", 40,
        "Record durable people facts only when they matter to future agent work.",
    ),
    "context/guidelines/CONSTITUTION.md": _context_file(
        "Constitution", "Always-on project doctrine and behavior rules for the agent.", "inline", 100,
        "Define the agent's project-specific principles, validation rules, escalation path, and tradeoffs.",
    ),
    "context/guidelines/LIMITATIONS.md": _context_file(
        "Limitations", "Hard limits for the agent and for context authoring in this project.", "inline", 110,
        "List non-negotiable constraints. Keep each limitation owned here and avoid duplicating it elsewhere.",
    ),
    "context/guidelines/ASSETS.md": _context_file(
        "Assets", "Map of on-demand asset folders and what belongs in each.", "stub", 120,
        "Explain `assets/` as supporting project material: sessions, plans, research, and other historical evidence.",
    ),
    "context/architecture/RUNTIME.md": _context_file(
        "Runtime", "Runtime bodies, host surfaces, generated context, and execution boundaries.", "stub", 200,
        "Describe how this agent runs, where generated context lands, and which host surfaces consume it.",
    ),
    "context/architecture/SERVICES.md": _context_file(
        "Services", "External services, ownership boundaries, and source-of-truth routing.", "stub", 210,
        "Map external systems at the boundary level. Detailed tool operation belongs in capabilities.",
    ),
}


def _config_body() -> str:
    return """version = 1
type = "agent-project"

[targets.codex]
output = ".codex/generated/context.md"

[targets.claude]
output = ".claude/rules/CONTEXT.md"
"""


def _binding_readme() -> str:
    return """# ContextKit Binding

This repository is managed by ContextKit, a local manager for agent project structure and runtime context.

The agent body stays in this repository: live context, supporting assets,
repeatable routines, and capability envelopes. ContextKit owns the shape,
compiler, templates, host bindings, guides, and audit tooling that turn that
body into Codex and Claude runtime context.

Common commands:

- `contextkit bootstrap`
- `contextkit init --with-layers`
- `contextkit init --with-template`
- `contextkit build --target codex`
- `contextkit build --target claude`
- `contextkit build --target all`
- `contextkit doctor`
- `contextkit audit`
- `contextkit guide authoring`

Add durable project context under `context/`. Put historical or supporting material
under `assets/`. Put repeatable procedures under `routines/`. Put installed tool
envelopes under `capabilities/`.
"""


LAYER_DIRS = [
    ".contextkit/audits",
    "context",
    "assets/sessions",
    "assets/plans",
    "assets/research",
    "routines",
    "capabilities",
]


def _ensure_project_layers(root: Path, created: list[str], skipped: list[str]) -> None:
    for rel in LAYER_DIRS:
        path = root / rel
        if path.exists():
            skipped.append(str(path))
        else:
            path.mkdir(parents=True, exist_ok=True)
            created.append(str(path))
    _write_if_missing(root / "capabilities" / "settings.json", '{\n  "capabilities": {}\n}\n', created, skipped)


def _init_project(root: Path, with_layers: bool = False, with_template: bool = False) -> dict[str, Any]:
    created: list[str] = []
    changed: list[str] = []
    skipped: list[str] = []
    _write_if_missing(root / CONFIG_REL, _config_body(), created, skipped)
    _write_if_missing(root / README_REL, _binding_readme(), created, skipped)
    _ensure_gitignore(root, created, changed)
    _ensure_env_local(root, created, skipped)
    if with_layers or with_template:
        _ensure_project_layers(root, created, skipped)
    if with_template:
        for rel, body in SKELETON_FILES.items():
            _write_if_missing(root / rel, body, created, skipped)
    return {"project": str(root), "created": created, "changed": changed, "skipped": skipped}


def cmd_init(args: argparse.Namespace) -> None:
    root = _find_project_root() if args.adopt else Path.cwd().resolve()
    with_layers = bool(getattr(args, "with_layers", False))
    with_template = bool(getattr(args, "with_template", False))
    binding_only = bool(getattr(args, "binding_only", False))
    if binding_only and (with_layers or with_template):
        _die("`--binding-only` is the default and cannot be combined with `--with-layers` or `--with-template`.", 2)
    _emit(_init_project(root, with_layers=with_layers, with_template=with_template), args.json)


def _codex_adapter() -> str:
    return """#!/usr/bin/env bash
set -euo pipefail

# Generated by `contextkit install-hooks --target codex`; do not edit by hand.

ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
ROOT="$(cd "$ROOT" && pwd -P)"
cd "$ROOT"

export PATH="$ROOT/.contextkit/manager:$PATH"

target="codex"
case "${1:-}" in
  "")
    ;;
  codex|claude|all)
    target="$1"
    ;;
  --target)
    target="${2:-}"
    ;;
  *)
    printf 'Unknown target argument: %s\\n' "$1" >&2
    exit 2
    ;;
esac

case "$target" in
  codex|claude|all)
    ;;
  *)
    printf 'Target must be codex, claude, or all; got: %s\\n' "$target" >&2
    exit 2
    ;;
esac

contextkit build --target "$target" >/dev/null
"""


def _read_json(path: Path) -> Any:
    try:
        return json.loads(path.read_text())
    except (OSError, ValueError):
        return None


def _write_json(path: Path, value: Any) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(value, ensure_ascii=False, indent=2, sort_keys=True) + "\n")


def _wire_codex(root: Path) -> dict[str, Any]:
    build = root / ".codex" / "hooks" / "build-context.sh"
    build.parent.mkdir(parents=True, exist_ok=True)
    existing = build.read_text() if build.exists() else None
    body = _codex_adapter()
    build.write_text(body)
    build.chmod(build.stat().st_mode | stat.S_IXUSR | stat.S_IXGRP | stat.S_IXOTH)

    config = root / ".codex" / "config.toml"
    config.parent.mkdir(parents=True, exist_ok=True)
    context_rel = DEFAULT_TARGETS["codex"].as_posix()
    if config.exists():
        text = config.read_text()
        changed_config = False
        if "project_doc_fallback_filenames" not in text:
            text = text.rstrip() + f'\nproject_doc_fallback_filenames = ["{context_rel}"]\n'
            changed_config = True
        elif context_rel not in text:
            text = text.rstrip() + f'\n# ContextKit output: {context_rel}\n'
            changed_config = True
        if "project_doc_max_bytes" not in text:
            text = text.rstrip() + "\nproject_doc_max_bytes = 131072\n"
            changed_config = True
        if changed_config:
            config.write_text(text if text.endswith("\n") else text + "\n")
    else:
        config.write_text(
            f'project_doc_fallback_filenames = ["{context_rel}"]\n'
            "project_doc_max_bytes = 131072\n"
        )
        changed_config = True

    hooks_path = root / ".codex" / "hooks.json"
    hooks = _read_json(hooks_path)
    if not isinstance(hooks, dict):
        hooks = {}
    session = hooks.setdefault("hooks", {}).setdefault("SessionStart", [])
    command = (
        "/bin/bash -lc 'root=$(git rev-parse --show-toplevel 2>/dev/null || pwd); "
        "/bin/bash \"$root/.codex/hooks/build-context.sh\"'"
    )
    hook_added = False
    if not any(command in (hook or {}).get("command", "")
               for entry in session for hook in (entry or {}).get("hooks", [])):
        session.append({
            "matcher": "startup|resume|clear|compact",
            "hooks": [{
                "type": "command",
                "command": command,
                "timeout": 30,
                "statusMessage": "Regenerating ContextKit context",
            }],
        })
        hook_added = True
    _write_json(hooks_path, hooks)
    return {
        "compiler": str(build),
        "compiler_changed": existing != body,
        "config": str(config),
        "hooks": str(hooks_path),
        "hook_added": hook_added,
    }


def _wire_claude(root: Path) -> dict[str, Any]:
    settings_file = root / ".claude" / "settings.json"
    settings = _read_json(settings_file)
    if not isinstance(settings, dict):
        settings = {}
    session = settings.setdefault("hooks", {}).setdefault("SessionStart", [])
    command = (
        "/bin/bash -lc 'root=$(git rev-parse --show-toplevel 2>/dev/null || pwd); "
        "PATH=\"$root/.contextkit/manager:$PATH\" contextkit build --target claude >/dev/null'"
    )
    needle = "contextkit build --target claude"
    hook_added = False
    hook_changed = False
    for entry in session:
        for hook in (entry or {}).get("hooks", []):
            if needle in (hook or {}).get("command", ""):
                if hook.get("command") != command:
                    hook["command"] = command
                    hook_changed = True
                break
        if hook_changed:
            break
    if not any(needle in (hook or {}).get("command", "")
               for entry in session for hook in (entry or {}).get("hooks", [])):
        session.append({"hooks": [{"type": "command", "command": command}]})
        hook_added = True
    _write_json(settings_file, settings)
    return {"settings": str(settings_file), "hook_added": hook_added, "hook_changed": hook_changed}


def _install_hooks(root: Path, targets: list[str]) -> dict[str, Any]:
    result: dict[str, Any] = {"project": str(root)}
    if "codex" in targets:
        result["codex"] = _wire_codex(root)
    if "claude" in targets:
        result["claude"] = _wire_claude(root)
    return result


def cmd_install_hooks(args: argparse.Namespace) -> None:
    root = _find_project_root()
    targets = args.target or ["codex"]
    result = _install_hooks(root, targets)
    _emit(result, args.json)


def _dedupe_targets(targets: list[str] | None) -> list[str]:
    raw = targets or ["codex", "claude"]
    out: list[str] = []
    for target in raw:
        if target not in out:
            out.append(target)
    return out


def _ensure_git_repo(root: Path) -> dict[str, Any]:
    git_path = root / ".git"
    if git_path.exists():
        return {
            "present": True,
            "initialized": False,
            "path": str(git_path),
            "checkpoint": {"required": False, "created": False},
        }
    try:
        proc = _run(["git", "init"], root)
    except (OSError, subprocess.TimeoutExpired) as exc:
        _die(f"git init failed: {exc}", 6)
    if proc.returncode != 0:
        detail = (proc.stderr or proc.stdout).strip()
        _die(f"git init failed in {root}: {detail}", 6)
    return {
        "present": True,
        "initialized": True,
        "path": str(git_path),
        "checkpoint": {"required": False, "created": False, "reason": "empty directory"},
    }


def _has_prebootstrap_files(root: Path) -> bool:
    try:
        children = list(root.iterdir())
    except OSError:
        return True
    for child in children:
        if child.name in {".git", ".DS_Store"}:
            continue
        return True
    return False


def _confirm_prebootstrap_checkpoint(root: Path, yes: bool) -> None:
    if yes:
        return
    lines = [
        "ContextKit bootstrap found files but no Git repository.",
        "Create a pre-bootstrap Git checkpoint before ContextKit changes project files.",
        "",
        "This runs:",
        "- git init",
        "- git add -A",
        "- git commit -m \"ContextKit pre-bootstrap checkpoint\"",
        "",
        f"Project: {root}",
        "",
        "Continue?",
    ]
    prompt = "\n".join(lines) + " [y/N] "
    try:
        with open("/dev/tty", "r+", encoding="utf-8") as tty:
            tty.write(prompt)
            tty.flush()
            answer = tty.readline().strip().lower()
    except OSError:
        _die(
            "\n".join(lines)
            + "\nRun `contextkit bootstrap --yes` to create the checkpoint automatically.",
            6,
        )
    if answer not in {"y", "yes"}:
        _die("ContextKit bootstrap cancelled before project files changed.", 6)


def _append_git_info_exclude(root: Path) -> None:
    path = root / ".git" / "info" / "exclude"
    try:
        text = path.read_text() if path.exists() else ""
    except OSError:
        text = ""
    existing = {line.strip() for line in text.splitlines() if line.strip() and not line.strip().startswith("#")}
    missing = [line for line in _required_gitignore_lines(_configured_capabilities_dir(root)) if line not in existing]
    if not missing:
        return
    path.parent.mkdir(parents=True, exist_ok=True)
    addition = "\n# ContextKit local and generated files\n" + "\n".join(missing) + "\n"
    path.write_text(text.rstrip("\n") + addition)


def _git_configured_identity(root: Path) -> bool:
    name = _run(["git", "config", "--get", "user.name"], root)
    email = _run(["git", "config", "--get", "user.email"], root)
    return name.returncode == 0 and bool(name.stdout.strip()) and email.returncode == 0 and bool(email.stdout.strip())


def _commit_prebootstrap_checkpoint(root: Path) -> dict[str, Any]:
    _append_git_info_exclude(root)
    add = _run(["git", "add", "-A"], root)
    if add.returncode != 0:
        detail = (add.stderr or add.stdout).strip()
        _die(f"pre-bootstrap git add failed in {root}: {detail}", 6)
    staged = _run(["git", "diff", "--cached", "--quiet"], root)
    if staged.returncode == 0:
        return {"required": True, "created": False, "reason": "no tracked files after git add"}
    if staged.returncode not in {0, 1}:
        detail = (staged.stderr or staged.stdout).strip()
        _die(f"pre-bootstrap git diff failed in {root}: {detail}", 6)

    commit_cmd = ["git"]
    if not _git_configured_identity(root):
        commit_cmd += ["-c", "user.name=ContextKit", "-c", "user.email=contextkit@local"]
    commit_cmd += ["commit", "-m", "ContextKit pre-bootstrap checkpoint"]
    commit = _run(commit_cmd, root)
    if commit.returncode != 0:
        detail = (commit.stderr or commit.stdout).strip()
        _die(f"pre-bootstrap checkpoint commit failed in {root}: {detail}", 6)
    rev = _run(["git", "rev-parse", "--short", "HEAD"], root)
    return {
        "required": True,
        "created": True,
        "commit": rev.stdout.strip() if rev.returncode == 0 else "",
        "message": "ContextKit pre-bootstrap checkpoint",
    }


def _prepare_git_for_bootstrap(root: Path, yes: bool) -> dict[str, Any]:
    git_path = root / ".git"
    if git_path.exists():
        return _ensure_git_repo(root)
    if not _has_prebootstrap_files(root):
        return _ensure_git_repo(root)

    _confirm_prebootstrap_checkpoint(root, yes)
    git = _ensure_git_repo(root)
    git["checkpoint"] = _commit_prebootstrap_checkpoint(root)
    return git


def _json_object_blocker(root: Path, rel: Path, label: str, blockers: list[str]) -> None:
    path = root / rel
    if not path.exists():
        return
    if not path.is_file():
        blockers.append(f"{label} is not a file: {rel.as_posix()}")
        return
    value = _read_json(path)
    if value is None:
        blockers.append(f"{label} is invalid JSON: {rel.as_posix()}")
    elif not isinstance(value, dict):
        blockers.append(f"{label} must be a JSON object: {rel.as_posix()}")


def _bootstrap_conflicts(root: Path, targets: list[str]) -> dict[str, list[Any]]:
    blockers: list[str] = []
    confirm: list[dict[str, str]] = []
    cfg: dict[str, Any] | None = None

    if (root / CONFIG_REL).exists():
        try:
            cfg = _config(root)
        except ContextKitError as exc:
            blockers.append(str(exc))

    legacy_dot_layers = _legacy_dot_layers(root, (cfg or {}).get("sources"))
    for rel in legacy_dot_layers:
        blockers.append(f"legacy dot body layer present: {rel} -> {rel[1:]}; run `contextkit migrate --plan`")

    if "codex" in targets:
        adapter = root / ".codex" / "hooks" / "build-context.sh"
        if adapter.exists() and not adapter.is_file():
            blockers.append(".codex/hooks/build-context.sh exists and is not a file")
        elif adapter.exists():
            try:
                existing = adapter.read_text()
            except OSError as exc:
                blockers.append(f"cannot read .codex/hooks/build-context.sh: {exc}")
            else:
                owned = "Generated by `contextkit install-hooks --target codex`" in existing
                if existing != _codex_adapter() and not owned:
                    confirm.append({
                        "path": ".codex/hooks/build-context.sh",
                        "reason": "file exists and is not a ContextKit-managed adapter",
                        "action": "replace with ContextKit adapter",
                    })
        _json_object_blocker(root, Path(".codex") / "hooks.json", "Codex hooks", blockers)

    if "claude" in targets:
        _json_object_blocker(root, Path(".claude") / "settings.json", "Claude settings", blockers)

    return {"blockers": blockers, "confirm": confirm}


def _confirm_bootstrap_conflicts(conflicts: list[dict[str, str]], yes: bool) -> None:
    if not conflicts or yes:
        return
    lines = [
        "ContextKit bootstrap found managed-file conflicts:",
        *[
            f"- {item['path']}: {item['reason']}; {item['action']}"
            for item in conflicts
        ],
        "",
        "Continue and apply these replacements?",
    ]
    prompt = "\n".join(lines) + " [y/N] "
    try:
        with open("/dev/tty", "r+", encoding="utf-8") as tty:
            tty.write(prompt)
            tty.flush()
            answer = tty.readline().strip().lower()
    except OSError:
        _die(
            "\n".join(lines)
            + "\nRun `contextkit bootstrap --yes` to approve these replacements.",
            6,
        )
    if answer not in {"y", "yes"}:
        _die("ContextKit bootstrap cancelled.", 6)


def _bootstrap_build_target(targets: list[str]) -> str:
    return "all" if {"codex", "claude"}.issubset(set(targets)) else targets[0]


def _format_bootstrap_result(result: dict[str, Any]) -> str:
    checkpoint = result["git"].get("checkpoint") or {}
    git_status = "initialized" if result["git"]["initialized"] else "present"
    if checkpoint.get("created"):
        git_status += f", checkpoint {checkpoint.get('commit')}"
    lines = [
        "# ContextKit Bootstrap",
        "",
        f"Project: `{result['project']}`",
        f"Status: {'ready' if result['ready'] else 'needs attention'}",
        "",
        "Steps:",
        f"- Git: {git_status}",
        f"- Init: {len(result['init']['created'])} created, {len(result['init']['changed'])} changed, {len(result['init']['skipped'])} skipped",
        f"- Hooks: {', '.join(result['targets'])}",
        f"- Build: {', '.join(sorted(result['build']['written']))}",
        f"- Doctor: {'ok' if result['doctor']['ok'] else 'needs attention'}",
        f"- Audit findings: {len(result['audit']['findings'])}",
        "",
    ]
    if result["confirmed_conflicts"]:
        lines += [
            "Confirmed replacements:",
            *[f"- `{item['path']}`" for item in result["confirmed_conflicts"]],
            "",
        ]
    if result["doctor"]["problems"]:
        lines += ["Doctor problems:", *[f"- {problem}" for problem in result["doctor"]["problems"]], ""]
    if result["audit"]["findings"]:
        lines += ["Audit findings:", *[
            f"- {item['severity']} `{item['code']}`: {item['path']}"
            for item in result["audit"]["findings"]
        ], ""]
    lines += [
        "Rule sources:",
        "- `contextkit guide bootstrap`",
        "- `contextkit guide validation`",
        "- `contextkit guide audit`",
        "",
    ]
    return "\n".join(lines)


def cmd_bootstrap(args: argparse.Namespace) -> None:
    root = _find_project_root()
    targets = _dedupe_targets(args.target)
    conflicts = _bootstrap_conflicts(root, targets)
    if conflicts["blockers"]:
        _die(
            "ContextKit bootstrap blocked:\n"
            + "\n".join(f"- {item}" for item in conflicts["blockers"]),
            6,
        )
    git = _prepare_git_for_bootstrap(root, args.yes)
    _confirm_bootstrap_conflicts(conflicts["confirm"], args.yes)
    confirmed_conflicts = conflicts["confirm"]

    init = _init_project(root, with_layers=True, with_template=args.with_template)
    hooks = _install_hooks(root, targets)
    build_target = _bootstrap_build_target(targets)
    written, warnings = _build_targets(root, build_target)
    doctor = _doctor_report(root)
    findings = _audit_context_files(root)
    audit = {
        "project": str(root),
        "rule_source": "contextkit guide audit",
        "findings": [item.as_dict() for item in findings],
    }
    result = {
        "project": str(root),
        "ready": doctor["ok"] and not findings,
        "targets": targets,
        "confirmed_conflicts": confirmed_conflicts,
        "git": git,
        "init": init,
        "hooks": hooks,
        "build": {"target": build_target, "written": written, "warnings": warnings},
        "doctor": doctor,
        "audit": audit,
        "rule_sources": [
            "contextkit guide bootstrap",
            "contextkit guide validation",
            "contextkit guide audit",
        ],
    }
    _emit(result, True) if args.json else _emit(_format_bootstrap_result(result))


def _git_state(root: Path) -> dict[str, Any]:
    git_dir = root / ".git"
    out: dict[str, Any] = {"present": git_dir.exists()}
    if git_dir.exists():
        proc = _run(["git", "status", "--short"], root)
        out["dirty"] = bool(proc.stdout.strip()) if proc.returncode == 0 else None
    return out


def _gitignore_patterns(root: Path) -> set[str]:
    path = root / ".gitignore"
    try:
        lines = path.read_text().splitlines()
    except OSError:
        return set()
    return {line.strip() for line in lines if line.strip() and not line.strip().startswith("#")}


def _required_project_files(root: Path, sources: dict[str, str]) -> dict[str, dict[str, Any]]:
    capability_gate = _capabilities_dir_from_sources(sources) / "settings.json"
    return {
        ".contextkit/config.toml": {"path": str(root / CONFIG_REL), "present": (root / CONFIG_REL).exists()},
        ".contextkit/README.md": {"path": str(root / README_REL), "present": (root / README_REL).exists()},
        ".gitignore": {"path": str(root / ".gitignore"), "present": (root / ".gitignore").exists()},
        ".env.local": {"path": str(root / ".env.local"), "present": (root / ".env.local").exists()},
        capability_gate.as_posix(): {
            "path": str(root / capability_gate),
            "present": (root / capability_gate).exists(),
        },
    }


def _guard_report(root: Path, sources: dict[str, str]) -> dict[str, bool]:
    patterns = _gitignore_patterns(root)
    return {line: line in patterns for line in _required_gitignore_lines(_capabilities_dir_from_sources(sources))}


def _doctor_report(root: Path) -> dict[str, Any]:
    cfg = _config(root)
    sources = cfg["sources"]
    required_files = _required_project_files(root, sources)
    gitignore_guards = _guard_report(root, sources)
    legacy_dot_layers = _legacy_dot_layers(root, sources)
    layers = {
        name: {
            "path": str(root / rel),
            "present": (root / rel).exists(),
        }
        for name, rel in sources.items()
    }
    problems: list[str] = []
    problems += [f"missing required file: {name}" for name, item in required_files.items() if not item["present"]]
    problems += [f"missing .gitignore guard: {pattern}" for pattern, present in gitignore_guards.items() if not present]
    problems += [f"missing project layer: {name} ({item['path']})" for name, item in layers.items() if not item["present"]]
    problems += [f"legacy dot layer present: {rel} -> {rel[1:]}" for rel in legacy_dot_layers]
    report = {
        "project": str(root),
        "config": str(root / CONFIG_REL) if (root / CONFIG_REL).exists() else None,
        "type": cfg["type"],
        "ok": not problems,
        "problems": problems,
        "rule_sources": ["contextkit guide validation", "contextkit guide bootstrap"],
        "git": _git_state(root),
        "required_files": required_files,
        "gitignore_guards": gitignore_guards,
        "legacy_dot_layers": legacy_dot_layers,
        "layers": layers,
        "tools": {
            "contextkit": str(Path(sys.argv[0]).resolve()),
            "capabilities": shutil.which("capabilities"),
            "routine": shutil.which("routine"),
        },
        "targets": {name: str(root / path) for name, path in cfg["targets"].items()},
        "hooks": {
            "codex_hooks": str(root / ".codex" / "hooks.json"),
            "codex_adapter": str(root / ".codex" / "hooks" / "build-context.sh"),
            "claude_settings": str(root / ".claude" / "settings.json"),
        },
    }
    return report


def cmd_doctor(args: argparse.Namespace) -> None:
    root = _find_project_root()
    report = _doctor_report(root)
    if args.json:
        _emit(report, True)
        return
    lines = [
        "# ContextKit Doctor",
        "",
        f"Project: `{root}`",
        f"Type: `{report['type']}`",
        f"Status: {'ok' if report['ok'] else 'needs attention'}",
        "",
    ]
    lines += ["Rule sources:", "- `contextkit guide validation`", "- `contextkit guide bootstrap`", ""]
    if report["problems"]:
        lines += ["Problems:", *[f"- {problem}" for problem in report["problems"]], ""]
    lines += ["Git:", f"- Present: {report['git']['present']}", f"- Dirty: {report['git'].get('dirty')}", ""]
    lines += ["Required files:"]
    for name, item in report["required_files"].items():
        marker = "present" if item["present"] else "missing"
        lines.append(f"- {name}: {marker}")
    lines += ["", "Gitignore guards:"]
    for pattern, present in report["gitignore_guards"].items():
        marker = "present" if present else "missing"
        lines.append(f"- `{pattern}`: {marker}")
    if report["legacy_dot_layers"]:
        lines += ["", "Legacy dot layers:"]
        lines += [f"- `{rel}` -> `{rel[1:]}`" for rel in report["legacy_dot_layers"]]
    lines.append("")
    lines += ["Layers:"]
    for name, item in report["layers"].items():
        marker = "present" if item["present"] else "missing"
        lines.append(f"- {name}: {marker} (`{item['path']}`)")
    lines += ["", "Tools:"]
    for name, value in report["tools"].items():
        lines.append(f"- {name}: `{value or 'not found'}`")
    lines += ["", "Targets:"]
    for name, value in report["targets"].items():
        lines.append(f"- {name}: `{value}`")
    _emit("\n".join(lines) + "\n")


def _weak_description(description: str) -> bool:
    words = re.findall(r"[A-Za-z0-9_'-]+", description)
    if len(words) < 6:
        return True
    generic = {"misc", "notes", "context", "information", "details", "things", "stuff"}
    return len(set(w.lower() for w in words) - generic) < 4


def _content_owner_hint(rel: str, text: str) -> str | None:
    lowered = text.lower()
    if "/guidelines/" in rel and sum(word in lowered for word in
                                    ["runtime", "container", "deployment", "service architecture"]) >= 2:
        return "This reads like architecture; consider `context/architecture/`."
    if "/architecture/" in rel and sum(word in lowered for word in
                                      ["always", "never", "must", "limitation", "do not"]) >= 4:
        return "This reads like doctrine or constraints; consider `context/guidelines/`."
    if "/identity/" in rel and sum(word in lowered for word in
                                  ["cli", "endpoint", "container", "database", "queue"]) >= 3:
        return "This reads like runtime/service architecture; consider `context/architecture/`."
    return None


def _historical_framing_hint(text: str) -> str | None:
    if re.search(r"\b(formerly|previously|used to|moved from|migrated from|unlike)\b", text, flags=re.I):
        return "Rewrite live doctrine in present tense; keep migration history in git, assets, or audit reports."
    return None


def _running_state_hint(text: str) -> str | None:
    if re.search(r"\b(todo|pending|next action|checkpoint|last sync(?:ed)?|current balance|open task)\b", text, flags=re.I):
        return "Live context excludes running task state; move work tracking to the project work system or assets."
    return None


def _normalized_claims(item: ContextFile) -> list[str]:
    claims: list[str] = []
    for raw in re.split(r"[\n.]", item.body):
        line = re.sub(r"\s+", " ", raw.strip().lower())
        line = re.sub(r"[`*_>#-]", "", line).strip()
        if not line:
            continue
        if len(line.split()) < 10:
            continue
        if line.startswith(("the ", "a ", "an ")) or any(ch.isalpha() for ch in line):
            claims.append(line)
    return claims


def _audit_context_files(root: Path, paths: list[Path] | None = None) -> list[Finding]:
    cfg = _config(root)
    context_dir = Path(cfg["sources"]["context"])
    findings: list[Finding] = []
    files: list[ContextFile] = []
    raw_paths = paths if paths is not None else sorted((root / context_dir).rglob("*.md"))
    for path in raw_paths:
        ctx, errors = _read_context_file(root, path)
        if errors:
            for err in errors:
                findings.append(Finding(
                    "error", "metadata", _rel(root, path), err,
                    rule_source="contextkit guide authoring",
                ))
            continue
        if ctx:
            files.append(ctx)

    claim_owners: dict[str, list[str]] = {}
    for item in files:
        rel = item.rel.as_posix()
        if _weak_description(item.description):
            findings.append(Finding(
                "warning", "weak-description", rel,
                "Description is too generic to route reliably.",
                "Make it a specific one-line answer to: when the agent loads this file.",
                "contextkit guide authoring",
            ))
        if "\n" in item.description:
            findings.append(Finding(
                "warning", "description", rel, "Description is one line.",
                rule_source="contextkit guide authoring",
            ))
        if item.load == "inline" and (len(item.body.split()) > 1200 or len(item.body.splitlines()) > 180):
            findings.append(Finding(
                "warning", "inline-bloat", rel,
                "Inline file is large enough to deserve review.",
                "Keep always-on context lean; move detail to a stub, routine, capability reference, or asset.",
                "contextkit guide authoring",
            ))
        if re.search(r"\[[^\]]+\]\((?:\.\.?/)?[^)]+\.md(?:#[^)]+)?\)", item.body):
            findings.append(Finding(
                "warning", "internal-context-link", rel,
                "Markdown links to sibling context files create stale routing assumptions.",
                "Prefer self-contained wording and let compiled metadata route sibling files.",
                "contextkit guide authoring",
            ))
        asset_live_pattern = re.compile(
            r"(?:see|load|read|per|according to|based on|from)\s+`?(?:\.assets|assets)/(?:sessions|plans|research)/"
            r"|\]\((?:\.assets|assets)/(?:sessions|plans|research)/",
            flags=re.I,
        )
        if asset_live_pattern.search(item.body):
            findings.append(Finding(
                "warning", "asset-as-live-doctrine", rel,
                "File points at historical assets as if they are live doctrine.",
                "Promote durable facts into the live owning layer; leave historical assets as evidence.",
                "contextkit guide authoring; contextkit guide assets",
            ))
        hint = _content_owner_hint(rel, item.body)
        if hint:
            findings.append(Finding(
                "info", "taxonomy-fit", rel,
                "File may live at the wrong context altitude.",
                hint,
                "contextkit guide authoring",
            ))
        hint = _historical_framing_hint(item.body)
        if hint:
            findings.append(Finding(
                "warning", "historical-framing", rel,
                "Live context appears to define itself through history or comparison.",
                hint,
                "contextkit guide authoring",
            ))
        hint = _running_state_hint(item.body)
        if hint:
            findings.append(Finding(
                "warning", "running-state-in-context", rel,
                "Live context appears to contain running task state.",
                hint,
                "contextkit guide authoring",
            ))
        for claim in _normalized_claims(item):
            claim_owners.setdefault(claim, []).append(rel)

    for claim, owners in sorted(claim_owners.items()):
        unique = sorted(set(owners))
        if len(unique) > 1:
            findings.append(Finding(
                "warning", "duplicate-live-fact", ", ".join(unique),
                f"Same durable-looking claim appears in {len(unique)} live files.",
                claim[:220],
                "contextkit guide authoring",
            ))
    return findings


def _audit_report(root: Path, findings: list[Finding]) -> str:
    today = _dt.date.today().isoformat()
    lines = [
        f"# ContextKit Audit - {today}",
        "",
        f"Project: `{root}`",
        "",
        "Audit procedure: `contextkit guide audit`",
        "Apply each finding by loading its `Rule source` guide.",
        "",
        "## Findings",
        "",
    ]
    if not findings:
        lines.append("No findings.")
    else:
        for finding in findings:
            lines += [
                f"### {finding.severity.upper()} `{finding.code}`",
                "",
                f"- Path: `{finding.path}`",
                f"- Rule source: `{finding.rule_source or 'contextkit guide audit'}`",
                f"- Finding: {finding.message}",
            ]
            if finding.hint:
                lines.append(f"- Hint: {finding.hint}")
            lines.append("")
    return "\n".join(lines).rstrip() + "\n"


def _write_audit(root: Path, report: str) -> Path:
    target_dir = root / ".contextkit" / "audits"
    target_dir.mkdir(parents=True, exist_ok=True)
    today = _dt.date.today().isoformat()
    target = target_dir / f"{today}_contextkit-audit.md"
    if target.exists():
        index = 2
        while True:
            candidate = target_dir / f"{today}_contextkit-audit-{index}.md"
            if not candidate.exists():
                target = candidate
                break
            index += 1
    target.write_text(report)
    return target


def cmd_audit(args: argparse.Namespace) -> None:
    root = _find_project_root()
    findings = _audit_context_files(root)
    report = _audit_report(root, findings)
    if args.write:
        written = _write_audit(root, report)
        result = {"project": str(root), "written": str(written), "rule_source": "contextkit guide audit",
                  "findings": [item.as_dict() for item in findings]}
        _emit(result, args.json)
    elif args.json:
        _emit({"project": str(root), "rule_source": "contextkit guide audit",
               "findings": [item.as_dict() for item in findings]}, True)
    else:
        _emit(report)


def cmd_audit_file(args: argparse.Namespace) -> None:
    root = _find_project_root()
    path = Path(args.path)
    if not path.is_absolute():
        path = root / path
    findings = _audit_context_files(root, [path])
    if args.json:
        _emit({"project": str(root), "rule_source": "contextkit guide audit",
               "findings": [item.as_dict() for item in findings]}, True)
    else:
        _emit(_audit_report(root, findings))


def _require_git_for_mutation(root: Path) -> None:
    if not (root / ".git").exists():
        _die("mutating operations require a git repository; run `git init` first", 6)


def cmd_groom(args: argparse.Namespace) -> None:
    root = _find_project_root()
    if args.apply:
        _require_git_for_mutation(root)
        _emit(
            "ContextKit v0 has no automatic groom patches yet.\n"
            "Run `contextkit audit --write`, review the report, and apply changes deliberately."
        )
        return
    findings = _audit_context_files(root)
    lines = ["# ContextKit Groom Plan", "", f"Project: `{root}`", ""]
    if not findings:
        lines.append("No audit findings to groom.")
    else:
        lines += [
            "Rule source:",
            "",
            "- Load `contextkit guide audit` for the audit walk.",
            "- For each finding, load its `rule_source` guide and repair the owning source.",
            "",
            f"Current finding count: {len(findings)}",
        ]
    _emit("\n".join(lines) + "\n")


def _tree_stats(path: Path) -> dict[str, int]:
    stats = {"files": 0, "dirs": 0}
    if not path.exists():
        return stats
    for child in path.rglob("*"):
        if child.is_dir():
            stats["dirs"] += 1
        elif child.is_file():
            stats["files"] += 1
    return stats


def _relative_file_set(path: Path) -> set[str]:
    if not path.is_dir():
        return set()
    files: set[str] = set()
    for child in path.rglob("*"):
        if child.is_file():
            files.add(child.relative_to(path).as_posix())
    return files


def _git_status_paths(root: Path, rels: list[str]) -> list[str]:
    if not (root / ".git").exists():
        return []
    try:
        proc = _run(["git", "status", "--porcelain", "--untracked-files=all", "--", *rels], root)
    except (OSError, subprocess.TimeoutExpired):
        return []
    if proc.returncode != 0:
        return []
    paths: list[str] = []
    for raw in proc.stdout.splitlines():
        if len(raw) < 4:
            continue
        path = raw[3:]
        if " -> " in path:
            path = path.split(" -> ", 1)[1]
        paths.append(path)
    return paths


def _visible_layer_steps(root: Path, sources: dict[str, str]) -> list[MigrationStep]:
    steps: list[MigrationStep] = []
    capabilities_source = _capabilities_dir_from_sources(sources).as_posix()
    for visible in ("context", "assets", "routines", "capabilities"):
        if visible == "capabilities" and capabilities_source == ".capabilities":
            target = root / ".capabilities"
            dirty = _git_status_paths(root, [".capabilities"])
            dirty_detail = ""
            if dirty:
                sample = ", ".join(f"`{item}`" for item in dirty[:8])
                dirty_detail = f" Git has uncommitted entries under this layer: {sample}" + (" ..." if len(dirty) > 8 else "")
            if target.exists():
                stats = _tree_stats(target)
                steps.append(MigrationStep(
                    title="Keep `.capabilities/`",
                    action="keep",
                    status="manual" if dirty else "ok",
                    detail=f"Configured capability source exists with {stats['files']} files and {stats['dirs']} directories.{dirty_detail}",
                ))
            else:
                steps.append(MigrationStep(
                    title="Create `.capabilities/`",
                    action="create",
                    status="ready",
                    detail="Configured capability source is absent. Create it before enabling capabilities.",
                ))
            continue
        legacy = root / f".{visible}"
        target = root / visible
        dirty = _git_status_paths(root, [f".{visible}", visible])
        dirty_detail = ""
        if dirty:
            sample = ", ".join(f"`{item}`" for item in dirty[:8])
            dirty_detail = f" Git has uncommitted entries under this layer: {sample}" + (" ..." if len(dirty) > 8 else "")
        if legacy.exists() and not target.exists():
            stats = _tree_stats(legacy)
            steps.append(MigrationStep(
                title=f"Rename `.{visible}/` to `{visible}/`",
                action="rename",
                status="manual" if dirty else "ready",
                detail=f"Legacy layer exists with {stats['files']} files and {stats['dirs']} directories; visible target is absent.{dirty_detail}",
                command=f"git mv .{visible} {visible}",
            ))
        elif legacy.exists() and target.exists():
            legacy_files = _relative_file_set(legacy)
            target_files = _relative_file_set(target)
            collisions = sorted(legacy_files & target_files)
            legacy_stats = _tree_stats(legacy)
            target_stats = _tree_stats(target)
            if collisions:
                steps.append(MigrationStep(
                    title=f"Merge `.{visible}/` into existing `{visible}/`",
                    action="merge",
                    status="manual",
                    detail=(
                        f"Both source and target exist. Legacy has {legacy_stats['files']} files; "
                        f"target has {target_stats['files']} files. {len(collisions)} relative paths collide: "
                        + ", ".join(f"`{item}`" for item in collisions[:8])
                        + (" ..." if len(collisions) > 8 else "")
                    ),
                ))
            else:
                steps.append(MigrationStep(
                    title=f"Merge `.{visible}/` into existing `{visible}/`",
                    action="merge",
                    status="manual" if dirty else "ready",
                    detail=(
                        f"Both source and target exist, but no file paths collide. Legacy has {legacy_stats['files']} files; "
                        f"target has {target_stats['files']} files. Preserve existing target-only content.{dirty_detail}"
                    ),
                    command=f"rsync -a .{visible}/ {visible}/ && git rm -r .{visible}",
                ))
        elif target.exists():
            stats = _tree_stats(target)
            steps.append(MigrationStep(
                title=f"Keep `{visible}/`",
                action="keep",
                status="manual" if dirty else "ok",
                detail=f"Visible layer already exists with {stats['files']} files and {stats['dirs']} directories.{dirty_detail}",
            ))
        else:
            steps.append(MigrationStep(
                title=f"Create `{visible}/`",
                action="create",
                status="ready",
                detail="Layer is absent. `contextkit init --with-layers` creates empty project body layers; `contextkit init --with-template` also creates starter context files.",
            ))
    return steps


def _bootstrap_steps(root: Path, sources: dict[str, str]) -> list[MigrationStep]:
    steps: list[MigrationStep] = []
    required = {
        ".contextkit/config.toml": root / CONFIG_REL,
        ".contextkit/README.md": root / README_REL,
        ".env.local": root / ".env.local",
    }
    for label, path in required.items():
        if path.exists():
            steps.append(MigrationStep(label, "keep", "ok", "Required bootstrap file already exists."))
        else:
            steps.append(MigrationStep(label, "create", "ready", "Missing required bootstrap file.", "contextkit adopt"))

    capabilities_dir = _capabilities_dir_from_sources(sources)
    settings_rel = capabilities_dir / "settings.json"
    settings = root / settings_rel
    legacy_settings = root / ".capabilities" / "settings.json"
    if settings.exists():
        steps.append(MigrationStep(settings_rel.as_posix(), "keep", "ok", "Capability gate already exists."))
    elif capabilities_dir.as_posix() != ".capabilities" and legacy_settings.exists():
        steps.append(MigrationStep(
            settings_rel.as_posix(),
            "move",
            "ready",
            "Capability gate exists under `.capabilities/` and will move with the visible layer migration.",
            "git mv .capabilities capabilities",
        ))
    else:
        steps.append(MigrationStep(settings_rel.as_posix(), "create", "ready", "Missing capability gate file.", "contextkit adopt --with-layers"))

    patterns = _gitignore_patterns(root)
    missing = [line for line in _required_gitignore_lines(capabilities_dir) if line not in patterns]
    if not (root / ".gitignore").exists():
        steps.append(MigrationStep(".gitignore", "create", "ready", "Missing .gitignore with ContextKit local/generated guards.", "contextkit adopt"))
    elif missing:
        steps.append(MigrationStep(
            ".gitignore guards",
            "update",
            "ready",
            "Missing guards: " + ", ".join(f"`{line}`" for line in missing),
            "contextkit adopt",
        ))
    else:
        steps.append(MigrationStep(".gitignore guards", "keep", "ok", "All ContextKit local/generated guards are present."))
    return steps


def _file_contains(path: Path, needle: str) -> bool:
    try:
        return needle in path.read_text()
    except OSError:
        return False


def _host_steps(root: Path) -> list[MigrationStep]:
    steps: list[MigrationStep] = []
    codex_build = root / ".codex" / "hooks" / "build-context.sh"
    if codex_build.exists():
        if _file_contains(codex_build, "contextkit build --target codex"):
            steps.append(MigrationStep("Codex build adapter", "keep", "ok", "`build-context.sh` already calls ContextKit."))
        else:
            steps.append(MigrationStep(
                "Codex build adapter",
                "replace",
                "ready",
                "Existing `.codex/hooks/build-context.sh` is a project-local compiler; ContextKit owns this adapter.",
                "contextkit install-hooks --target codex",
            ))
    else:
        steps.append(MigrationStep(
            "Codex build adapter",
            "create",
            "ready",
            "No Codex ContextKit adapter found.",
            "contextkit install-hooks --target codex",
        ))

    codex_hooks = root / ".codex" / "hooks.json"
    if codex_hooks.exists():
        if _file_contains(codex_hooks, ".codex/hooks/build-context.sh"):
            steps.append(MigrationStep("Codex SessionStart hook", "keep", "ok", "`hooks.json` already calls the build adapter."))
        else:
            steps.append(MigrationStep("Codex SessionStart hook", "update", "ready", "`hooks.json` does not call the ContextKit build adapter.", "contextkit install-hooks --target codex"))
    else:
        steps.append(MigrationStep("Codex SessionStart hook", "create", "ready", "No Codex hook file found.", "contextkit install-hooks --target codex"))

    codex_config = root / ".codex" / "config.toml"
    if codex_config.exists() and _file_contains(codex_config, ".codex/generated/context.md"):
        steps.append(MigrationStep("Codex fallback config", "keep", "ok", "Codex fallback reads `.codex/generated/context.md`."))
    else:
        steps.append(MigrationStep("Codex fallback config", "update", "ready", "Codex fallback includes `.codex/generated/context.md`.", "contextkit install-hooks --target codex"))

    claude_settings = root / ".claude" / "settings.json"
    if claude_settings.exists():
        if _file_contains(claude_settings, "contextkit build --target claude"):
            steps.append(MigrationStep("Claude SessionStart hook", "keep", "ok", "Claude hook already calls ContextKit."))
        else:
            steps.append(MigrationStep(
                "Claude SessionStart hook",
                "review",
                "manual",
                "Existing Claude hooks are present but do not call ContextKit; review before replacing or augmenting them.",
                "contextkit install-hooks --target claude",
            ))
    else:
        steps.append(MigrationStep("Claude SessionStart hook", "create", "ready", "No Claude settings hook found.", "contextkit install-hooks --target claude"))

    for rel in (".codex/generated/context.md", ".claude/rules/CONTEXT.md"):
        path = root / rel
        if path.exists():
            steps.append(MigrationStep(rel, "regenerate", "ready", "Generated output exists; rebuild after migration.", "contextkit build --target all"))
        else:
            steps.append(MigrationStep(rel, "create", "ready", "Generated output will be created by the ContextKit compiler.", "contextkit build --target all"))
    return steps


def _instruction_file_steps(root: Path) -> list[MigrationStep]:
    steps: list[MigrationStep] = []
    for rel in ("CLAUDE.md", "AGENTS.md"):
        path = root / rel
        if path.exists():
            steps.append(MigrationStep(
                rel,
                "review",
                "manual",
                "Root instruction file exists. Delete only if it duplicates compiled ContextKit output.",
            ))
    if not steps:
        steps.append(MigrationStep("Root instruction files", "keep", "ok", "No root `CLAUDE.md` or `AGENTS.md` found."))
    return steps


def _migration_plan(root: Path) -> dict[str, Any]:
    sources = _config(root)["sources"]
    sections = {
        "Project body layers": _visible_layer_steps(root, sources),
        "Bootstrap files": _bootstrap_steps(root, sources),
        "Host bindings": _host_steps(root),
        "Instruction files": _instruction_file_steps(root),
    }
    all_steps = [step for steps in sections.values() for step in steps]
    blockers = [step for step in all_steps if step.status == "blocked"]
    manual = [step for step in all_steps if step.status == "manual"]
    ready = [step for step in all_steps if step.status == "ready"]
    return {
        "project": str(root),
        "git": _git_state(root),
        "summary": {
            "ok": len(blockers) == 0,
            "ready": len(ready),
            "manual": len(manual),
            "blocked": len(blockers),
        },
        "rule_sources": ["contextkit guide migration"],
        "sections": {
            name: [step.as_dict() for step in steps]
            for name, steps in sections.items()
        },
    }


def _format_migration_plan(plan: dict[str, Any]) -> str:
    lines = ["# ContextKit Migration Plan", "", f"Project: `{plan['project']}`", ""]
    summary = plan["summary"]
    git = plan["git"]
    lines += [
        "Rule source:",
        "",
        "- `contextkit guide migration`",
        "",
        "Summary:",
        "",
        f"- Git present: {git.get('present')}",
        f"- Git dirty: {git.get('dirty')}",
        f"- Ready steps: {summary['ready']}",
        f"- Manual review steps: {summary['manual']}",
        f"- Blocked steps: {summary['blocked']}",
        "",
    ]
    for section, steps in plan["sections"].items():
        lines += [f"## {section}", ""]
        for step in steps:
            status = step["status"]
            lines += [
                f"### {step['title']}",
                "",
                f"- Action: `{step['action']}`",
                f"- Status: `{status}`",
                f"- Detail: {step['detail']}",
            ]
            if step.get("command"):
                lines.append(f"- Command: `{step['command']}`")
            lines.append("")
    lines += [
        "## Verification After Migration",
        "",
        "1. Load `contextkit guide migration`.",
        "2. Run `contextkit doctor`.",
        "3. Run `contextkit build --target all`.",
        "4. Run `contextkit audit` and follow its rule-source guide routing.",
        "5. Review generated `.codex/generated/context.md` and `.claude/rules/CONTEXT.md` before removing old project-local compilers.",
        "",
    ]
    return "\n".join(lines)


def cmd_migrate(args: argparse.Namespace) -> None:
    root = _find_project_root()
    if args.apply:
        _require_git_for_mutation(root)
        _die("contextkit migrate --apply is not implemented in v0; use --plan first", 6)
    plan = _migration_plan(root)
    if args.json:
        _emit(plan, True)
    else:
        _emit(_format_migration_plan(plan))


def cmd_guide(args: argparse.Namespace) -> None:
    topic = args.topic or "authoring"
    if topic not in GUIDE_TOPICS:
        _die(f"unknown guide topic: {topic}\nAvailable: {', '.join(GUIDE_TOPICS)}", 6)
    _emit(_read_bundle((Path("guides") / f"{topic}.md").as_posix()))


def cmd_templates(_: argparse.Namespace) -> None:
    lines = ["# ContextKit Templates", "", "Starter context template files:", ""]
    for rel in sorted(SKELETON_FILES):
        lines.append(f"- `{rel}`")
    lines += ["", "Run `contextkit init --with-template` to create missing binding, layers, and starter context files."]
    _emit("\n".join(lines) + "\n")


HELP = """contextkit — manager for repo-backed agent project bodies and runtime context.

Commands:
  contextkit help
  contextkit bootstrap [--target codex|claude] [--target ...] [--with-template] [--yes] [--json]
  contextkit doctor [--json]
  contextkit init [--with-layers|--with-template] [--json]
  contextkit adopt [--with-layers|--with-template] [--json]
  contextkit install-hooks --target codex|claude [--target ...]
  contextkit build --target codex|claude|all [--json]
  contextkit audit [--write] [--json]
  contextkit audit-file <path> [--json]
  contextkit groom --plan|--apply
  contextkit migrate --plan|--apply
  contextkit guide [bootstrap|authoring|validation|assets|routines|audit|destructive|migration|hooks|capabilities]
  contextkit templates
"""


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="contextkit", add_help=False)
    sub = parser.add_subparsers(dest="command")

    sub.add_parser("help", add_help=False).set_defaults(func=lambda _args: _emit(HELP))
    p = sub.add_parser("bootstrap")
    p.add_argument("--target", choices=["codex", "claude"], action="append")
    p.add_argument("--with-template", action="store_true")
    p.add_argument("--yes", action="store_true")
    p.add_argument("--json", action="store_true")
    p.set_defaults(func=cmd_bootstrap)

    p = sub.add_parser("doctor")
    p.add_argument("--json", action="store_true")
    p.set_defaults(func=cmd_doctor)

    p = sub.add_parser("init")
    init_group = p.add_mutually_exclusive_group()
    init_group.add_argument("--with-layers", action="store_true")
    init_group.add_argument("--with-template", action="store_true")
    p.add_argument("--binding-only", action="store_true", help=argparse.SUPPRESS)
    p.add_argument("--json", action="store_true")
    p.set_defaults(func=cmd_init, adopt=False, binding_only=False)

    p = sub.add_parser("adopt")
    adopt_group = p.add_mutually_exclusive_group()
    adopt_group.add_argument("--with-layers", action="store_true")
    adopt_group.add_argument("--with-template", action="store_true")
    p.add_argument("--json", action="store_true")
    p.set_defaults(func=cmd_init, adopt=True, binding_only=False)

    p = sub.add_parser("install-hooks")
    p.add_argument("--target", choices=["codex", "claude"], action="append", required=True)
    p.add_argument("--json", action="store_true")
    p.set_defaults(func=cmd_install_hooks)

    p = sub.add_parser("build")
    p.add_argument("--target", choices=["codex", "claude", "all"], default="codex")
    p.add_argument("--json", action="store_true")
    p.set_defaults(func=cmd_build)

    p = sub.add_parser("audit")
    p.add_argument("--write", action="store_true")
    p.add_argument("--json", action="store_true")
    p.set_defaults(func=cmd_audit)

    p = sub.add_parser("audit-file")
    p.add_argument("path")
    p.add_argument("--json", action="store_true")
    p.set_defaults(func=cmd_audit_file)

    p = sub.add_parser("groom")
    group = p.add_mutually_exclusive_group(required=True)
    group.add_argument("--plan", action="store_true")
    group.add_argument("--apply", action="store_true")
    p.set_defaults(func=cmd_groom)

    p = sub.add_parser("migrate")
    group = p.add_mutually_exclusive_group(required=True)
    group.add_argument("--plan", action="store_true")
    group.add_argument("--apply", action="store_true")
    p.add_argument("--json", action="store_true")
    p.set_defaults(func=cmd_migrate)

    p = sub.add_parser("guide")
    p.add_argument("topic", nargs="?")
    p.set_defaults(func=cmd_guide)

    sub.add_parser("templates").set_defaults(func=cmd_templates)
    return parser


def main(argv: list[str] | None = None) -> int:
    argv = list(sys.argv[1:] if argv is None else argv)
    if not argv:
        argv = ["help"]
    parser = build_parser()
    args = parser.parse_args(argv)
    if not hasattr(args, "func"):
        _emit(HELP)
        return 0
    try:
        args.func(args)
        return 0
    except ContextKitError as exc:
        sys.stderr.write(str(exc) + "\n")
        return exc.exit_code
    except BrokenPipeError:
        return 0


if __name__ == "__main__":
    raise SystemExit(main())
