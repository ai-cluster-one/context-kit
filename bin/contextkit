# CONTEXTKIT_ENV=local
"""


class ContextKitError(Exception):
    def __init__(self, message: str, exit_code: int = 1) -> None:
        super().__init__(message)
        self.exit_code = exit_code


@dataclass(frozen=True)
class ContextFile:
    path: Path
    rel: Path
    title: str
    description: str
    load: str
    order: int
    body: str
    raw_frontmatter: dict[str, str]
    source: str = "project"


@dataclass(frozen=True)
class MemoryFile:
    path: Path
    rel: Path
    body: str


@dataclass(frozen=True)
class MemoryLocation:
    path: Path
    reference: str
    external: bool


@dataclass(frozen=True)
class UpdateSource:
    base: str
    ref: str
    base_origin: str
    ref_origin: str


@dataclass(frozen=True)
class InstallPaths:
    home: Path
    bin_dir: Path
    manager: Path
    link: Path


@dataclass
class Finding:
    severity: str
    code: str
    path: str
    message: str
    hint: str = ""
    rule_source: str = ""

    def as_dict(self) -> dict[str, str]:
        out = {
            "severity": self.severity,
            "code": self.code,
            "path": self.path,
            "message": self.message,
        }
        if self.rule_source:
            out["rule_source"] = self.rule_source
        if self.hint:
            out["hint"] = self.hint
        return out


@dataclass
class MigrationStep:
    title: str
    action: str
    status: str
    detail: str
    command: str = ""

    def as_dict(self) -> dict[str, str]:
        out = {
            "title": self.title,
            "action": self.action,
            "status": self.status,
            "detail": self.detail,
        }
        if self.command:
            out["command"] = self.command
        return out


def _die(message: str, exit_code: int = 1) -> None:
    raise ContextKitError(message, exit_code)


def _emit(value: Any, as_json: bool = False) -> None:
    if as_json:
        sys.stdout.write(json.dumps(value, ensure_ascii=False, indent=2) + "\n")
    elif isinstance(value, str):
        sys.stdout.write(value if value.endswith("\n") else value + "\n")
    else:
        sys.stdout.write(json.dumps(value, ensure_ascii=False, indent=2) + "\n")


def _script_path() -> Path:
    try:
        return Path(sys.argv[0]).resolve()
    except OSError:
        return Path(__file__).resolve()


def _bundle_candidates() -> list[Path]:
    candidates: list[Path] = []
    env = os.environ.get("CONTEXTKIT_BUNDLE_DIR")
    if env:
        candidates.append(Path(env).expanduser())
    legacy_env = os.environ.get("CONTEXTKIT_DOCTRINE_DIR")
    if legacy_env:
        candidates.append(Path(legacy_env).expanduser())

    script = _script_path()
    # Repo checkout: <repo>/bin/contextkit -> <repo>/bundle.
    # Installed manager: ~/.contextkit/.manager/contextkit -> ~/.contextkit/bundle.
    # Local bundle fallback: <dir>/contextkit -> <dir>/bundle.
    # Legacy doctrine paths are compatibility bridges, not canonical product layout.
    candidates += [
        script.parent.parent / BUNDLE_REL,
        script.parent / BUNDLE_REL,
        Path.home() / ".contextkit" / BUNDLE_REL,
        script.parent.parent / LEGACY_DOCTRINE_REL,
        script.parent / LEGACY_DOCTRINE_REL,
        Path.home() / ".contextkit" / LEGACY_DOCTRINE_REL,
    ]
    out: list[Path] = []
    seen: set[str] = set()
    for candidate in candidates:
        key = str(candidate)
        if key not in seen:
            out.append(candidate)
            seen.add(key)
    return out


def _guide_candidates() -> list[Path]:
    candidates: list[Path] = []
    env = os.environ.get("CONTEXTKIT_GUIDES_DIR")
    if env:
        candidates.append(Path(env).expanduser())

    script = _script_path()
    candidates += [
        script.parent.parent / GUIDES_REL,
        script.parent / GUIDES_REL,
        Path.home() / ".contextkit" / GUIDES_REL,
    ]
    out: list[Path] = []
    seen: set[str] = set()
    for candidate in candidates:
        key = str(candidate)
        if key not in seen:
            out.append(candidate)
            seen.add(key)
    return out


def _template_candidates() -> list[Path]:
    candidates: list[Path] = []
    env = os.environ.get("CONTEXTKIT_TEMPLATES_DIR")
    if env:
        candidates.append(Path(env).expanduser())

    script = _script_path()
    candidates += [
        script.parent.parent / TEMPLATES_REL,
        script.parent / TEMPLATES_REL,
        Path.home() / ".contextkit" / TEMPLATES_REL,
    ]
    out: list[Path] = []
    seen: set[str] = set()
    for candidate in candidates:
        key = str(candidate)
        if key not in seen:
            out.append(candidate)
            seen.add(key)
    return out


def _remote_ref() -> str:
    value = os.environ.get("CONTEXTKIT_REF")
    if value is None:
        value = os.environ.get("CONTEXTKIT_TAG")
    return _validate_source_ref("main" if value is None else value, "ContextKit remote ref")


def _remote_base() -> str:
    return _validate_source_base(os.environ.get("CONTEXTKIT_RAW_BASE", DEFAULT_RAW_BASE), "CONTEXTKIT_RAW_BASE")


def _configured_path(value: str | Path, label: str) -> Path:
    raw = Path(value).expanduser()
    lexical = Path(os.path.abspath(str(raw)))
    if lexical.is_symlink():
        _die(f"ContextKit update needs review: {label} is a symlink at the managed boundary", 7)
    try:
        resolved = lexical.resolve(strict=False)
    except OSError as exc:
        _die(f"ContextKit update cannot resolve {label}: {exc}", 7)
    return resolved


def _configured_bin_dir() -> Path:
    override = os.environ.get("CONTEXTKIT_BIN")
    if override is not None:
        if not override.strip():
            _die("CONTEXTKIT_BIN must not be empty", 6)
        return _configured_path(override, "CONTEXTKIT_BIN")
    on_path: set[Path] = set()
    for value in os.environ.get("PATH", "").split(os.pathsep):
        if not value:
            continue
        try:
            on_path.add(Path(value).expanduser().resolve())
        except OSError:
            continue
    for candidate in (Path.home() / ".local" / "bin", Path.home() / "bin"):
        try:
            if candidate.is_dir() and candidate.resolve() in on_path:
                return _configured_path(candidate, "ContextKit bin directory")
        except OSError:
            continue
    return _configured_path(Path.home() / ".local" / "bin", "ContextKit bin directory")


def _install_paths() -> InstallPaths:
    home_value = os.environ.get("CONTEXTKIT_HOME")
    if home_value is not None and not home_value.strip():
        _die("CONTEXTKIT_HOME must not be empty", 6)
    home = _configured_path(home_value or (Path.home() / ".contextkit"), "CONTEXTKIT_HOME")
    bin_dir = _configured_bin_dir()
    if home == Path(home.anchor) or bin_dir == Path(bin_dir.anchor):
        _die("ContextKit update needs review: managed paths cannot be filesystem roots", 7)
    if home == bin_dir or home in bin_dir.parents or bin_dir in home.parents:
        _die("ContextKit update needs review: CONTEXTKIT_HOME and CONTEXTKIT_BIN must not overlap", 7)
    paths = InstallPaths(
        home=home,
        bin_dir=bin_dir,
        manager=home / ".manager" / "contextkit",
        link=bin_dir / "contextkit",
    )
    _validate_existing_install_paths(paths)
    _validate_no_update_residue(paths)
    return paths


def _residue_prefix(paths: InstallPaths, kind: str) -> str:
    owner = hashlib.sha256(str(paths.home).encode("utf-8")).hexdigest()[:12]
    return f".contextkit-{owner}-{kind}-"


def _validate_no_update_residue(paths: InstallPaths) -> None:
    residues: list[Path] = []
    if paths.home.parent.is_dir():
        for kind in ("stage", "backup"):
            residues.extend(sorted(paths.home.parent.glob(_residue_prefix(paths, kind) + "*")))
    if paths.bin_dir.is_dir():
        residues.extend(sorted(paths.bin_dir.glob(_residue_prefix(paths, "link") + "*")))
    if residues:
        rendered = ", ".join(str(path) for path in residues)
        _die(f"ContextKit update needs review: managed cleanup residue exists: {rendered}", 7)


def _cleanup_tree(path: Path) -> str | None:
    if not path.exists() and not path.is_symlink():
        return None
    try:
        if path.is_dir() and not path.is_symlink():
            shutil.rmtree(path)
        else:
            path.unlink()
    except OSError as exc:
        return str(exc)
    if path.exists() or path.is_symlink():
        return "path still exists after cleanup"
    return None


def _validate_existing_install_paths(paths: InstallPaths) -> None:
    if paths.home.exists() and not paths.home.is_dir():
        _die(f"ContextKit update needs review: managed root is not a directory: {paths.home}", 7)
    if paths.bin_dir.exists() and not paths.bin_dir.is_dir():
        _die(f"ContextKit update needs review: bin path is not a directory: {paths.bin_dir}", 7)
    for name in (".manager", "bundle", "guides", "templates"):
        path = paths.home / name
        if path.is_symlink() or (path.exists() and not path.is_dir()):
            _die(f"ContextKit update needs review: managed directory has foreign shape: {path}", 7)
    for name in (RELEASE_MANIFEST, INSTALL_PROVENANCE):
        path = paths.home / name
        if path.is_symlink() or (path.exists() and not path.is_file()):
            _die(f"ContextKit update needs review: managed state file has foreign shape: {path}", 7)
    if paths.manager.is_symlink() or (paths.manager.exists() and not paths.manager.is_file()):
        _die(f"ContextKit update needs review: manager has foreign shape: {paths.manager}", 7)
    if paths.link.is_symlink():
        try:
            target = paths.link.resolve(strict=False)
        except OSError as exc:
            _die(f"ContextKit update cannot inspect its command symlink: {exc}", 7)
        if target != paths.manager:
            _die(f"ContextKit update needs review: command symlink is owned by another target: {paths.link}", 7)
    elif paths.link.exists():
        _die(f"ContextKit update needs review: command path is not a managed symlink: {paths.link}", 7)


def _validate_source_base(value: Any, owner: str, exit_code: int = 6) -> str:
    if not isinstance(value, str) or not value or value != value.strip():
        _die(f"invalid ContextKit update source in {owner}", exit_code)
    try:
        parsed = urllib.parse.urlsplit(value)
    except (TypeError, ValueError):
        _die(f"invalid ContextKit update source in {owner}", exit_code)
    if parsed.username is not None or parsed.password is not None or parsed.query or parsed.fragment:
        _die(f"invalid ContextKit update source in {owner}: credentials, query, and fragment are not allowed", exit_code)
    if parsed.scheme not in {"https", "http", "file"}:
        _die(f"invalid ContextKit update source in {owner}: expected an https, http, or file URL", exit_code)
    scheme = parsed.scheme.lower()
    if scheme == "file":
        if parsed.netloc not in {"", "localhost"}:
            _die(f"invalid ContextKit update source in {owner}: remote file hosts are not allowed", exit_code)
        try:
            local_path = Path(urllib.request.url2pathname(parsed.path))
        except (OSError, ValueError):
            _die(f"invalid ContextKit update source in {owner}: malformed local-file path", exit_code)
        if not local_path.is_absolute() or local_path == Path(local_path.anchor) or "\\" in parsed.path or any(ord(char) < 32 for char in parsed.path):
            _die(f"invalid ContextKit update source in {owner}: local-file path must be absolute", exit_code)
        try:
            return local_path.resolve(strict=False).as_uri().rstrip("/")
        except (OSError, ValueError):
            _die(f"invalid ContextKit update source in {owner}: malformed local-file path", exit_code)
    if not parsed.netloc or parsed.path and not parsed.path.startswith("/"):
        _die(f"invalid ContextKit update source in {owner}: network host or path is malformed", exit_code)
    try:
        host = parsed.hostname
        port = parsed.port
    except ValueError:
        _die(f"invalid ContextKit update source in {owner}: network host or port is malformed", exit_code)
    if not host or port is not None and not (1 <= port <= 65535):
        _die(f"invalid ContextKit update source in {owner}: network host or port is malformed", exit_code)
    try:
        if ":" in host:
            canonical_host = f"[{ipaddress.IPv6Address(host).compressed}]"
        else:
            try:
                canonical_host = str(ipaddress.IPv4Address(host))
            except ipaddress.AddressValueError:
                canonical_host = host.encode("idna").decode("ascii").lower()
                labels = canonical_host.split(".")
                if any(not label or len(label) > 63 or not re.fullmatch(r"[A-Za-z0-9](?:[A-Za-z0-9-]*[A-Za-z0-9])?", label) for label in labels):
                    raise ValueError("invalid host")
    except (UnicodeError, ValueError, ipaddress.AddressValueError):
        _die(f"invalid ContextKit update source in {owner}: network host is malformed", exit_code)
    if "\\" in parsed.path or any(ord(char) < 32 for char in parsed.path):
        _die(f"invalid ContextKit update source in {owner}: network path is malformed", exit_code)
    netloc = canonical_host + (f":{port}" if port is not None else "")
    path = parsed.path.rstrip("/")
    return urllib.parse.urlunsplit((scheme, netloc, path, "", ""))


def _validate_source_ref(value: Any, owner: str, exit_code: int = 6) -> str:
    if not isinstance(value, str) or not value or value != value.strip() or len(value) > 200:
        _die(f"invalid ContextKit update ref in {owner}", exit_code)
    if value.startswith("/") or value.endswith("/") or "\\" in value or any(ord(char) < 32 for char in value):
        _die(f"invalid ContextKit update ref in {owner}", exit_code)
    components = value.split("/")
    for component in components:
        if not component or component in {".", ".."} or not re.fullmatch(r"[A-Za-z0-9_@+-][A-Za-z0-9._@+-]*", component):
            _die(f"invalid ContextKit update ref in {owner}", exit_code)
        decoded = component
        for _ in range(3):
            next_value = urllib.parse.unquote(decoded)
            if next_value == decoded:
                break
            decoded = next_value
        if decoded in {".", ".."} or "/" in decoded or "\\" in decoded:
            _die(f"invalid ContextKit update ref in {owner}", exit_code)
    return value


def _release_url(source: UpdateSource, rel: str = RELEASE_MANIFEST) -> str:
    quoted = "/".join(urllib.parse.quote(part) for part in rel.split("/"))
    quoted_ref = "/".join(urllib.parse.quote(part) for part in source.ref.split("/"))
    return f"{source.base}/{quoted_ref}/{quoted}"


def _fetch_update_bytes(source: UpdateSource, rel: str) -> bytes:
    url = _release_url(source, rel)
    try:
        with urllib.request.urlopen(url, timeout=30) as response:
            content = response.read(MAX_UPDATE_FILE_BYTES + 1)
    except (OSError, ValueError, urllib.error.URLError, http.client.HTTPException) as exc:
        _die(f"ContextKit update fetch failed: {url}\n{exc}", 5)
    if len(content) > MAX_UPDATE_FILE_BYTES:
        _die(f"ContextKit update source is too large: {url}", 6)
    return content


def _release_version(value: Any, source: str, exit_code: int = 6) -> tuple[int, int, int]:
    if not isinstance(value, str) or not re.fullmatch(r"(?:0|[1-9][0-9]{0,5})\.(?:0|[1-9][0-9]{0,5})\.(?:0|[1-9][0-9]{0,5})", value):
        _die(f"invalid ContextKit release version in {source}: expected MAJOR.MINOR.PATCH", exit_code)
    try:
        parts = tuple(int(part) for part in value.split("."))
    except (TypeError, ValueError, OverflowError):
        _die(f"invalid ContextKit release version in {source}: expected bounded integers", exit_code)
    if any(part > 999999 for part in parts):
        _die(f"invalid ContextKit release version in {source}: component exceeds 999999", exit_code)
    return parts  # type: ignore[return-value]


def _validate_release_manifest(value: Any, source: str, exit_code: int = 6) -> dict[str, Any]:
    if not isinstance(value, dict):
        _die(f"invalid ContextKit release manifest in {source}: expected a JSON object", exit_code)
    if set(value) != {"schema", "version", "files"}:
        _die(f"invalid ContextKit release manifest in {source}: unexpected or missing fields", exit_code)
    schema = value.get("schema")
    if not isinstance(schema, int) or isinstance(schema, bool) or schema != 1:
        _die(f"invalid ContextKit release manifest in {source}: unsupported schema", exit_code)
    _release_version(value.get("version"), source, exit_code)
    files = value.get("files")
    if not isinstance(files, dict) or not files:
        _die(f"invalid ContextKit release manifest in {source}: files must be a non-empty object", exit_code)
    required = {"bin/contextkit", "bundle/runtime.md"}
    seen: set[str] = set()
    for rel, digest in files.items():
        if not isinstance(rel, str) or not rel or "\\" in rel or any(ord(char) < 32 for char in rel):
            _die(f"invalid ContextKit release manifest in {source}: file path is unsafe", exit_code)
        try:
            path = Path(rel)
        except (OSError, ValueError):
            _die(f"invalid ContextKit release manifest in {source}: file path is unsafe", exit_code)
        allowed = rel == "bin/contextkit" or rel.startswith(PRODUCT_FILE_PREFIXES)
        if path.is_absolute() or any(part in {"", ".", ".."} or part.startswith(".") for part in path.parts) or path.as_posix() != rel or not allowed:
            _die(f"invalid ContextKit release path in {source}: {rel}", exit_code)
        if rel in seen:
            _die(f"duplicate ContextKit release path in {source}: {rel}", exit_code)
        if not isinstance(digest, str) or not re.fullmatch(r"[0-9a-f]{64}", digest):
            _die(f"invalid sha256 for {rel} in {source}", exit_code)
        seen.add(rel)
    ordered = sorted(seen)
    for index, rel in enumerate(ordered):
        prefix = rel + "/"
        if any(other.startswith(prefix) for other in ordered[index + 1:]):
            _die(f"invalid ContextKit release manifest in {source}: file/directory path collision", exit_code)
    missing = sorted(required - seen)
    if missing:
        _die(f"invalid ContextKit release manifest in {source}: missing {', '.join(missing)}", exit_code)
    if not any(rel.startswith("guides/") for rel in seen):
        _die(f"invalid ContextKit release manifest in {source}: no guides", exit_code)
    if not any(rel.startswith("templates/") for rel in seen):
        _die(f"invalid ContextKit release manifest in {source}: no templates", exit_code)
    return value


def _manifest_bytes(value: dict[str, Any]) -> bytes:
    return (json.dumps(value, ensure_ascii=False, indent=2, sort_keys=True) + "\n").encode("utf-8")


def _json_without_duplicates(content: bytes, source: str, exit_code: int) -> Any:
    def object_pairs(pairs: list[tuple[str, Any]]) -> dict[str, Any]:
        value: dict[str, Any] = {}
        for key, item in pairs:
            if key in value:
                raise ValueError("duplicate JSON object key")
            value[key] = item
        return value

    try:
        return json.loads(content.decode("utf-8"), object_pairs_hook=object_pairs)
    except (UnicodeError, json.JSONDecodeError, ValueError) as exc:
        _die(f"invalid ContextKit JSON in {source}: {exc}", exit_code)


def _remote_release(source: UpdateSource) -> tuple[dict[str, Any], bytes, str]:
    url = _release_url(source)
    content = _fetch_update_bytes(source, RELEASE_MANIFEST)
    value = _json_without_duplicates(content, url, 6)
    manifest = _validate_release_manifest(value, url)
    pin = os.environ.get("CONTEXTKIT_SHA256")
    if pin is not None:
        if not re.fullmatch(r"[0-9a-f]{64}", pin):
            _die("CONTEXTKIT_SHA256 must be a lowercase sha256 digest", 6)
        if manifest["files"].get("bin/contextkit") != pin:
            _die("ContextKit update manager digest does not match CONTEXTKIT_SHA256", 6)
    return manifest, _manifest_bytes(manifest), url


def _installed_release(home: Path) -> tuple[dict[str, Any] | None, bytes | None]:
    path = home / RELEASE_MANIFEST
    if not path.exists():
        return None, None
    try:
        content = path.read_bytes()
    except OSError as exc:
        _die(f"installed ContextKit release manifest is invalid: {path}\n{exc}", 7)
    value = _json_without_duplicates(content, str(path), 7)
    manifest = _validate_release_manifest(value, str(path), 7)
    return manifest, _manifest_bytes(manifest)


def _installed_provenance(home: Path, current: dict[str, Any] | None, current_bytes: bytes | None) -> tuple[dict[str, Any] | None, list[str]]:
    path = home / INSTALL_PROVENANCE
    if not path.exists():
        return None, ([f"missing managed provenance: {path}"] if current is not None else [])
    if current is None or current_bytes is None:
        _die(f"ContextKit update needs review: provenance exists without a release manifest: {path}", 7)
    try:
        content = path.read_bytes()
    except OSError as exc:
        _die(f"ContextKit update cannot read installed provenance: {exc}", 7)
    value = _json_without_duplicates(content, str(path), 7)
    schema = value.get("schema") if isinstance(value, dict) else None
    if not isinstance(value, dict) or set(value) != {"schema", "version", "manifest_sha256", "source"} or not isinstance(schema, int) or isinstance(schema, bool) or schema != 1:
        _die(f"ContextKit update needs review: invalid installed provenance schema: {path}", 7)
    _release_version(value.get("version"), str(path), 7)
    if value.get("version") != current.get("version"):
        _die(f"ContextKit update needs review: installed provenance version does not match release manifest", 7)
    expected_hash = hashlib.sha256(current_bytes).hexdigest()
    if value.get("manifest_sha256") != expected_hash:
        _die(f"ContextKit update needs review: installed provenance manifest hash does not match release manifest", 7)
    source = value.get("source")
    if not isinstance(source, dict) or set(source) != {"base", "ref", "manifest"}:
        _die(f"ContextKit update needs review: installed provenance source is invalid", 7)
    base = _validate_source_base(source.get("base"), "installed provenance", 7)
    ref = _validate_source_ref(source.get("ref"), "installed provenance", 7)
    installed_source = UpdateSource(base, ref, "installed", "installed")
    if source.get("manifest") != _release_url(installed_source):
        _die(f"ContextKit update needs review: installed provenance manifest URL is inconsistent", 7)
    return value, []


def _update_source(provenance: dict[str, Any] | None) -> UpdateSource:
    installed_source = provenance.get("source") if provenance else {}
    explicit_base = os.environ.get("CONTEXTKIT_RAW_BASE")
    explicit_ref = os.environ.get("CONTEXTKIT_REF")
    if explicit_ref is None:
        explicit_ref = os.environ.get("CONTEXTKIT_TAG")
    if explicit_base is not None:
        base = _validate_source_base(explicit_base, "CONTEXTKIT_RAW_BASE")
        base_origin = "environment"
    elif installed_source:
        base = _validate_source_base(installed_source.get("base"), "installed provenance", 7)
        base_origin = "installed"
    else:
        base = DEFAULT_RAW_BASE
        base_origin = "default"
    if explicit_ref is not None:
        ref = _validate_source_ref(explicit_ref, "CONTEXTKIT_REF")
        ref_origin = "environment"
    elif installed_source:
        ref = _validate_source_ref(installed_source.get("ref"), "installed provenance", 7)
        ref_origin = "installed"
    else:
        ref = "main"
        ref_origin = "default"
    return UpdateSource(base, ref, base_origin, ref_origin)


def _installed_payload_findings(home: Path, manifest: dict[str, Any]) -> list[str]:
    findings: list[str] = []
    expected_destinations = {_update_destination(rel).as_posix() for rel in manifest["files"]}
    for rel, expected in sorted(manifest["files"].items()):
        path = home / _update_destination(rel)
        if not path.is_file() or path.is_symlink():
            findings.append(f"missing or non-canonical installed file: {path}")
            continue
        try:
            actual = hashlib.sha256(path.read_bytes()).hexdigest()
        except OSError as exc:
            findings.append(f"cannot read installed file {path}: {exc}")
            continue
        if actual != expected:
            findings.append(f"installed checksum differs: {path}")
    for directory in ("bundle", "guides", "templates"):
        root = home / directory
        if not root.is_dir():
            continue
        for path in sorted(item for item in root.rglob("*") if item.is_file() or item.is_symlink()):
            rel = path.relative_to(home).as_posix()
            if rel not in expected_destinations:
                findings.append(f"untracked installed file: {path}")
    return findings


def _update_status() -> tuple[dict[str, Any], dict[str, Any], bytes, UpdateSource, InstallPaths]:
    paths = _install_paths()
    current, current_bytes = _installed_release(paths.home)
    provenance, state_findings = _installed_provenance(paths.home, current, current_bytes)
    source = _update_source(provenance)
    if provenance is not None:
        installed_channel = provenance["source"]
        if source.base != installed_channel["base"] or source.ref != installed_channel["ref"]:
            state_findings.append("selected update source differs from installed managed provenance")
    remote, remote_bytes, manifest_url = _remote_release(source)
    result: dict[str, Any] = {
        "status": "update_available",
        "changed": False,
        "current": None if current is None else {
            "version": current["version"],
            "manifest_sha256": hashlib.sha256(current_bytes or b"").hexdigest(),
        },
        "available": {
            "version": remote["version"],
            "manifest_sha256": hashlib.sha256(remote_bytes).hexdigest(),
        },
        "source": {
            "base": source.base,
            "ref": source.ref,
            "manifest": manifest_url,
            "base_origin": source.base_origin,
            "ref_origin": source.ref_origin,
        },
        "installed_source": provenance,
        "install_home": str(paths.home),
    }
    if current is None:
        result["reason"] = "no installed release manifest"
        return result, remote, remote_bytes, source, paths
    current_version = _release_version(current["version"], str(paths.home / RELEASE_MANIFEST), 7)
    remote_version = _release_version(remote["version"], manifest_url)
    if remote_version < current_version:
        _die(
            f"ContextKit update needs review: source version {remote['version']} is older than installed version {current['version']}",
            7,
        )
    if remote_version == current_version and current_bytes != remote_bytes:
        _die(
            f"ContextKit update needs review: version {remote['version']} has different release manifests",
            7,
        )
    state_findings += _installed_payload_findings(paths.home, current)
    if not paths.link.is_symlink():
        state_findings.append(f"missing managed command symlink: {paths.link}")
    if state_findings:
        result["reason"] = "installed managed state differs from its release contract"
        result["findings"] = state_findings
        return result, remote, remote_bytes, source, paths
    if current_bytes == remote_bytes:
        result["status"] = "up_to_date"
        result["reason"] = "installed and available release manifests match"
    else:
        result["reason"] = "a newer release is available"
    return result, remote, remote_bytes, source, paths


def _update_destination(rel: str) -> Path:
    path = Path(rel)
    if rel == "bin/contextkit":
        return Path(".manager") / "contextkit"
    return path


def _stage_update(paths: InstallPaths, source: UpdateSource, manifest: dict[str, Any], manifest_bytes: bytes) -> Path:
    paths.home.parent.mkdir(parents=True, exist_ok=True)
    stage = Path(tempfile.mkdtemp(prefix=_residue_prefix(paths, "stage"), dir=str(paths.home.parent)))
    try:
        for rel, expected in sorted(manifest["files"].items()):
            content = _fetch_update_bytes(source, rel)
            actual = hashlib.sha256(content).hexdigest()
            if actual != expected:
                _die(f"ContextKit update checksum mismatch for {rel}: expected {expected}, got {actual}", 6)
            if rel == "bin/contextkit" and os.environ.get("CONTEXTKIT_SHA256") not in {None, actual}:
                _die("downloaded ContextKit manager does not match CONTEXTKIT_SHA256", 6)
            destination = stage / _update_destination(rel)
            destination.parent.mkdir(parents=True, exist_ok=True)
            destination.write_bytes(content)
        manager = stage / ".manager" / "contextkit"
        content = manager.read_bytes()
        if not content.startswith(b"#!/usr/bin/env python3"):
            _die("fetched bin/contextkit does not look like the ContextKit manager", 6)
        try:
            compile(content.decode("utf-8"), "bin/contextkit", "exec")
        except (UnicodeError, SyntaxError) as exc:
            _die(f"fetched bin/contextkit does not compile: {exc}", 6)
        manager.chmod(manager.stat().st_mode | stat.S_IXUSR | stat.S_IXGRP | stat.S_IXOTH)
        (stage / RELEASE_MANIFEST).write_bytes(manifest_bytes)
        provenance = {
            "schema": 1,
            "version": manifest["version"],
            "manifest_sha256": hashlib.sha256(manifest_bytes).hexdigest(),
            "source": {"base": source.base, "ref": source.ref, "manifest": _release_url(source)},
        }
        (stage / INSTALL_PROVENANCE).write_bytes(_manifest_bytes(provenance))
        return stage
    except BaseException:
        cleanup_error = _cleanup_tree(stage)
        if cleanup_error:
            _die(
                f"ContextKit update preparation failed and stage cleanup is incomplete; residue preserved at {stage}: {cleanup_error}",
                7,
            )
        raise


def _replace_install(paths: InstallPaths, stage: Path) -> str:
    _validate_existing_install_paths(paths)
    paths.home.mkdir(parents=True, exist_ok=True)
    paths.bin_dir.mkdir(parents=True, exist_ok=True)
    backup = Path(tempfile.mkdtemp(prefix=_residue_prefix(paths, "backup"), dir=str(paths.home.parent)))
    names = [".manager", "bundle", "guides", "templates", RELEASE_MANIFEST, INSTALL_PROVENANCE]
    moved_old: list[str] = []
    installed_new: list[str] = []
    try:
        for name in names:
            destination = paths.home / name
            incoming = stage / name
            if destination.exists() or destination.is_symlink():
                os.replace(destination, backup / name)
                moved_old.append(name)
            os.replace(incoming, destination)
            installed_new.append(name)
        link_stage = Path(tempfile.mkdtemp(prefix=_residue_prefix(paths, "link"), dir=str(paths.bin_dir)))
        temp_link = link_stage / "contextkit"
        try:
            temp_link.symlink_to(paths.manager)
            os.replace(temp_link, paths.link)
        finally:
            cleanup_error = _cleanup_tree(link_stage)
            if cleanup_error:
                _die(
                    f"ContextKit update command-link cleanup is incomplete; residue preserved at {link_stage}: {cleanup_error}",
                    7,
                )
    except BaseException as original:
        rollback_errors: list[str] = []
        for name in reversed(installed_new):
            destination = paths.home / name
            try:
                if destination.is_dir() and not destination.is_symlink():
                    shutil.rmtree(destination)
                else:
                    destination.unlink(missing_ok=True)
            except OSError as exc:
                rollback_errors.append(f"remove {destination}: {exc}")
        for name in reversed(moved_old):
            saved = backup / name
            if saved.exists() or saved.is_symlink():
                try:
                    os.replace(saved, paths.home / name)
                except OSError as exc:
                    rollback_errors.append(f"restore {name}: {exc}")
        if rollback_errors:
            _die(
                "ContextKit update failed and rollback is incomplete; "
                f"backup preserved at {backup}; " + "; ".join(rollback_errors),
                7,
            )
        cleanup_error = _cleanup_tree(backup)
        if cleanup_error:
            _die(
                "ContextKit update failed; rollback completed but backup cleanup is incomplete; "
                f"residue preserved at {backup}: {cleanup_error}",
                7,
            )
        raise original
    cleanup_error = _cleanup_tree(backup)
    if cleanup_error:
        _die(
            f"ContextKit was installed, but backup cleanup is incomplete; residue preserved at {backup}: {cleanup_error}",
            7,
        )
    return str(paths.link)


def _apply_update(paths: InstallPaths, source: UpdateSource, manifest: dict[str, Any], manifest_bytes: bytes) -> str:
    stage = _stage_update(paths, source, manifest, manifest_bytes)
    try:
        result = _replace_install(paths, stage)
    except BaseException as original:
        cleanup_error = _cleanup_tree(stage)
        if cleanup_error:
            _die(
                f"ContextKit update failed and stage cleanup is incomplete; residue preserved at {stage}: {cleanup_error}",
                7,
            )
        raise original
    cleanup_error = _cleanup_tree(stage)
    if cleanup_error:
        _die(
            f"ContextKit was installed, but stage cleanup is incomplete; residue preserved at {stage}: {cleanup_error}",
            7,
        )
    return result


def cmd_update(args: argparse.Namespace) -> None:
    if args.apply and not args.yes and not (sys.stdin.isatty() and sys.stderr.isatty()):
        _die("contextkit update --apply requires --yes when no interactive terminal is available", 6)
    status, manifest, manifest_bytes, source, paths = _update_status()
    if args.check or status["status"] == "up_to_date":
        _emit(status, args.json)
        return
    if not args.yes:
        sys.stderr.write(
            f"Install ContextKit {manifest['version']} from {source.base} at ref {source.ref}? [y/N] "
        )
        answer = sys.stdin.readline().strip().lower()
        if answer not in {"y", "yes"}:
            _die("ContextKit update aborted", 1)
    link = _apply_update(paths, source, manifest, manifest_bytes)
    installed_manifest, installed_bytes = _installed_release(paths.home)
    installed_provenance, post_findings = _installed_provenance(paths.home, installed_manifest, installed_bytes)
    if installed_manifest is None or installed_bytes is None or installed_provenance is None or post_findings:
        _die("ContextKit update completed but installed state could not be verified", 7)
    status.update({
        "status": "updated",
        "changed": True,
        "symlink": link,
        "current": {
            "version": installed_manifest["version"],
            "manifest_sha256": hashlib.sha256(installed_bytes).hexdigest(),
        },
        "installed_source": installed_provenance,
        "reason": "installed release and managed provenance match the selected source",
    })
    status.pop("findings", None)
    _emit(status, args.json)


def _fetch_bundle(rel: Path) -> str | None:
    url = f"{_remote_base()}/{_remote_ref()}/{BUNDLE_REL.as_posix()}/{rel.as_posix()}"
    try:
        with urllib.request.urlopen(url, timeout=8) as response:
            return response.read().decode("utf-8")
    except (OSError, ValueError, UnicodeError, urllib.error.URLError, http.client.HTTPException):
        return None


def _fetch_guide(rel: Path) -> str | None:
    url = f"{_remote_base()}/{_remote_ref()}/{GUIDES_REL.as_posix()}/{rel.as_posix()}"
    try:
        with urllib.request.urlopen(url, timeout=8) as response:
            return response.read().decode("utf-8")
    except (OSError, ValueError, UnicodeError, urllib.error.URLError, http.client.HTTPException):
        return None


def _read_bundle(rel: str) -> str:
    path = Path(rel)
    for base in _bundle_candidates():
        source = base / path
        try:
            return source.read_text()
        except OSError:
            continue

    fetched = _fetch_bundle(path)
    if fetched is not None:
        return fetched

    searched = ", ".join(str(path) for path in _bundle_candidates())
    _die(
        f"ContextKit bundle source not found: {BUNDLE_REL / path}\n"
        f"Searched: {searched}\n"
        "Set CONTEXTKIT_BUNDLE_DIR, install ContextKit bundle globally, or run from the ContextKit checkout.",
        6,
    )


def _read_guide(rel: str) -> str:
    path = Path(rel)
    for base in _guide_candidates():
        source = base / path
        try:
            return source.read_text()
        except OSError:
            continue

    fetched = _fetch_guide(path)
    if fetched is not None:
        return fetched

    searched = ", ".join(str(path) for path in _guide_candidates())
    _die(
        f"ContextKit guide source not found: {GUIDES_REL / path}\n"
        f"Searched: {searched}\n"
        "Set CONTEXTKIT_GUIDES_DIR, install ContextKit guides globally, or run from the ContextKit checkout.",
        6,
    )


def _template_root() -> Path:
    for candidate in _template_candidates():
        if candidate.is_dir():
            return candidate
    searched = ", ".join(str(path) for path in _template_candidates())
    _die(
        f"ContextKit templates source not found: {TEMPLATES_REL}\n"
        f"Searched: {searched}\n"
        "Set CONTEXTKIT_TEMPLATES_DIR, install ContextKit templates globally, or run from the ContextKit checkout.",
        6,
    )


def _template_files() -> list[Path]:
    root = _template_root()
    base = root / "context"
    if not base.is_dir():
        return []
    return sorted(path for path in base.rglob("*.md") if path.is_file())


def _global_context_template() -> Path:
    source = _template_root() / GLOBAL_CONTEXT_TEMPLATE_REL
    if not source.is_file():
        _die(
            f"ContextKit global-context starter not found: {source}\n"
            "Install the complete ContextKit templates distribution or run from the ContextKit checkout.",
            6,
        )
    return source


def _run(args: list[str], root: Path, env: dict[str, str] | None = None,
         timeout: int = 30) -> subprocess.CompletedProcess[str]:
    merged_env = dict(os.environ)
    if env:
        merged_env.update(env)
    return subprocess.run(
        args,
        cwd=str(root),
        env=merged_env,
        text=True,
        capture_output=True,
        timeout=timeout,
    )


def _git_root(start: Path) -> Path | None:
    try:
        proc = _run(["git", "rev-parse", "--show-toplevel"], start)
    except (OSError, subprocess.TimeoutExpired):
        return None
    if proc.returncode != 0:
        return None
    return Path(proc.stdout.strip()).resolve()


def _find_project_root(start: Path | None = None) -> Path:
    here = (start or Path.cwd()).resolve()
    home = Path.home().resolve()
    for directory in (here, *here.parents):
        if (directory / CONFIG_REL).exists():
            return directory
        if (directory / "context").is_dir():
            return directory
        if (directory / ".git").is_dir():
            return directory
        if directory == home:
            break
    return _git_root(here) or here


def _load_toml(path: Path) -> dict[str, Any]:
    if not path.exists():
        return {}
    if tomllib is None:
        _die("Python 3.11+ is required to read .contextkit/config.toml", 6)
    try:
        return tomllib.loads(path.read_text())
    except Exception as exc:  # noqa: BLE001 - config error should be concise
        _die(f"invalid config TOML at {path}: {exc}", 6)


def _resolve_global_context_path(root: Path, value: str) -> Path:
    expanded = os.path.expandvars(value)
    if re.search(r"\$(?:[A-Za-z_][A-Za-z0-9_]*|\{[^}]+\})", expanded):
        _die(
            f"unresolved environment variable in sources.global_context: {value}\n"
            "Export the variable before running ContextKit or configure a concrete path.",
            6,
        )
    candidate = Path(expanded).expanduser()
    if not candidate.is_absolute():
        candidate = root / candidate
    resolved = candidate.resolve()
    project_root = root.resolve()
    if resolved == project_root or project_root in resolved.parents or resolved in project_root.parents:
        _die(
            f"invalid sources.global_context: {value}\n"
            "Global context and the project must be separate, non-overlapping directory trees. Keep project-owned doctrine under context/.\n"
            "Use `contextkit guide global-context` for the source contract.",
            6,
        )
    return resolved


def _config(root: Path) -> dict[str, Any]:
    raw = _load_toml(root / CONFIG_REL)
    raw_sources = dict((raw.get("sources") or {}) if isinstance(raw.get("sources"), dict) else {})
    global_context_raw = raw_sources.pop("global_context", None)
    sources = dict(DEFAULT_SOURCES)
    sources.update(raw_sources)
    for name, rel in sources.items():
        if not isinstance(rel, str) or not rel.strip():
            _die(f"invalid source path for {name}: expected a non-empty string", 6)
        rel_path = Path(rel)
        allowed_dot_capabilities = name == "capabilities" and rel_path.as_posix() == ".capabilities"
        if rel_path.parts and rel_path.parts[0].startswith(".") and not allowed_dot_capabilities:
            _die(
                f"invalid source path for {name}: {rel}\n"
                "ContextKit project-body folders are visible: context/, assets/, routines/, capabilities/.\n"
                "Only `sources.capabilities = \".capabilities\"` is allowed as a legacy compatibility override.\n"
                "Use `contextkit migrate --plan` for legacy dot-folder projects.",
                6,
            )

    global_context: Path | None = None
    if global_context_raw is not None:
        if not isinstance(global_context_raw, str) or not global_context_raw.strip():
            _die("invalid sources.global_context: expected a non-empty path string", 6)
        global_context = _resolve_global_context_path(root, global_context_raw)

    targets: dict[str, Path] = dict(DEFAULT_TARGETS)
    raw_targets = raw.get("targets") if isinstance(raw.get("targets"), dict) else {}
    for name, entry in raw_targets.items():
        if isinstance(entry, dict) and isinstance(entry.get("output"), str):
            targets[name] = Path(entry["output"])

    return {
        "version": raw.get("version", VERSION),
        "type": raw.get("type", "agent-project"),
        "sources": sources,
        "global_context": global_context,
        "global_context_raw": global_context_raw,
        "targets": targets,
        "raw": raw,
    }


def _capabilities_dir_from_sources(sources: dict[str, str]) -> Path:
    return Path(sources.get("capabilities") or DEFAULT_SOURCES["capabilities"])


def _configured_capabilities_dir(root: Path) -> Path:
    try:
        return _capabilities_dir_from_sources(_config(root)["sources"])
    except ContextKitError:
        return Path(DEFAULT_SOURCES["capabilities"])


def _required_gitignore_lines(capabilities_dir: Path | None = None) -> list[str]:
    cap_dir = capabilities_dir or Path(DEFAULT_SOURCES["capabilities"])
    cap_state_guard = cap_dir / "*" / "state"
    return [
        *REQUIRED_GITIGNORE_BASE_LINES[:5],
        cap_state_guard.as_posix() + "/",
        *REQUIRED_GITIGNORE_BASE_LINES[5:],
    ]


def _legacy_dot_layers(root: Path, sources: dict[str, str] | None = None) -> list[str]:
    allowed: set[str] = set()
    if sources and _capabilities_dir_from_sources(sources).as_posix() == ".capabilities":
        allowed.add(".capabilities")
    return [
        rel for rel in [".context", ".assets", ".routines", ".capabilities"]
        if rel not in allowed and (root / rel).exists()
    ]


def _rel(root: Path, path: Path) -> str:
    try:
        return path.resolve().relative_to(root.resolve()).as_posix()
    except ValueError:
        return str(path)


def _parse_frontmatter(text: str) -> tuple[dict[str, str], str]:
    if not text.startswith("---\n"):
        return {}, text
    end = text.find("\n---", 4)
    if end == -1:
        return {}, text
    fm_text = text[4:end]
    body_start = end + len("\n---")
    if body_start < len(text) and text[body_start] == "\n":
        body_start += 1
    fm: dict[str, str] = {}
    for raw_line in fm_text.splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#"):
            continue
        if ":" not in line:
            continue
        key, value = line.split(":", 1)
        key = key.strip()
        value = value.strip()
        if len(value) >= 2 and value[0] == value[-1] and value[0] in ("'", '"'):
            value = value[1:-1]
        fm[key] = value
    return fm, text[body_start:]


def _read_context_file(root: Path, path: Path, source: str = "project") -> tuple[ContextFile | None, list[str]]:
    rel = Path(_rel(root, path))
    try:
        text = path.read_text()
    except OSError as exc:
        return None, [f"cannot read {rel}: {exc}"]
    fm, body = _parse_frontmatter(text)
    errors: list[str] = []
    title = fm.get("title", "").strip()
    description = fm.get("description", "").strip()
    load = fm.get("load", "").strip()
    order_raw = fm.get("order", "").strip()
    if not title:
        errors.append(f"Missing frontmatter title: {rel}")
    if not description:
        errors.append(f"Missing frontmatter description: {rel}")
    if load not in {"inline", "stub"}:
        if not load:
            errors.append(f"Missing frontmatter load: {rel}")
        else:
            errors.append(f"Invalid frontmatter load in {rel}: {load}")
    try:
        order = int(order_raw)
    except ValueError:
        order = 0
        errors.append(f"Invalid frontmatter order in {rel}: {order_raw or '<missing>'}")
    if errors:
        return None, errors
    return ContextFile(path, rel, title, description, load, order, body, fm, source), []


def _collect_context(root: Path, context_dir: Path, source: str = "project") -> tuple[list[ContextFile], list[str]]:
    base = context_dir if context_dir.is_absolute() else root / context_dir
    if not base.is_dir():
        legacy = root / f".{context_dir.as_posix()}"
        if source == "project" and not context_dir.as_posix().startswith(".") and legacy.is_dir():
            _die(
                f"context source directory not found: {context_dir}\n"
                f"Legacy `{legacy.name}/` exists. Rename it to `{context_dir.as_posix()}/` before building with ContextKit.",
                6,
            )
        if source == "global":
            _die(
                f"global context source directory not found: {base}\n"
                "Repair `sources.global_context` in .contextkit/config.toml or remove it to disable global context.\n"
                "Use `contextkit guide global-context` for the source contract.",
                6,
            )
        _die(
            f"context source directory not found: {context_dir}\n"
            "Run `contextkit init --with-layers` to create empty project layers, or `contextkit init --with-template` to add starter context files.",
            6,
        )
    files: list[ContextFile] = []
    errors: list[str] = []
    for path in sorted(base.rglob("*.md")):
        ctx, ctx_errors = _read_context_file(root, path, source)
        if ctx:
            files.append(ctx)
        errors.extend(ctx_errors)
    if errors:
        _die("\n".join(errors), 6)
    files.sort(key=lambda item: (item.order, item.rel.as_posix()))
    return files, errors


def _context_reference(item: ContextFile) -> str:
    if item.source == "global":
        return str(item.path.resolve())
    return item.rel.as_posix()


def _runtime_block() -> str:
    return _read_bundle("runtime.md")


def _guide_summary(topic: str) -> tuple[str, str]:
    text = _read_guide(f"{topic}.md")
    title = topic
    paragraphs: list[str] = []
    current: list[str] = []
    for raw in text.splitlines():
        line = raw.strip()
        if line.startswith("# ") and title == topic:
            title = line[2:].strip()
            continue
        if not line:
            if current:
                paragraphs.append(" ".join(current))
                current = []
            continue
        if line.startswith("#") or line.startswith("```") or line.startswith("|"):
            continue
        current.append(line)
    if current:
        paragraphs.append(" ".join(current))
    summary = paragraphs[0] if paragraphs else f"Load when working with {topic}."
    return title, _one_line(summary)


def _guide_menu() -> str:
    lines = [
        "# Guide Menu",
        "",
        "Guides are on-demand. Load the guide only when the task needs that workflow or surface.",
        "",
    ]
    for topic in GUIDE_TOPICS:
        title, summary = _guide_summary(topic)
        lines.append(f"- `contextkit guide {topic}` - {title}: {summary}")
    return "\n".join(lines)


def _generated_block(target: str) -> str:
    return f"""<!-- Generated by ContextKit. Do not edit by hand. -->
Source config: `{CONFIG_REL.as_posix()}`
Rebuild: `contextkit build --target {target}`
"""


def _one_line(value: str) -> str:
    return re.sub(r"\s+", " ", value).strip()


def _visible_project_terms(value: str, capabilities_dir: Path | None = None) -> str:
    replacements = {
        "`.context`": "`context/`",
        "`.context/`": "`context/`",
        "`.assets`": "`assets/`",
        "`.assets/`": "`assets/`",
        "`.routines`": "`routines/`",
        "`.routines/`": "`routines/`",
    }
    if (capabilities_dir or Path(DEFAULT_SOURCES["capabilities"])).as_posix() != ".capabilities":
        replacements.update({
            "`.capabilities`": "`capabilities/`",
            "`.capabilities/`": "`capabilities/`",
        })
    for old, new in replacements.items():
        value = value.replace(old, new)
    return value


def _frontmatter_name_description(path: Path) -> tuple[str, str]:
    try:
        fm, _body = _parse_frontmatter(path.read_text())
    except OSError:
        return "", ""
    return fm.get("name", "").strip(), fm.get("description", "").strip()


def _routine_index(root: Path, routines_dir: Path, warnings: list[str]) -> str:
    if not (root / routines_dir).is_dir():
        warnings.append(f"routine layer not present; add `{routines_dir.as_posix()}/` or run `contextkit guide routines`")
        return ""
    routines: list[tuple[str, str, Path]] = []
    for path in sorted((root / routines_dir).rglob("*.md")):
        name, description = _frontmatter_name_description(path)
        rel = Path(_rel(root, path))
        if not name:
            warnings.append(f"routine missing frontmatter name: {rel.as_posix()}")
            continue
        if not description:
            warnings.append(f"routine missing frontmatter description: {rel.as_posix()}")
            continue
        if name != path.stem:
            warnings.append(f"routine name `{name}` does not match filename stem `{path.stem}`: {rel.as_posix()}")
        routines.append((name, _one_line(description), rel))
    lines = [
        "# Routines (repeatable procedures)",
        "",
        "Each is a self-contained recipe. Load its file when you need to run that procedure.",
        "",
    ]
    if not routines:
        lines += ["No routines are declared in this project.", ""]
    else:
        for name, description, rel in routines:
            lines.append(f"- **[{name}]({rel.as_posix()})** - {description}")
        lines.append("")
    return "\n".join(lines)


def _load_capability_snapshots(name: str) -> tuple[str | None, dict[str, Any] | None]:
    reg = CAP_HOME / name
    stub = None
    try:
        stub = (reg / "stub").read_text().strip()
    except OSError:
        pass
    manifest = _read_json(reg / "manifest.json")
    return stub, manifest if isinstance(manifest, dict) else None


def _capability_gate(root: Path, capabilities_dir: Path) -> dict[str, Any]:
    gate = _read_json(root / capabilities_dir / "settings.json")
    if gate is None or not isinstance(gate, dict) or not isinstance(gate.get("capabilities"), dict):
        return {"capabilities": {}}
    return gate


def _capability_ids_summary(envdir: Path, name: str) -> str | None:
    ids = _read_json(envdir / "identifiers.json")
    if isinstance(ids, dict) and ids:
        return f"- Identifiers ({len(ids)}): inspect `capabilities/{name}/identifiers.json` for the full labelled list"
    if ids is not None:
        return f"- Identifiers file present but not a JSON object - fix `capabilities/{name}/identifiers.json`"
    return None


def _capability_connections_summary(envdir: Path) -> str | None:
    conns = _read_json(envdir / "connections.json")
    valid = (isinstance(conns, dict)
             and isinstance(conns.get("connections"), dict)
             and conns["connections"])
    if valid:
        default = conns.get("default")
        items = "; ".join(
            cid + ("*" if cid == default else "")
            + (" (read-only)" if isinstance(entry, dict)
               and entry.get("allow_write") is False else "")
            for cid, entry in sorted(conns["connections"].items())
        )
        return f"- Connections (`--connection <id>`; * = default): {items}"
    if conns is not None:
        return "- Connections file present but not a valid envelope - fix `connections.json`"
    return None


def _capability_references(root: Path, envdir: Path) -> list[str]:
    refs: list[str] = []
    refdir = envdir / "reference"
    if not refdir.is_dir():
        return refs
    for md in sorted(refdir.glob("*.md")):
        name, description = _frontmatter_name_description(md)
        if not name:
            continue
        rel = _rel(root, md)
        suffix = f" - {_one_line(description)}" if description else ""
        refs.append(f"- `{rel}`{suffix}")
    return refs


def _capability_index(root: Path, capabilities_dir: Path, warnings: list[str]) -> str:
    if not (root / capabilities_dir).is_dir():
        warnings.append(f"capability layer not present; add `{capabilities_dir.as_posix()}/` or run `contextkit guide capabilities`")
        return ""
    gate = _capability_gate(root, capabilities_dir)
    enabled = sorted(
        name for name, entry in gate["capabilities"].items()
        if isinstance(entry, dict) and entry.get("enabled") is True
    )
    lines = ["# Capabilities", "", "<!-- capabilities:begin - generated by ContextKit; do not edit -->", ""]
    if not enabled:
        gate_rel = (capabilities_dir / "settings.json").as_posix()
        lines += [
            f"No capabilities are enabled in this project. Install and enable capabilities, then record the gate in `{gate_rel}`.",
            "",
        ]
    else:
        lines += [
            "Each enabled capability is a CLI on PATH. `<name> help` is the full contract; `<name> doctor` proves readiness.",
            "Exit 4 is policy - a disabled capability or a read-only connection; ask the user, never lift a gate yourself.",
            "",
        ]
    for name in enabled:
        stub, manifest = _load_capability_snapshots(name)
        envdir = root / capabilities_dir / name
        lines += [f"## {name}", ""]
        if stub is None:
            lines += [f"Enabled but not installed - run `capabilities install {name}`.", ""]
            continue
        lines += [_visible_project_terms(_one_line(stub), capabilities_dir), ""]
        bullet: list[str] = []
        conn_summary = _capability_connections_summary(envdir)
        if conn_summary:
            bullet.append(conn_summary)
        ids_summary = _capability_ids_summary(envdir, name)
        if ids_summary:
            bullet.append(ids_summary)
        topics = ((manifest or {}).get("docs") or {}).get("topics") or []
        if topics:
            bullet.append(f"- Guides (`{name} guide <topic>`): " + ", ".join(sorted(topics)))
        refs = _capability_references(root, envdir)
        if refs:
            if bullet:
                bullet.append("")
            bullet += ["**References** (load on demand):", "", *refs]
        if bullet:
            lines += bullet + [""]
    lines += ["<!-- capabilities:end -->", ""]
    return "\n".join(lines)


MEMORY_ID_PATTERN = re.compile(r"(?m)^<!-- contextkit-memory-id: ([0-9a-f]{64}) -->\n?")


def _memory_location(root: Path) -> MemoryLocation:
    raw = os.environ.get(MEMORY_DIR_ENV)
    if raw is None or not raw.strip():
        location = MemoryLocation(root / MEMORY_REL, MEMORY_REL.as_posix(), False)
    else:
        expanded = os.path.expandvars(raw.strip())
        if re.search(r"\$(?:[A-Za-z_][A-Za-z0-9_]*|\{[^}]+\})", expanded):
            _die(
                f"unresolved environment variable in {MEMORY_DIR_ENV}: {raw}\n"
                f"Set {MEMORY_DIR_ENV} to the project memory directory before running ContextKit.",
                6,
            )
        candidate = Path(expanded).expanduser()
        if not candidate.is_absolute():
            candidate = root / candidate
        location = MemoryLocation(candidate.resolve(), f"${MEMORY_DIR_ENV}", True)

    resolved = location.path.resolve()
    project_root = root.resolve()
    if location.external and (resolved == project_root or resolved in project_root.parents):
        _die(
            f"invalid {MEMORY_DIR_ENV}: {raw}\n"
            "The memory source must be a dedicated directory, not the project root or one of its ancestors.",
            6,
        )
    cfg = _config(root)
    protected: list[tuple[str, Path]] = [
        *[(f"sources.{name}", (root / rel).resolve()) for name, rel in cfg["sources"].items()],
        *[(f"targets.{name}", (root / rel).resolve()) for name, rel in cfg["targets"].items()],
    ]
    global_context: Path | None = cfg["global_context"]
    if global_context is not None:
        protected.append(("sources.global_context", global_context.resolve()))
    for owner, protected_path in protected:
        if resolved == protected_path or resolved in protected_path.parents or protected_path in resolved.parents:
            _die(
                f"invalid active memory root: {location.reference} overlaps {owner} at {protected_path}\n"
                "Choose a dedicated memory directory so one Markdown tree cannot belong to two ContextKit layers.",
                6,
            )
    active_path = resolved if location.external else location.path
    return MemoryLocation(active_path, location.reference, location.external)


def _memory_reference(location: MemoryLocation, path: Path) -> str:
    try:
        relative = path.absolute().relative_to(location.path.absolute())
    except ValueError:
        _die(f"memory path escapes the configured memory tree: {path}", 6)
    return (Path(location.reference) / relative).as_posix()


def _assert_memory_write_path(location: MemoryLocation, path: Path) -> None:
    base = location.path
    try:
        relative = path.absolute().relative_to(base.absolute())
    except ValueError:
        _die(f"memory destination escapes the configured memory tree: {path}", 6)
    if not location.external and base.is_symlink():
        _die(f"project memory path must not be a symlink: {base}\nUse `contextkit guide memory` for the memory contract.", 6)
    cursor = base
    for part in relative.parts:
        cursor = cursor / part
        if cursor.is_symlink():
            _die(f"memory paths must not be symlinks: {cursor}\nUse `contextkit guide memory` for the memory contract.", 6)
    resolved_parent = path.parent.resolve()
    resolved_base = base.resolve()
    if resolved_parent != resolved_base and resolved_base not in resolved_parent.parents:
        _die(f"memory destination resolves outside the configured memory tree: {path}", 6)


def _collect_memory(root: Path) -> list[MemoryFile]:
    location = _memory_location(root)
    base = location.path
    if not location.external and base.is_symlink():
        _die(f"project memory path must not be a symlink: {base}\nUse `contextkit guide memory` for the memory contract.", 6)
    if not base.exists():
        return []
    if not base.is_dir():
        _die(f"project memory path is not a directory: {base}\nUse `contextkit guide memory` for the memory contract.", 6)
    files: list[MemoryFile] = []
    entries = sorted(base.rglob("*"))
    symlinks = [path for path in entries if path.is_symlink()]
    if symlinks:
        _die(f"memory paths must not be symlinks: {symlinks[0]}\nUse `contextkit guide memory` for the memory contract.", 6)
    for path in (path for path in entries if path.is_file() and path.suffix.lower() == ".md"):
        try:
            body = path.read_text()
        except (OSError, UnicodeError) as exc:
            _die(f"cannot read project memory file {path}: {exc}", 6)
        files.append(MemoryFile(path=path, rel=Path(_memory_reference(location, path)), body=body))
    return files


def _memory_body_for_context(body: str) -> str:
    return MEMORY_ID_PATTERN.sub("", body).strip()


def _render_memory_block(root: Path) -> tuple[str, list[MemoryFile]]:
    files = _collect_memory(root)
    if not files:
        return "", files
    lines = [
        "# Project Memory",
        "",
        "This generated block projects the memory source files named below. Use `contextkit guide memory` to judge or groom this material.",
        "",
    ]
    for item in files:
        lines += [f"## Memory Source: `{item.rel.as_posix()}`", ""]
        body = _memory_body_for_context(item.body)
        lines += [body if body else "(empty memory file)", ""]
    return "\n".join(lines).rstrip() + "\n", files


def _compose_context(root: Path, target: str) -> tuple[str, list[str]]:
    cfg = _config(root)
    sources = cfg["sources"]
    context_dir = Path(sources["context"])
    routines_dir = Path(sources["routines"])
    capabilities_dir = Path(sources["capabilities"])
    project_files, _ = _collect_context(root, context_dir)
    global_context: Path | None = cfg["global_context"]
    global_files: list[ContextFile] = []
    if global_context is not None:
        global_files, _ = _collect_context(root, global_context, "global")
    files = sorted(
        [*global_files, *project_files],
        key=lambda item: (item.order, 0 if item.source == "global" else 1, item.rel.as_posix()),
    )
    warnings: list[str] = []
    inline = [item for item in files if item.load == "inline"]
    stubs = [item for item in files if item.load == "stub"]
    routine_index = _routine_index(root, routines_dir, warnings)
    capability_index = _capability_index(root, capabilities_dir, warnings)
    memory_block, _memory_files = _render_memory_block(root)

    title = "Codex" if target == "codex" else "Claude"
    out: list[str] = [f"# {title} Context", "", _generated_block(target).strip(), ""]
    if warnings:
        out += ["Generation warnings:", ""]
        out += [f"- {warning}" for warning in warnings]
        out.append("")

    out += [
        "---",
        "",
        _runtime_block().strip(),
        "",
        "---",
        "",
        _guide_menu().strip(),
        "",
        "---",
        "",
    ]
    if memory_block:
        out += [memory_block.strip(), "", "---", ""]
    out += ["# Inline Context", ""]
    if inline:
        for item in inline:
            source_label = "Global Source" if item.source == "global" else "Source"
            out += ["---", "", f"## {source_label}: `{_context_reference(item)}`", "", item.body.strip(), ""]
    else:
        out += ["No inline context files.", ""]

    out += ["---", "", "# Context Stubs", "",
            "These context files are visible by metadata only. Load the path when the task needs that doctrine.",
            ""]
    if stubs:
        for item in stubs:
            origin = ", global" if item.source == "global" else ""
            out.append(f"- **{item.title}** (`{_context_reference(item)}`{origin}) - {item.description}")
        out.append("")
    else:
        out += ["No stub context files.", ""]

    if routine_index:
        out += ["---", "", f"<!-- Routine index - generated from {routines_dir.as_posix()} front matter. -->", "",
                routine_index.strip(), ""]
    if capability_index:
        out += ["---", "", "<!-- Capability index - generated by `capabilities context` from the live registry. -->", "",
                capability_index.strip(), ""]
    return "\n".join(out).rstrip() + "\n", warnings


def cmd_build(args: argparse.Namespace) -> None:
    root = _find_project_root()
    written, warnings_by_target = _build_targets(root, args.target)
    _emit({"project": str(root), "written": written, "warnings": warnings_by_target}, args.json)


def _codex_context_limit(root: Path) -> int | None:
    path = root / ".codex" / "config.toml"
    if not path.exists():
        return None
    _text, raw = _codex_top_level_config(path)
    value = raw.get("project_doc_max_bytes")
    if value is None:
        return None
    if isinstance(value, bool) or not isinstance(value, int) or value <= 0:
        _die(f"invalid project_doc_max_bytes in {path}: expected a positive integer", 6)
    return value


def _build_targets(root: Path, target: str) -> tuple[dict[str, str], dict[str, list[str]]]:
    cfg = _config(root)
    targets = ["codex", "claude"] if target == "all" else [target]
    written: dict[str, str] = {}
    warnings_by_target: dict[str, list[str]] = {}
    for item in targets:
        text, warnings = _compose_context(root, item)
        if item == "codex":
            limit = _codex_context_limit(root)
            size = len(text.encode())
            if limit is not None and size > limit:
                _die(
                    f"generated Codex context is {size} bytes, but project_doc_max_bytes is {limit} in .codex/config.toml\n"
                    "ContextKit will not write a target that Codex may truncate. Groom project memory or raise the reviewed Codex limit, then rebuild.\n"
                    "Rule sources: `contextkit guide memory`; `contextkit guide hooks`.",
                    6,
                )
        output = root / cfg["targets"][item]
        output.parent.mkdir(parents=True, exist_ok=True)
        with tempfile.NamedTemporaryFile("w", delete=False, dir=str(output.parent)) as tmp:
            tmp.write(text)
            tmp_path = Path(tmp.name)
        tmp_path.replace(output)
        output.chmod(0o644)
        written[item] = str(output)
        warnings_by_target[item] = warnings
    return written, warnings_by_target


def _atomic_write_text(path: Path, body: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    mode = path.stat().st_mode if path.exists() else 0o644
    with tempfile.NamedTemporaryFile("w", delete=False, dir=str(path.parent)) as tmp:
        tmp.write(body)
        tmp_path = Path(tmp.name)
    tmp_path.replace(path)
    path.chmod(mode)


def _memory_entry_id(body: str) -> str:
    return hashlib.sha256(body.strip().encode()).hexdigest()


def _memory_result_with_build(root: Path, result: dict[str, Any]) -> dict[str, Any]:
    try:
        written, warnings = _build_targets(root, "all")
    except ContextKitError as exc:
        path = result.get("path") or _memory_location(root).reference
        _die(f"memory is present at {path}, but generated context could not be rebuilt: {exc}", exc.exit_code)
    result["written_targets"] = written
    result["warnings"] = warnings
    return result


def cmd_memory_add(args: argparse.Namespace) -> None:
    root = _find_project_root()
    location = _memory_location(root)
    if args.stdin and args.text is not None:
        _die("provide memory text either as an argument or with `--stdin`, not both", 2)
    body = sys.stdin.read() if args.stdin else (args.text or "")
    body = body.strip()
    if not body:
        _die("memory text is empty; pass text or use `--stdin`", 2)
    entry_id = _memory_entry_id(body)
    marker = f"<!-- contextkit-memory-id: {entry_id} -->"
    for item in _collect_memory(root):
        if marker in item.body:
            result = {
                "project": str(root),
                "status": "skipped",
                "reason": "identical memory already exists",
                "path": item.rel.as_posix(),
                "memory_directory": str(location.path),
                "entry_id": entry_id,
            }
            _emit(_memory_result_with_build(root, result), args.json)
            return

    now = _dt.datetime.now().astimezone()
    relative = Path(f"{now.date().isoformat()}.md")
    path = location.path / relative
    _assert_memory_write_path(location, path)
    existing = path.read_text() if path.exists() else f"# {now.date().isoformat()}\n"
    heading = f"## {now.strftime('%H:%M')}"
    if args.title:
        heading += f" — {_one_line(args.title)}"
    addition = f"\n{marker}\n{heading}\n\n{body}\n"
    _atomic_write_text(path, existing.rstrip() + "\n" + addition)
    result = {
        "project": str(root),
        "status": "created",
        "path": _memory_reference(location, path),
        "memory_directory": str(location.path),
        "entry_id": entry_id,
        "current_session": "continue with the captured fact; restart is not required",
    }
    _emit(_memory_result_with_build(root, result), args.json)


def cmd_memory_context(args: argparse.Namespace) -> None:
    root = _find_project_root()
    block, files = _render_memory_block(root)
    if args.json:
        _emit({
            "project": str(root),
            "files": [item.rel.as_posix() for item in files],
            "context": block,
        }, True)
        return
    sys.stdout.write(block)


def cmd_memory_search(args: argparse.Namespace) -> None:
    root = _find_project_root()
    needle = args.query.casefold()
    matches: list[dict[str, Any]] = []
    for item in _collect_memory(root):
        for line_number, line in enumerate(item.body.splitlines(), start=1):
            if re.fullmatch(r"<!-- contextkit-memory-id: [0-9a-f]{64} -->", line.strip()):
                continue
            if needle in line.casefold():
                matches.append({"path": item.rel.as_posix(), "line": line_number, "text": line})
    result = {"project": str(root), "query": args.query, "matches": matches}
    if args.json:
        _emit(result, True)
        return
    if not matches:
        _emit("No memory matches.")
        return
    _emit("\n".join(f"{item['path']}:{item['line']}: {item['text']}" for item in matches))


def cmd_memory_status(args: argparse.Namespace) -> None:
    root = _find_project_root()
    location = _memory_location(root)
    files = _collect_memory(root)
    result = {
        "project": str(root),
        "source": location.reference,
        "directory": str(location.path),
        "external": location.external,
        "present": location.path.is_dir(),
        "files": len(files),
        "characters": sum(len(item.body) for item in files),
        "paths": [item.rel.as_posix() for item in files],
        "rule_source": "contextkit guide memory",
    }
    if args.json:
        _emit(result, True)
        return
    lines = [
        "# ContextKit Memory Status",
        "",
        f"Project: `{root}`",
        f"Source: `{result['source']}`",
        f"Directory: `{result['directory']}`",
        f"Storage: {'environment-configured' if result['external'] else 'project-local'}",
        f"State: {'present' if result['present'] else 'absent (valid until first add or import)'}",
        f"Markdown files: {result['files']}",
        f"Characters: {result['characters']}",
        "Rule source: `contextkit guide memory`",
    ]
    if files:
        lines += ["", "Files:", *[f"- `{item.rel.as_posix()}`" for item in files]]
    _emit("\n".join(lines) + "\n")


def _memory_import_plan(root: Path, source: Path, provider: str) -> dict[str, Any]:
    try:
        source = source.expanduser().resolve(strict=True)
    except OSError as exc:
        _die(f"memory import source is unavailable: {source}: {exc}", 6)
    if not re.fullmatch(r"[A-Za-z0-9][A-Za-z0-9._-]*", provider):
        _die("provider must contain only letters, digits, dots, underscores, or hyphens", 2)
    location = _memory_location(root)
    destination_root = location.path / "imports" / provider
    if source == destination_root or destination_root in source.parents or source in destination_root.parents:
        _die("memory import source and destination must not overlap", 6)
    if source.is_file():
        candidates = [source] if source.suffix.lower() == ".md" else []
        source_root = source.parent
    elif source.is_dir():
        source_entries = sorted(source.rglob("*"))
        source_symlinks = [path for path in source_entries if path.is_symlink()]
        if source_symlinks:
            _die(f"memory import sources must not contain symlinks: {source_symlinks[0]}", 6)
        candidates = [path for path in source_entries if path.is_file() and path.suffix.lower() == ".md"]
        source_root = source
    else:
        _die(f"memory import source is not a file or directory: {source}", 6)

    entries: list[dict[str, str]] = []
    for candidate in candidates:
        try:
            body = candidate.read_text()
        except (OSError, UnicodeError) as exc:
            _die(f"cannot read memory import source {candidate}: {exc}", 6)
        relative = Path(candidate.name) if source.is_file() else candidate.relative_to(source_root)
        destination = destination_root / relative
        _assert_memory_write_path(location, destination)
        if not destination.exists():
            status = "create"
        elif destination.is_file() and destination.read_text() == body:
            status = "skip"
        else:
            status = "conflict"
        entries.append({
            "source": str(candidate),
            "destination": _memory_reference(location, destination),
            "destination_path": str(destination),
            "status": status,
        })
    return {
        "project": str(root),
        "provider": provider,
        "source": str(source),
        "destination": _memory_reference(location, destination_root),
        "memory_directory": str(location.path),
        "entries": entries,
    }


def cmd_memory_import(args: argparse.Namespace) -> None:
    root = _find_project_root()
    location = _memory_location(root)
    plan = _memory_import_plan(root, Path(args.source), args.provider)
    plan["mode"] = "apply" if args.apply else "plan"
    if args.plan:
        _emit(plan, args.json)
        return
    conflicts = [item for item in plan["entries"] if item["status"] == "conflict"]
    if conflicts:
        _die("memory import blocked by destination conflicts; review `contextkit memory import --plan` output", 6)
    created: list[str] = []
    for item in plan["entries"]:
        if item["status"] != "create":
            continue
        source = Path(item["source"])
        destination = Path(item["destination_path"])
        _assert_memory_write_path(location, destination)
        _atomic_write_text(destination, source.read_text())
        created.append(item["destination"])
    plan["created"] = created
    plan["skipped"] = [item["destination"] for item in plan["entries"] if item["status"] == "skip"]
    if created:
        plan = _memory_result_with_build(root, plan)
    _emit(plan, args.json)


def _write_if_missing(path: Path, body: str, created: list[str], skipped: list[str]) -> None:
    if path.exists():
        skipped.append(str(path))
        return
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(body)
    created.append(str(path))


def _ensure_gitignore(root: Path, created: list[str], changed: list[str]) -> None:
    path = root / ".gitignore"
    required = _required_gitignore_lines(_configured_capabilities_dir(root))
    if not path.exists():
        path.write_text("# ContextKit local and generated files\n" + "\n".join(required) + "\n")
        created.append(str(path))
        return
    text = path.read_text()
    existing = {line.strip() for line in text.splitlines() if line.strip() and not line.strip().startswith("#")}
    missing = [line for line in required if line not in existing]
    if not missing:
        return
    addition = "\n# ContextKit local and generated files\n" + "\n".join(missing) + "\n"
    path.write_text(text.rstrip("\n") + "\n" + addition)
    changed.append(str(path))


def _ensure_env_local(root: Path, created: list[str], skipped: list[str]) -> None:
    path = root / ".env.local"
    if path.exists():
        skipped.append(str(path))
        return
    path.write_text(ENV_LOCAL_BODY)
    created.append(str(path))


def _context_file(title: str, description: str, load: str, order: int, body: str) -> str:
    return (
        "---\n"
        f"title: {title}\n"
        f"description: {description}\n"
        f"load: {load}\n"
        f"order: {order}\n"
        "---\n\n"
        f"# {title}\n\n"
        f"{body.rstrip()}\n"
    )


def _config_body() -> str:
    return """version = 1
type = "agent-project"

[sources]
# Optional shared doctrine outside this project:
# global_context = "~/contextkit-global"

[targets.codex]
output = ".codex/generated/context.md"

[targets.claude]
output = ".claude/rules/CONTEXT.md"
"""


def _binding_readme() -> str:
    return """# ContextKit Binding

This repository is managed by ContextKit, a local manager for agent project structure, project memory, and runtime context.

The agent body stays in this repository: live context, supporting assets,
repeatable routines, and capability envelopes. ContextKit owns the shape,
compiler, templates, host bindings, guides, and audit tooling that turn that
body into Codex and Claude runtime context.

Common commands:

- `contextkit bootstrap`
- `contextkit init --with-layers`
- `contextkit init --with-template`
- `contextkit build --target codex`
- `contextkit build --target claude`
- `contextkit build --target all`
- `contextkit doctor`
- `contextkit audit`
- `contextkit guide authoring`
- `contextkit guide global-context`
- `contextkit guide memory`

Add durable project context under `context/`. Configure optional cross-project doctrine with `sources.global_context`. Use `contextkit guide memory` before adding project memory. Put historical or supporting material under `assets/`. Put repeatable procedures under `routines/`. Put installed tool envelopes under `capabilities/`.
"""


LAYER_DIRS = [
    ".contextkit/audits",
    "context",
    "assets/sessions",
    "assets/plans",
    "assets/research",
    "routines",
    "capabilities",
]


def _ensure_project_layers(root: Path, created: list[str], skipped: list[str]) -> None:
    for rel in LAYER_DIRS:
        path = root / rel
        if path.exists():
            skipped.append(str(path))
        else:
            path.mkdir(parents=True, exist_ok=True)
            created.append(str(path))
    _write_if_missing(root / "capabilities" / "settings.json", '{\n  "capabilities": {}\n}\n', created, skipped)


def _init_project(root: Path, with_layers: bool = False, with_template: bool = False) -> dict[str, Any]:
    created: list[str] = []
    changed: list[str] = []
    skipped: list[str] = []
    _write_if_missing(root / CONFIG_REL, _config_body(), created, skipped)
    _write_if_missing(root / README_REL, _binding_readme(), created, skipped)
    _ensure_gitignore(root, created, changed)
    _ensure_env_local(root, created, skipped)
    if with_layers or with_template:
        _ensure_project_layers(root, created, skipped)
    if with_template:
        template_root = _template_root()
        for source in _template_files():
            rel = source.relative_to(template_root)
            _write_if_missing(root / rel, source.read_text(), created, skipped)
    return {"project": str(root), "created": created, "changed": changed, "skipped": skipped}


def cmd_init(args: argparse.Namespace) -> None:
    root = _find_project_root() if args.adopt else Path.cwd().resolve()
    with_layers = bool(getattr(args, "with_layers", False))
    with_template = bool(getattr(args, "with_template", False))
    binding_only = bool(getattr(args, "binding_only", False))
    if binding_only and (with_layers or with_template):
        _die("`--binding-only` is the default and cannot be combined with `--with-layers` or `--with-template`.", 2)
    _emit(_init_project(root, with_layers=with_layers, with_template=with_template), args.json)


def _configured_project_ancestor(path: Path) -> Path | None:
    for directory in (path, *path.parents):
        if (directory / CONFIG_REL).is_file():
            return directory.resolve()
    return None


def _paths_overlap(left: Path, right: Path) -> bool:
    return left == right or left in right.parents or right in left.parents


def _assert_global_context_destination_safe(destination: Path) -> None:
    active_project = _configured_project_ancestor(Path.cwd().resolve())
    if active_project is not None and _paths_overlap(destination, active_project):
        _die(
            f"global context destination overlaps the active ContextKit project: {destination}\n"
            "Choose a separate, non-overlapping directory such as a sibling of the project.",
            6,
        )
    containing_project = _configured_project_ancestor(destination)
    if containing_project is not None:
        _die(
            f"global context destination is inside a ContextKit-managed project: {containing_project}\n"
            "Choose a separate, non-overlapping directory such as a sibling of the project.",
            6,
        )


def _assert_existing_global_context_tree_safe(destination: Path) -> None:
    def raise_walk_error(error: OSError) -> None:
        raise error

    try:
        for current, directories, files in os.walk(destination, topdown=True, followlinks=False, onerror=raise_walk_error):
            current_path = Path(current)
            if ".contextkit" in directories:
                binding = current_path / ".contextkit"
                try:
                    binding_mode = binding.lstat().st_mode
                except OSError as exc:
                    _die(f"cannot inspect global context destination {destination}: {exc}", 6)
                if stat.S_ISLNK(binding_mode):
                    _die(f"cannot safely inspect global context destination {destination}: nested .contextkit is a symlink at {binding}", 6)
            if current_path.name != ".contextkit" or "config.toml" not in {*directories, *files}:
                continue
            config = current_path / "config.toml"
            try:
                config_mode = config.lstat().st_mode
            except OSError as exc:
                _die(f"cannot inspect global context destination {destination}: {exc}", 6)
            if not stat.S_ISREG(config_mode):
                _die(f"cannot safely inspect global context destination {destination}: ambiguous project marker at {config}", 6)
            project = current_path.parent.resolve()
            _die(
                f"global context destination contains a ContextKit-managed project: {project}\n"
                "Choose a dedicated directory that does not contain projects or neighboring repositories.",
                6,
            )
    except OSError as exc:
        _die(f"cannot inspect global context destination {destination}: {exc}", 6)


def _init_global_context(value: str) -> dict[str, Any]:
    lexical_destination = Path(os.path.abspath(str(Path(value).expanduser())))
    try:
        destination_mode = lexical_destination.lstat().st_mode
    except FileNotFoundError:
        destination_exists = False
    except OSError as exc:
        _die(f"cannot inspect global context destination {lexical_destination}: {exc}", 6)
    else:
        if stat.S_ISLNK(destination_mode):
            _die(f"global context destination must not be a symlink: {lexical_destination}", 6)
        if not stat.S_ISDIR(destination_mode):
            _die(f"global context destination is not a directory: {lexical_destination}", 6)
        destination_exists = True

    try:
        destination = lexical_destination.resolve(strict=False)
    except (OSError, RuntimeError, ValueError) as exc:
        _die(f"cannot resolve global context destination {value}: {exc}", 6)

    _assert_global_context_destination_safe(destination)
    if destination_exists:
        _assert_existing_global_context_tree_safe(destination)
    starter_body = _global_context_template().read_text()
    starter = destination / GLOBAL_CONTEXT_TEMPLATE_REL.name
    try:
        starter_mode = starter.lstat().st_mode
    except FileNotFoundError:
        starter_exists = False
    except OSError as exc:
        _die(f"cannot inspect global context starter {starter}: {exc}", 6)
    else:
        if not stat.S_ISREG(starter_mode):
            _die(f"global context starter must be a regular file when it exists: {starter}", 6)
        starter_exists = True

    created: list[str] = []
    skipped: list[str] = []
    if destination_exists:
        skipped.append(str(destination))
    else:
        destination.mkdir(parents=True, exist_ok=True)
        created.append(str(destination))

    if starter_exists:
        skipped.append(str(starter))
    else:
        try:
            with starter.open("x") as handle:
                handle.write(starter_body)
        except FileExistsError:
            _die(f"global context starter appeared during initialization; rerun after reviewing it: {starter}", 6)
        except OSError as exc:
            _die(f"cannot create global context starter {starter}: {exc}", 6)
        created.append(str(starter))
    return {
        "global_context": str(destination),
        "created": created,
        "skipped": skipped,
        "guide": "contextkit guide global-context",
    }


def _format_global_context_init(result: dict[str, Any]) -> str:
    return "\n".join([
        "# ContextKit Global Context",
        "",
        f"- Source: `{result['global_context']}`",
        f"- Created: {len(result['created'])}",
        f"- Skipped: {len(result['skipped'])}",
        "",
        "The source is not enabled in any project automatically.",
        "Use `contextkit guide global-context` to connect, author, and validate it.",
        "",
    ])


def cmd_global_context_init(args: argparse.Namespace) -> None:
    result = _init_global_context(args.path)
    _emit(result, True) if args.json else _emit(_format_global_context_init(result))


def _codex_adapter() -> str:
    return """#!/usr/bin/env bash
set -euo pipefail

# Generated by `contextkit install-hooks --target codex`; do not edit by hand.

ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
ROOT="$(cd "$ROOT" && pwd -P)"
cd "$ROOT"

export PATH="$ROOT/.contextkit/manager:$PATH"

target="codex"
case "${1:-}" in
  "")
    ;;
  codex|claude|all)
    target="$1"
    ;;
  --target)
    target="${2:-}"
    ;;
  *)
    printf 'Unknown target argument: %s\\n' "$1" >&2
    exit 2
    ;;
esac

case "$target" in
  codex|claude|all)
    ;;
  *)
    printf 'Target must be codex, claude, or all; got: %s\\n' "$target" >&2
    exit 2
    ;;
esac

contextkit build --target "$target" >/dev/null
"""


def _read_json(path: Path) -> Any:
    try:
        return json.loads(path.read_text())
    except (OSError, ValueError):
        return None


def _write_json(path: Path, value: Any) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(value, ensure_ascii=False, indent=2, sort_keys=True) + "\n")


def _nested_toml_key_paths(value: Any, key: str, prefix: tuple[str, ...] = ()) -> list[str]:
    if not isinstance(value, dict):
        return []
    paths: list[str] = []
    for name, child in value.items():
        current = (*prefix, name)
        if name == key and prefix:
            paths.append(".".join(current))
        paths += _nested_toml_key_paths(child, key, current)
    return paths


def _codex_top_level_config(path: Path) -> tuple[str, dict[str, Any]]:
    if not path.exists():
        return "", {}
    text = path.read_text()
    raw = _load_toml(path)
    for key in ("project_doc_fallback_filenames", "project_doc_max_bytes"):
        nested = _nested_toml_key_paths(raw, key)
        if nested:
            _die(
                f"Codex setting {key} must be top-level in {path}; found: {', '.join(nested)}\n"
                "ContextKit preserved the existing config. Move the setting to the top level, then install the Codex hook again.",
                6,
            )
    return text, raw


def _insert_top_level_toml(text: str, additions: list[str]) -> str:
    if not additions:
        return text if text.endswith("\n") else text + "\n"
    lines = text.splitlines()
    table_index = next((index for index, line in enumerate(lines) if re.match(r"\s*\[", line)), len(lines))
    before = lines[:table_index]
    after = lines[table_index:]
    if before and before[-1].strip():
        before.append("")
    before += additions
    if after:
        before.append("")
    return "\n".join([*before, *after]).rstrip() + "\n"


def _planned_codex_config(path: Path, context_rel: str) -> tuple[str, bool]:
    config_text, config_raw = _codex_top_level_config(path)
    additions: list[str] = []
    fallback = config_raw.get("project_doc_fallback_filenames")
    if fallback is None:
        additions.append(f'project_doc_fallback_filenames = ["{context_rel}"]')
    elif not isinstance(fallback, list) or not all(isinstance(item, str) for item in fallback):
        _die(f"Codex project_doc_fallback_filenames must be a top-level string array: {path}\nContextKit preserved the existing config.", 6)
    elif context_rel not in fallback:
        _die(
            f"Codex project_doc_fallback_filenames does not include {context_rel}: {path}\n"
            "ContextKit preserved the existing config. Add the generated target to the top-level array, then install the hook again.",
            6,
        )
    max_bytes = config_raw.get("project_doc_max_bytes")
    if max_bytes is None:
        additions.append("project_doc_max_bytes = 131072")
    elif isinstance(max_bytes, bool) or not isinstance(max_bytes, int) or max_bytes <= 0:
        _die(f"Codex project_doc_max_bytes must be a positive top-level integer: {path}\nContextKit preserved the existing config.", 6)
    next_config = _insert_top_level_toml(config_text, additions)
    return next_config, next_config != config_text


def _validated_session_hooks(container: dict[str, Any], path: Path, label: str) -> list[dict[str, Any]]:
    if "hooks" not in container:
        return []
    hooks = container["hooks"]
    if not isinstance(hooks, dict):
        _die(f"{label} hooks must be a JSON object: {path}\nContextKit preserved the existing file.", 6)
    if "SessionStart" not in hooks:
        return []
    session = hooks["SessionStart"]
    if not isinstance(session, list):
        _die(f"{label} hooks.SessionStart must be a JSON array: {path}\nContextKit preserved the existing file.", 6)
    for entry in session:
        if not isinstance(entry, dict):
            _die(f"{label} SessionStart entries must be JSON objects: {path}\nContextKit preserved the existing file.", 6)
        entry_hooks = entry.get("hooks", [])
        if not isinstance(entry_hooks, list):
            _die(f"{label} SessionStart entry hooks must be a JSON array: {path}\nContextKit preserved the existing file.", 6)
        for hook in entry_hooks:
            if not isinstance(hook, dict):
                _die(f"{label} hook entries must be JSON objects: {path}\nContextKit preserved the existing file.", 6)
            if "command" in hook and not isinstance(hook["command"], str):
                _die(f"{label} hook commands must be strings: {path}\nContextKit preserved the existing file.", 6)
    return session


def _json_object_for_update(path: Path, label: str) -> tuple[dict[str, Any], bool]:
    existed = path.exists()
    value = _read_json(path)
    if existed and not isinstance(value, dict):
        _die(f"{label} must be a valid JSON object: {path}\nContextKit preserved the existing file.", 6)
    return (value if existed else {}), existed


def _preflight_codex_binding(root: Path) -> tuple[Path, str, bool, Path, dict[str, Any]]:
    config = root / ".codex" / "config.toml"
    next_config, changed_config = _planned_codex_config(config, DEFAULT_TARGETS["codex"].as_posix())
    hooks_path = root / ".codex" / "hooks.json"
    hooks, _existed = _json_object_for_update(hooks_path, "Codex hooks")
    _validated_session_hooks(hooks, hooks_path, "Codex")
    return config, next_config, changed_config, hooks_path, hooks


def _preflight_claude_binding(root: Path) -> tuple[Path, dict[str, Any], bool]:
    settings_file = root / ".claude" / "settings.json"
    settings, existed = _json_object_for_update(settings_file, "Claude settings")
    _validated_session_hooks(settings, settings_file, "Claude")
    return settings_file, settings, existed


def _wire_codex(root: Path) -> dict[str, Any]:
    build = root / ".codex" / "hooks" / "build-context.sh"
    existing = build.read_text() if build.exists() else None
    body = _codex_adapter()

    config, next_config, changed_config, hooks_path, hooks = _preflight_codex_binding(root)

    build.parent.mkdir(parents=True, exist_ok=True)
    build.write_text(body)
    build.chmod(build.stat().st_mode | stat.S_IXUSR | stat.S_IXGRP | stat.S_IXOTH)
    config.parent.mkdir(parents=True, exist_ok=True)
    if changed_config or not config.exists():
        config.write_text(next_config)

    session = hooks.setdefault("hooks", {}).setdefault("SessionStart", [])
    command = (
        "/bin/bash -lc 'root=$(git rev-parse --show-toplevel 2>/dev/null || pwd); "
        "/bin/bash \"$root/.codex/hooks/build-context.sh\"'"
    )
    hook_added = False
    if not any(command in (hook or {}).get("command", "")
               for entry in session for hook in (entry or {}).get("hooks", [])):
        session.append({
            "matcher": "startup|resume|clear|compact",
            "hooks": [{
                "type": "command",
                "command": command,
                "timeout": 30,
                "statusMessage": "Regenerating ContextKit context",
            }],
        })
        hook_added = True
    _write_json(hooks_path, hooks)
    return {
        "compiler": str(build),
        "compiler_changed": existing != body,
        "config": str(config),
        "hooks": str(hooks_path),
        "hook_added": hook_added,
    }


def _wire_claude(root: Path) -> dict[str, Any]:
    settings_file, settings, settings_existed = _preflight_claude_binding(root)
    auto_memory_disabled = False
    if not settings_existed:
        settings["autoMemoryEnabled"] = False
        auto_memory_disabled = True
    session = settings.setdefault("hooks", {}).setdefault("SessionStart", [])
    command = (
        "/bin/bash -lc 'root=$(git rev-parse --show-toplevel 2>/dev/null || pwd); "
        "PATH=\"$root/.contextkit/manager:$PATH\" contextkit build --target claude >/dev/null'"
    )
    needle = "contextkit build --target claude"
    hook_added = False
    hook_changed = False
    for entry in session:
        for hook in (entry or {}).get("hooks", []):
            if needle in (hook or {}).get("command", ""):
                if hook.get("command") != command:
                    hook["command"] = command
                    hook_changed = True
                break
        if hook_changed:
            break
    if not any(needle in (hook or {}).get("command", "")
               for entry in session for hook in (entry or {}).get("hooks", [])):
        session.append({"hooks": [{"type": "command", "command": command}]})
        hook_added = True
    _write_json(settings_file, settings)
    return {
        "settings": str(settings_file),
        "hook_added": hook_added,
        "hook_changed": hook_changed,
        "auto_memory_disabled": auto_memory_disabled,
    }


def _install_hooks(root: Path, targets: list[str]) -> dict[str, Any]:
    result: dict[str, Any] = {"project": str(root)}
    if "codex" in targets:
        _preflight_codex_binding(root)
    if "claude" in targets:
        _preflight_claude_binding(root)
    if "codex" in targets:
        result["codex"] = _wire_codex(root)
    if "claude" in targets:
        result["claude"] = _wire_claude(root)
    return result


def cmd_install_hooks(args: argparse.Namespace) -> None:
    root = _find_project_root()
    targets = args.target or ["codex"]
    result = _install_hooks(root, targets)
    _emit(result, args.json)


def _dedupe_targets(targets: list[str] | None) -> list[str]:
    raw = targets or ["codex", "claude"]
    out: list[str] = []
    for target in raw:
        if target not in out:
            out.append(target)
    return out


def _ensure_git_repo(root: Path) -> dict[str, Any]:
    git_path = root / ".git"
    if git_path.exists():
        return {
            "present": True,
            "initialized": False,
            "path": str(git_path),
            "checkpoint": {"required": False, "created": False},
        }
    try:
        proc = _run(["git", "init"], root)
    except (OSError, subprocess.TimeoutExpired) as exc:
        _die(f"git init failed: {exc}", 6)
    if proc.returncode != 0:
        detail = (proc.stderr or proc.stdout).strip()
        _die(f"git init failed in {root}: {detail}", 6)
    return {
        "present": True,
        "initialized": True,
        "path": str(git_path),
        "checkpoint": {"required": False, "created": False, "reason": "empty directory"},
    }


def _has_prebootstrap_files(root: Path) -> bool:
    try:
        children = list(root.iterdir())
    except OSError:
        return True
    for child in children:
        if child.name in {".git", ".DS_Store"}:
            continue
        return True
    return False


def _confirm_prebootstrap_checkpoint(root: Path, yes: bool) -> None:
    if yes:
        return
    lines = [
        "ContextKit bootstrap found files but no Git repository.",
        "Create a pre-bootstrap Git checkpoint before ContextKit changes project files.",
        "",
        "This runs:",
        "- git init",
        "- git add -A",
        "- git commit -m \"ContextKit pre-bootstrap checkpoint\"",
        "",
        f"Project: {root}",
        "",
        "Continue?",
    ]
    prompt = "\n".join(lines) + " [y/N] "
    try:
        with open("/dev/tty", "r+", encoding="utf-8") as tty:
            tty.write(prompt)
            tty.flush()
            answer = tty.readline().strip().lower()
    except OSError:
        _die(
            "\n".join(lines)
            + "\nRun `contextkit bootstrap --yes` to create the checkpoint automatically.",
            6,
        )
    if answer not in {"y", "yes"}:
        _die("ContextKit bootstrap cancelled before project files changed.", 6)


def _append_git_info_exclude(root: Path) -> None:
    path = root / ".git" / "info" / "exclude"
    try:
        text = path.read_text() if path.exists() else ""
    except OSError:
        text = ""
    existing = {line.strip() for line in text.splitlines() if line.strip() and not line.strip().startswith("#")}
    missing = [line for line in _required_gitignore_lines(_configured_capabilities_dir(root)) if line not in existing]
    if not missing:
        return
    path.parent.mkdir(parents=True, exist_ok=True)
    addition = "\n# ContextKit local and generated files\n" + "\n".join(missing) + "\n"
    path.write_text(text.rstrip("\n") + addition)


def _git_configured_identity(root: Path) -> bool:
    name = _run(["git", "config", "--get", "user.name"], root)
    email = _run(["git", "config", "--get", "user.email"], root)
    return name.returncode == 0 and bool(name.stdout.strip()) and email.returncode == 0 and bool(email.stdout.strip())


def _commit_prebootstrap_checkpoint(root: Path) -> dict[str, Any]:
    _append_git_info_exclude(root)
    add = _run(["git", "add", "-A"], root)
    if add.returncode != 0:
        detail = (add.stderr or add.stdout).strip()
        _die(f"pre-bootstrap git add failed in {root}: {detail}", 6)
    staged = _run(["git", "diff", "--cached", "--quiet"], root)
    if staged.returncode == 0:
        return {"required": True, "created": False, "reason": "no tracked files after git add"}
    if staged.returncode not in {0, 1}:
        detail = (staged.stderr or staged.stdout).strip()
        _die(f"pre-bootstrap git diff failed in {root}: {detail}", 6)

    commit_cmd = ["git"]
    if not _git_configured_identity(root):
        commit_cmd += ["-c", "user.name=ContextKit", "-c", "user.email=contextkit@local"]
    commit_cmd += ["commit", "-m", "ContextKit pre-bootstrap checkpoint"]
    commit = _run(commit_cmd, root)
    if commit.returncode != 0:
        detail = (commit.stderr or commit.stdout).strip()
        _die(f"pre-bootstrap checkpoint commit failed in {root}: {detail}", 6)
    rev = _run(["git", "rev-parse", "--short", "HEAD"], root)
    return {
        "required": True,
        "created": True,
        "commit": rev.stdout.strip() if rev.returncode == 0 else "",
        "message": "ContextKit pre-bootstrap checkpoint",
    }


def _prepare_git_for_bootstrap(root: Path, yes: bool) -> dict[str, Any]:
    git_path = root / ".git"
    if git_path.exists():
        return _ensure_git_repo(root)
    if not _has_prebootstrap_files(root):
        return _ensure_git_repo(root)

    _confirm_prebootstrap_checkpoint(root, yes)
    git = _ensure_git_repo(root)
    git["checkpoint"] = _commit_prebootstrap_checkpoint(root)
    return git


def _json_object_blocker(root: Path, rel: Path, label: str, blockers: list[str]) -> None:
    path = root / rel
    if not path.exists():
        return
    if not path.is_file():
        blockers.append(f"{label} is not a file: {rel.as_posix()}")
        return
    value = _read_json(path)
    if value is None:
        blockers.append(f"{label} is invalid JSON: {rel.as_posix()}")
    elif not isinstance(value, dict):
        blockers.append(f"{label} must be a JSON object: {rel.as_posix()}")


def _hook_shape_blocker(root: Path, rel: Path, label: str, blockers: list[str]) -> None:
    path = root / rel
    value = _read_json(path)
    if not isinstance(value, dict):
        return
    try:
        _validated_session_hooks(value, path, label)
    except ContextKitError as exc:
        blockers.append(str(exc))


def _bootstrap_conflicts(root: Path, targets: list[str]) -> dict[str, list[Any]]:
    blockers: list[str] = []
    confirm: list[dict[str, str]] = []
    cfg: dict[str, Any] | None = None

    if (root / CONFIG_REL).exists():
        try:
            cfg = _config(root)
        except ContextKitError as exc:
            blockers.append(str(exc))

    global_context = (cfg or {}).get("global_context")
    if global_context is not None and not global_context.is_dir():
        blockers.append(
            f"configured global context source is missing or is not a directory: {global_context}; "
            "repair sources.global_context or remove it to disable the source"
        )

    legacy_dot_layers = _legacy_dot_layers(root, (cfg or {}).get("sources"))
    for rel in legacy_dot_layers:
        blockers.append(f"legacy dot body layer present: {rel} -> {rel[1:]}; run `contextkit migrate --plan`")

    if "codex" in targets:
        try:
            _planned_codex_config(root / ".codex" / "config.toml", DEFAULT_TARGETS["codex"].as_posix())
        except ContextKitError as exc:
            blockers.append(str(exc))
        adapter = root / ".codex" / "hooks" / "build-context.sh"
        if adapter.exists() and not adapter.is_file():
            blockers.append(".codex/hooks/build-context.sh exists and is not a file")
        elif adapter.exists():
            try:
                existing = adapter.read_text()
            except OSError as exc:
                blockers.append(f"cannot read .codex/hooks/build-context.sh: {exc}")
            else:
                owned = "Generated by `contextkit install-hooks --target codex`" in existing
                if existing != _codex_adapter() and not owned:
                    confirm.append({
                        "path": ".codex/hooks/build-context.sh",
                        "reason": "file exists and is not a ContextKit-managed adapter",
                        "action": "replace with ContextKit adapter",
                    })
        _json_object_blocker(root, Path(".codex") / "hooks.json", "Codex hooks", blockers)
        _hook_shape_blocker(root, Path(".codex") / "hooks.json", "Codex", blockers)

    if "claude" in targets:
        _json_object_blocker(root, Path(".claude") / "settings.json", "Claude settings", blockers)
        _hook_shape_blocker(root, Path(".claude") / "settings.json", "Claude", blockers)

    return {"blockers": blockers, "confirm": confirm}


def _confirm_bootstrap_conflicts(conflicts: list[dict[str, str]], yes: bool) -> None:
    if not conflicts or yes:
        return
    lines = [
        "ContextKit bootstrap found managed-file conflicts:",
        *[
            f"- {item['path']}: {item['reason']}; {item['action']}"
            for item in conflicts
        ],
        "",
        "Continue and apply these replacements?",
    ]
    prompt = "\n".join(lines) + " [y/N] "
    try:
        with open("/dev/tty", "r+", encoding="utf-8") as tty:
            tty.write(prompt)
            tty.flush()
            answer = tty.readline().strip().lower()
    except OSError:
        _die(
            "\n".join(lines)
            + "\nRun `contextkit bootstrap --yes` to approve these replacements.",
            6,
        )
    if answer not in {"y", "yes"}:
        _die("ContextKit bootstrap cancelled.", 6)


def _bootstrap_build_target(targets: list[str]) -> str:
    return "all" if {"codex", "claude"}.issubset(set(targets)) else targets[0]


def _format_bootstrap_result(result: dict[str, Any]) -> str:
    checkpoint = result["git"].get("checkpoint") or {}
    git_status = "initialized" if result["git"]["initialized"] else "present"
    if checkpoint.get("created"):
        git_status += f", checkpoint {checkpoint.get('commit')}"
    lines = [
        "# ContextKit Bootstrap",
        "",
        f"Project: `{result['project']}`",
        f"Status: {'ready' if result['ready'] else 'needs attention'}",
        "",
        "Steps:",
        f"- Git: {git_status}",
        f"- Init: {len(result['init']['created'])} created, {len(result['init']['changed'])} changed, {len(result['init']['skipped'])} skipped",
        f"- Hooks: {', '.join(result['targets'])}",
        f"- Build: {', '.join(sorted(result['build']['written']))}",
        f"- Doctor: {'ok' if result['doctor']['ok'] else 'needs attention'}",
        f"- Audit findings: {len(result['audit']['findings'])}",
        "",
    ]
    if result["confirmed_conflicts"]:
        lines += [
            "Confirmed replacements:",
            *[f"- `{item['path']}`" for item in result["confirmed_conflicts"]],
            "",
        ]
    if result["doctor"]["problems"]:
        lines += ["Doctor problems:", *[f"- {problem}" for problem in result["doctor"]["problems"]], ""]
    if result["audit"]["findings"]:
        lines += ["Audit findings:", *[
            f"- {item['severity']} `{item['code']}`: {item['path']}"
            for item in result["audit"]["findings"]
        ], ""]
    lines += [
        "Rule sources:",
        "- `contextkit guide bootstrap`",
        "- `contextkit guide validation`",
        "- `contextkit guide audit`",
        "",
    ]
    return "\n".join(lines)


def cmd_bootstrap(args: argparse.Namespace) -> None:
    root = _find_project_root()
    targets = _dedupe_targets(args.target)
    conflicts = _bootstrap_conflicts(root, targets)
    if conflicts["blockers"]:
        _die(
            "ContextKit bootstrap blocked:\n"
            + "\n".join(f"- {item}" for item in conflicts["blockers"]),
            6,
        )
    git = _prepare_git_for_bootstrap(root, args.yes)
    _confirm_bootstrap_conflicts(conflicts["confirm"], args.yes)
    confirmed_conflicts = conflicts["confirm"]

    init = _init_project(root, with_layers=True, with_template=args.with_template)
    hooks = _install_hooks(root, targets)
    build_target = _bootstrap_build_target(targets)
    written, warnings = _build_targets(root, build_target)
    doctor = _doctor_report(root)
    findings = _project_audit_findings(root)
    audit = {
        "project": str(root),
        "rule_source": "contextkit guide audit",
        "findings": [item.as_dict() for item in findings],
    }
    result = {
        "project": str(root),
        "ready": doctor["ok"] and not findings,
        "targets": targets,
        "confirmed_conflicts": confirmed_conflicts,
        "git": git,
        "init": init,
        "hooks": hooks,
        "build": {"target": build_target, "written": written, "warnings": warnings},
        "doctor": doctor,
        "audit": audit,
        "rule_sources": [
            "contextkit guide bootstrap",
            "contextkit guide validation",
            "contextkit guide audit",
        ],
    }
    _emit(result, True) if args.json else _emit(_format_bootstrap_result(result))


def _git_state(root: Path) -> dict[str, Any]:
    git_dir = root / ".git"
    out: dict[str, Any] = {"present": git_dir.exists()}
    if git_dir.exists():
        proc = _run(["git", "status", "--short"], root)
        out["dirty"] = bool(proc.stdout.strip()) if proc.returncode == 0 else None
    return out


def _gitignore_patterns(root: Path) -> set[str]:
    path = root / ".gitignore"
    try:
        lines = path.read_text().splitlines()
    except OSError:
        return set()
    return {line.strip() for line in lines if line.strip() and not line.strip().startswith("#")}


def _required_project_files(root: Path, sources: dict[str, str]) -> dict[str, dict[str, Any]]:
    capability_gate = _capabilities_dir_from_sources(sources) / "settings.json"
    return {
        ".contextkit/config.toml": {"path": str(root / CONFIG_REL), "present": (root / CONFIG_REL).exists()},
        ".contextkit/README.md": {"path": str(root / README_REL), "present": (root / README_REL).exists()},
        ".gitignore": {"path": str(root / ".gitignore"), "present": (root / ".gitignore").exists()},
        ".env.local": {"path": str(root / ".env.local"), "present": (root / ".env.local").exists()},
        capability_gate.as_posix(): {
            "path": str(root / capability_gate),
            "present": (root / capability_gate).exists(),
        },
    }


def _guard_report(root: Path, sources: dict[str, str]) -> dict[str, bool]:
    patterns = _gitignore_patterns(root)
    return {line: line in patterns for line in _required_gitignore_lines(_capabilities_dir_from_sources(sources))}


def _doctor_report(root: Path) -> dict[str, Any]:
    cfg = _config(root)
    sources = cfg["sources"]
    required_files = _required_project_files(root, sources)
    gitignore_guards = _guard_report(root, sources)
    legacy_dot_layers = _legacy_dot_layers(root, sources)
    layers = {
        name: {
            "path": str(root / rel),
            "present": (root / rel).exists(),
        }
        for name, rel in sources.items()
    }
    global_context_path: Path | None = cfg["global_context"]
    global_context = None
    if global_context_path is not None:
        global_context = {
            "configured": cfg["global_context_raw"],
            "path": str(global_context_path),
            "present": global_context_path.exists(),
            "directory": global_context_path.is_dir(),
        }
    problems: list[str] = []
    problems += [f"missing required file: {name}" for name, item in required_files.items() if not item["present"]]
    problems += [f"missing .gitignore guard: {pattern}" for pattern, present in gitignore_guards.items() if not present]
    problems += [f"missing project layer: {name} ({item['path']})" for name, item in layers.items() if not item["present"]]
    problems += [f"legacy dot layer present: {rel} -> {rel[1:]}" for rel in legacy_dot_layers]
    if global_context and not global_context["present"]:
        problems.append(f"missing global context source: {global_context['path']}")
    elif global_context and not global_context["directory"]:
        problems.append(f"global context source is not a directory: {global_context['path']}")
    rule_sources = ["contextkit guide validation", "contextkit guide bootstrap"]
    if global_context:
        rule_sources.append("contextkit guide global-context")
    report = {
        "project": str(root),
        "config": str(root / CONFIG_REL) if (root / CONFIG_REL).exists() else None,
        "type": cfg["type"],
        "ok": not problems,
        "problems": problems,
        "rule_sources": rule_sources,
        "git": _git_state(root),
        "required_files": required_files,
        "gitignore_guards": gitignore_guards,
        "legacy_dot_layers": legacy_dot_layers,
        "layers": layers,
        "global_context": global_context,
        "tools": {
            "contextkit": str(Path(sys.argv[0]).resolve()),
            "capabilities": shutil.which("capabilities"),
            "routine": shutil.which("routine"),
        },
        "targets": {name: str(root / path) for name, path in cfg["targets"].items()},
        "hooks": {
            "codex_hooks": str(root / ".codex" / "hooks.json"),
            "codex_adapter": str(root / ".codex" / "hooks" / "build-context.sh"),
            "claude_settings": str(root / ".claude" / "settings.json"),
        },
    }
    return report


def cmd_doctor(args: argparse.Namespace) -> None:
    root = _find_project_root()
    report = _doctor_report(root)
    if args.json:
        _emit(report, True)
        return
    lines = [
        "# ContextKit Doctor",
        "",
        f"Project: `{root}`",
        f"Type: `{report['type']}`",
        f"Status: {'ok' if report['ok'] else 'needs attention'}",
        "",
    ]
    lines += ["Rule sources:", *[f"- `{source}`" for source in report["rule_sources"]], ""]
    if report["problems"]:
        lines += ["Problems:", *[f"- {problem}" for problem in report["problems"]], ""]
    lines += ["Git:", f"- Present: {report['git']['present']}", f"- Dirty: {report['git'].get('dirty')}", ""]
    lines += ["Required files:"]
    for name, item in report["required_files"].items():
        marker = "present" if item["present"] else "missing"
        lines.append(f"- {name}: {marker}")
    lines += ["", "Gitignore guards:"]
    for pattern, present in report["gitignore_guards"].items():
        marker = "present" if present else "missing"
        lines.append(f"- `{pattern}`: {marker}")
    if report["legacy_dot_layers"]:
        lines += ["", "Legacy dot layers:"]
        lines += [f"- `{rel}` -> `{rel[1:]}`" for rel in report["legacy_dot_layers"]]
    lines.append("")
    lines += ["Layers:"]
    for name, item in report["layers"].items():
        marker = "present" if item["present"] else "missing"
        lines.append(f"- {name}: {marker} (`{item['path']}`)")
    if report["global_context"]:
        item = report["global_context"]
        marker = "present" if item["directory"] else "missing or invalid"
        lines += ["", "Global context:", f"- Source: {marker} (`{item['path']}`)"]
    lines += ["", "Tools:"]
    for name, value in report["tools"].items():
        lines.append(f"- {name}: `{value or 'not found'}`")
    lines += ["", "Targets:"]
    for name, value in report["targets"].items():
        lines.append(f"- {name}: `{value}`")
    _emit("\n".join(lines) + "\n")


def _weak_description(description: str) -> bool:
    words = re.findall(r"[A-Za-z0-9_'-]+", description)
    if len(words) < 6:
        return True
    generic = {"misc", "notes", "context", "information", "details", "things", "stuff"}
    return len(set(w.lower() for w in words) - generic) < 4


def _content_owner_hint(rel: str, text: str) -> str | None:
    lowered = text.lower()
    if "/guidelines/" in rel and sum(word in lowered for word in
                                    ["runtime", "container", "deployment", "service architecture"]) >= 2:
        return "This reads like architecture; consider `context/architecture/`."
    if "/architecture/" in rel and sum(word in lowered for word in
                                      ["always", "never", "must", "limitation", "do not"]) >= 4:
        return "This reads like doctrine or constraints; consider `context/guidelines/`."
    if "/identity/" in rel and sum(word in lowered for word in
                                  ["cli", "endpoint", "container", "database", "queue"]) >= 3:
        return "This reads like runtime/service architecture; consider `context/architecture/`."
    return None


def _historical_framing_hint(text: str) -> str | None:
    if re.search(r"\b(formerly|previously|used to|moved from|migrated from|unlike)\b", text, flags=re.I):
        return "Rewrite live doctrine in present tense; keep migration history in git, assets, or audit reports."
    return None


def _running_state_hint(text: str) -> str | None:
    if re.search(r"\b(todo|pending|next action|checkpoint|last sync(?:ed)?|current balance|open task)\b", text, flags=re.I):
        return "Live context excludes running task state; move work tracking to the project work system or assets."
    return None


def _hard_wrapped_prose_hint(text: str) -> str | None:
    in_fence = False
    previous_can_continue = False
    for raw in text.splitlines():
        stripped = raw.strip()
        if stripped.startswith(("```", "~~~")):
            in_fence = not in_fence
            previous_can_continue = False
            continue
        if in_fence:
            continue
        if not stripped:
            previous_can_continue = False
            continue
        if raw.startswith("    ") or stripped.startswith(("#", ">", "|", "<")):
            previous_can_continue = False
            continue
        if stripped in {"---", "***", "___"}:
            previous_can_continue = False
            continue
        if re.match(r"^(?:[-+*]|\d+[.)])\s+", stripped):
            previous_can_continue = True
            continue
        if previous_can_continue:
            return "Keep each prose paragraph and list item on one physical line; let the editor or renderer wrap it visually."
        previous_can_continue = True
    return None


def _normalized_claim_text(text: str) -> list[str]:
    claims: list[str] = []
    for raw in re.split(r"[\n.]", text):
        line = re.sub(r"\s+", " ", raw.strip().lower())
        line = re.sub(r"[`*_>#-]", "", line).strip()
        if not line:
            continue
        if len(line.split()) < 10:
            continue
        if line.startswith(("the ", "a ", "an ")) or any(ch.isalpha() for ch in line):
            claims.append(line)
    return claims


def _normalized_claims(item: ContextFile) -> list[str]:
    return _normalized_claim_text(item.body)


def _audit_context_files(root: Path, paths: list[Path] | None = None) -> list[Finding]:
    cfg = _config(root)
    context_dir = Path(cfg["sources"]["context"])
    findings: list[Finding] = []
    files: list[ContextFile] = []
    global_context: Path | None = cfg["global_context"]
    sourced_paths: list[tuple[Path, str]] = []
    if paths is not None:
        for path in paths:
            resolved = (path if path.is_absolute() else root / path).resolve()
            source = "project"
            if global_context is not None:
                try:
                    resolved.relative_to(global_context)
                    source = "global"
                except ValueError:
                    pass
            sourced_paths.append((resolved, source))
    else:
        sourced_paths += [(path, "project") for path in sorted((root / context_dir).rglob("*.md"))]
        if global_context is not None:
            if not global_context.is_dir():
                findings.append(Finding(
                    "error", "global-context-source", str(global_context),
                    "Configured global context source is missing or is not a directory.",
                    "Repair `sources.global_context` in `.contextkit/config.toml` or remove it to disable the source.",
                    "contextkit guide global-context",
                ))
            else:
                sourced_paths += [(path, "global") for path in sorted(global_context.rglob("*.md"))]
    for path, source in sourced_paths:
        ctx, errors = _read_context_file(root, path, source)
        if errors:
            for err in errors:
                findings.append(Finding(
                    "error", "metadata", _rel(root, path), err,
                    rule_source="contextkit guide authoring",
                ))
            continue
        if ctx:
            files.append(ctx)

    claim_owners: dict[str, list[str]] = {}
    for item in files:
        rel = item.rel.as_posix()
        if _weak_description(item.description):
            findings.append(Finding(
                "warning", "weak-description", rel,
                "Description is too generic to route reliably.",
                "Make it a specific one-line answer to: when the agent loads this file.",
                "contextkit guide authoring",
            ))
        if "\n" in item.description:
            findings.append(Finding(
                "warning", "description", rel, "Description is one line.",
                rule_source="contextkit guide authoring",
            ))
        if item.load == "inline" and (len(item.body.split()) > 1200 or len(item.body.splitlines()) > 180):
            findings.append(Finding(
                "warning", "inline-bloat", rel,
                "Inline file is large enough to deserve review.",
                "Keep always-on context lean; move detail to a stub, routine, capability reference, or asset.",
                "contextkit guide authoring",
            ))
        if re.search(r"\[[^\]]+\]\((?:\.\.?/)?[^)]+\.md(?:#[^)]+)?\)", item.body):
            findings.append(Finding(
                "warning", "internal-context-link", rel,
                "Markdown links to sibling context files create stale routing assumptions.",
                "Prefer self-contained wording and let compiled metadata route sibling files.",
                "contextkit guide authoring",
            ))
        asset_live_pattern = re.compile(
            r"(?:see|load|read|per|according to|based on|from)\s+`?(?:\.assets|assets)/(?:sessions|plans|research)/"
            r"|\]\((?:\.assets|assets)/(?:sessions|plans|research)/",
            flags=re.I,
        )
        if asset_live_pattern.search(item.body):
            findings.append(Finding(
                "warning", "asset-as-live-doctrine", rel,
                "File points at historical assets as if they are live doctrine.",
                "Promote durable facts into the live owning layer; leave historical assets as evidence.",
                "contextkit guide authoring; contextkit guide assets",
            ))
        hint = _content_owner_hint(rel, item.body)
        if hint:
            findings.append(Finding(
                "info", "taxonomy-fit", rel,
                "File may live at the wrong context altitude.",
                hint,
                "contextkit guide authoring",
            ))
        hint = _historical_framing_hint(item.body)
        if hint:
            findings.append(Finding(
                "warning", "historical-framing", rel,
                "Live context appears to define itself through history or comparison.",
                hint,
                "contextkit guide authoring",
            ))
        hint = _running_state_hint(item.body)
        if hint:
            findings.append(Finding(
                "warning", "running-state-in-context", rel,
                "Live context appears to contain running task state.",
                hint,
                "contextkit guide authoring",
            ))
        hint = _hard_wrapped_prose_hint(item.body)
        if hint:
            findings.append(Finding(
                "warning", "hard-wrapped-prose", rel,
                "Authored prose uses a width-driven physical line break.",
                hint,
                "contextkit guide authoring",
            ))
        for claim in _normalized_claims(item):
            claim_owners.setdefault(claim, []).append(rel)

    for claim, owners in sorted(claim_owners.items()):
        unique = sorted(set(owners))
        if len(unique) > 1:
            findings.append(Finding(
                "warning", "duplicate-live-fact", ", ".join(unique),
                f"Same durable-looking claim appears in {len(unique)} live files.",
                claim[:220],
                "contextkit guide authoring",
            ))
    return findings


def _live_context_claim_owners(root: Path) -> dict[str, list[str]]:
    cfg = _config(root)
    context_dir = Path(cfg["sources"]["context"])
    sourced_paths: list[tuple[Path, str]] = [
        (path, "project") for path in sorted((root / context_dir).rglob("*.md"))
    ]
    global_context: Path | None = cfg["global_context"]
    if global_context is not None and global_context.is_dir():
        sourced_paths += [(path, "global") for path in sorted(global_context.rglob("*.md"))]
    owners: dict[str, list[str]] = {}
    for path, source in sourced_paths:
        item, errors = _read_context_file(root, path, source)
        if errors or item is None:
            continue
        for claim in _normalized_claims(item):
            owners.setdefault(claim, []).append(item.rel.as_posix())
    return owners


def _audit_memory(root: Path, paths: list[Path] | None = None) -> list[Finding]:
    location = _memory_location(root)
    base = location.path
    findings: list[Finding] = []
    if paths is None and not location.external and base.is_symlink():
        return [Finding(
            "error", "memory-symlink", location.reference,
            "Project-local memory must not be a symlink.",
            f"Remove the symlink or configure an intentional external root through {MEMORY_DIR_ENV}.",
            "contextkit guide memory",
        )]
    if paths is None and not base.exists():
        return []
    if paths is None:
        if not base.is_dir():
            return [Finding(
                "error", "memory-path", location.reference,
                "Project memory path is not a directory.",
                "Replace the path with a directory or remove it before the first memory capture.",
                "contextkit guide memory",
            )]
        entries = sorted(base.rglob("*"))
        symlinks = [path for path in entries if path.is_symlink()]
        for path in symlinks:
            findings.append(Finding(
                "error", "memory-symlink", _memory_reference(location, path),
                "Memory paths must not be symlinks because they can escape the configured memory tree.",
                "Replace the symlink with an ordinary Markdown file or directory inside the configured memory root.",
                "contextkit guide memory",
            ))
        all_files = [path for path in entries if not path.is_symlink() and path.is_file()]
        markdown_paths = [path for path in all_files if path.suffix.lower() == ".md"]
        other_files = [path for path in all_files if path.suffix.lower() != ".md"]
        if not markdown_paths and not other_files and not symlinks:
            findings.append(Finding(
                "info", "empty-memory-layer", location.reference,
                "The optional memory directory is empty.",
                "Remove the empty directory; ContextKit recreates it on the next add or import.",
                "contextkit guide memory",
            ))
        for path in other_files:
            findings.append(Finding(
                "warning", "uncompiled-memory-file", _memory_reference(location, path),
                "Only Markdown files are included in project memory context.",
                "Move useful text into Markdown or relocate the file to its owning layer.",
                "contextkit guide memory",
            ))
    else:
        markdown_paths = [
            (path if path.is_absolute() else root / path).resolve()
            for path in paths
            if (path if path.is_absolute() else root / path).suffix.lower() == ".md"
        ]

    live_claims = _live_context_claim_owners(root)
    memory_claims: dict[str, list[str]] = {}
    for path in markdown_paths:
        try:
            body = path.read_text()
        except (OSError, UnicodeError) as exc:
            findings.append(Finding(
                "error", "unreadable-memory", _memory_reference(location, path),
                f"Memory file cannot be read: {exc}",
                rule_source="contextkit guide memory",
            ))
            continue
        rel = _memory_reference(location, path)
        visible_body = _memory_body_for_context(body)
        if not visible_body:
            findings.append(Finding(
                "warning", "empty-memory-file", rel,
                "Memory file contributes no project knowledge.",
                "Remove the empty file or add the provisional note it is meant to preserve.",
                "contextkit guide memory",
            ))
        for claim in _normalized_claim_text(visible_body):
            memory_claims.setdefault(claim, []).append(rel)
            if claim in live_claims:
                owners = ", ".join(sorted(set(live_claims[claim])))
                findings.append(Finding(
                    "warning", "memory-duplicates-live-fact", f"{rel}, {owners}",
                    "A memory claim duplicates current live context.",
                    "Keep the live owner and remove or rewrite the provisional memory copy after verification.",
                    "contextkit guide memory; contextkit guide authoring",
                ))
    for claim, owners in sorted(memory_claims.items()):
        unique = sorted(set(owners))
        if len(unique) > 1:
            findings.append(Finding(
                "warning", "duplicate-memory-claim", ", ".join(unique),
                "The same provisional claim appears in multiple memory files.",
                claim[:220],
                "contextkit guide memory",
            ))
    return findings


def _project_audit_findings(root: Path) -> list[Finding]:
    return [*_audit_context_files(root), *_audit_memory(root)]


def _audit_report(root: Path, findings: list[Finding]) -> str:
    today = _dt.date.today().isoformat()
    lines = [
        f"# ContextKit Audit - {today}",
        "",
        f"Project: `{root}`",
        "",
        "Audit procedure: `contextkit guide audit`",
        "Apply each finding by loading its `Rule source` guide.",
        "",
        "## Findings",
        "",
    ]
    if not findings:
        lines.append("No findings.")
    else:
        for finding in findings:
            lines += [
                f"### {finding.severity.upper()} `{finding.code}`",
                "",
                f"- Path: `{finding.path}`",
                f"- Rule source: `{finding.rule_source or 'contextkit guide audit'}`",
                f"- Finding: {finding.message}",
            ]
            if finding.hint:
                lines.append(f"- Hint: {finding.hint}")
            lines.append("")
    return "\n".join(lines).rstrip() + "\n"


def _write_audit(root: Path, report: str) -> Path:
    target_dir = root / ".contextkit" / "audits"
    target_dir.mkdir(parents=True, exist_ok=True)
    today = _dt.date.today().isoformat()
    target = target_dir / f"{today}_contextkit-audit.md"
    if target.exists():
        index = 2
        while True:
            candidate = target_dir / f"{today}_contextkit-audit-{index}.md"
            if not candidate.exists():
                target = candidate
                break
            index += 1
    target.write_text(report)
    return target


def cmd_audit(args: argparse.Namespace) -> None:
    root = _find_project_root()
    findings = _project_audit_findings(root)
    report = _audit_report(root, findings)
    if args.write:
        written = _write_audit(root, report)
        result = {"project": str(root), "written": str(written), "rule_source": "contextkit guide audit",
                  "findings": [item.as_dict() for item in findings]}
        _emit(result, args.json)
    elif args.json:
        _emit({"project": str(root), "rule_source": "contextkit guide audit",
               "findings": [item.as_dict() for item in findings]}, True)
    else:
        _emit(report)


def cmd_audit_file(args: argparse.Namespace) -> None:
    root = _find_project_root()
    path = Path(args.path)
    if not path.is_absolute():
        path = root / path
    try:
        path.resolve().relative_to(_memory_location(root).path.resolve())
        findings = _audit_memory(root, [path])
    except ValueError:
        findings = _audit_context_files(root, [path])
    if args.json:
        _emit({"project": str(root), "rule_source": "contextkit guide audit",
               "findings": [item.as_dict() for item in findings]}, True)
    else:
        _emit(_audit_report(root, findings))


def _require_git_for_mutation(root: Path) -> None:
    if not (root / ".git").exists():
        _die("mutating operations require a git repository; run `git init` first", 6)


def cmd_groom(args: argparse.Namespace) -> None:
    root = _find_project_root()
    if args.apply:
        _require_git_for_mutation(root)
        _emit(
            "ContextKit v0 has no automatic groom patches yet.\n"
            "Run `contextkit audit --write`, review the report, and apply changes deliberately."
        )
        return
    findings = _project_audit_findings(root)
    lines = ["# ContextKit Groom Plan", "", f"Project: `{root}`", ""]
    if not findings:
        lines.append("No audit findings to groom.")
    else:
        lines += [
            "Rule source:",
            "",
            "- Load `contextkit guide audit` for the audit walk.",
            "- For each finding, load its `rule_source` guide and repair the owning source.",
            "",
            f"Current finding count: {len(findings)}",
        ]
    _emit("\n".join(lines) + "\n")


def _tree_stats(path: Path) -> dict[str, int]:
    stats = {"files": 0, "dirs": 0}
    if not path.exists():
        return stats
    for child in path.rglob("*"):
        if child.is_dir():
            stats["dirs"] += 1
        elif child.is_file():
            stats["files"] += 1
    return stats


def _relative_file_set(path: Path) -> set[str]:
    if not path.is_dir():
        return set()
    files: set[str] = set()
    for child in path.rglob("*"):
        if child.is_file():
            files.add(child.relative_to(path).as_posix())
    return files


def _git_status_paths(root: Path, rels: list[str]) -> list[str]:
    if not (root / ".git").exists():
        return []
    try:
        proc = _run(["git", "status", "--porcelain", "--untracked-files=all", "--", *rels], root)
    except (OSError, subprocess.TimeoutExpired):
        return []
    if proc.returncode != 0:
        return []
    paths: list[str] = []
    for raw in proc.stdout.splitlines():
        if len(raw) < 4:
            continue
        path = raw[3:]
        if " -> " in path:
            path = path.split(" -> ", 1)[1]
        paths.append(path)
    return paths


def _visible_layer_steps(root: Path, sources: dict[str, str]) -> list[MigrationStep]:
    steps: list[MigrationStep] = []
    capabilities_source = _capabilities_dir_from_sources(sources).as_posix()
    for visible in ("context", "assets", "routines", "capabilities"):
        if visible == "capabilities" and capabilities_source == ".capabilities":
            target = root / ".capabilities"
            dirty = _git_status_paths(root, [".capabilities"])
            dirty_detail = ""
            if dirty:
                sample = ", ".join(f"`{item}`" for item in dirty[:8])
                dirty_detail = f" Git has uncommitted entries under this layer: {sample}" + (" ..." if len(dirty) > 8 else "")
            if target.exists():
                stats = _tree_stats(target)
                steps.append(MigrationStep(
                    title="Keep `.capabilities/`",
                    action="keep",
                    status="manual" if dirty else "ok",
                    detail=f"Configured capability source exists with {stats['files']} files and {stats['dirs']} directories.{dirty_detail}",
                ))
            else:
                steps.append(MigrationStep(
                    title="Create `.capabilities/`",
                    action="create",
                    status="ready",
                    detail="Configured capability source is absent. Create it before enabling capabilities.",
                ))
            continue
        legacy = root / f".{visible}"
        target = root / visible
        dirty = _git_status_paths(root, [f".{visible}", visible])
        dirty_detail = ""
        if dirty:
            sample = ", ".join(f"`{item}`" for item in dirty[:8])
            dirty_detail = f" Git has uncommitted entries under this layer: {sample}" + (" ..." if len(dirty) > 8 else "")
        if legacy.exists() and not target.exists():
            stats = _tree_stats(legacy)
            steps.append(MigrationStep(
                title=f"Rename `.{visible}/` to `{visible}/`",
                action="rename",
                status="manual" if dirty else "ready",
                detail=f"Legacy layer exists with {stats['files']} files and {stats['dirs']} directories; visible target is absent.{dirty_detail}",
                command=f"git mv .{visible} {visible}",
            ))
        elif legacy.exists() and target.exists():
            legacy_files = _relative_file_set(legacy)
            target_files = _relative_file_set(target)
            collisions = sorted(legacy_files & target_files)
            legacy_stats = _tree_stats(legacy)
            target_stats = _tree_stats(target)
            if collisions:
                steps.append(MigrationStep(
                    title=f"Merge `.{visible}/` into existing `{visible}/`",
                    action="merge",
                    status="manual",
                    detail=(
                        f"Both source and target exist. Legacy has {legacy_stats['files']} files; "
                        f"target has {target_stats['files']} files. {len(collisions)} relative paths collide: "
                        + ", ".join(f"`{item}`" for item in collisions[:8])
                        + (" ..." if len(collisions) > 8 else "")
                    ),
                ))
            else:
                steps.append(MigrationStep(
                    title=f"Merge `.{visible}/` into existing `{visible}/`",
                    action="merge",
                    status="manual" if dirty else "ready",
                    detail=(
                        f"Both source and target exist, but no file paths collide. Legacy has {legacy_stats['files']} files; "
                        f"target has {target_stats['files']} files. Preserve existing target-only content.{dirty_detail}"
                    ),
                    command=f"rsync -a .{visible}/ {visible}/ && git rm -r .{visible}",
                ))
        elif target.exists():
            stats = _tree_stats(target)
            steps.append(MigrationStep(
                title=f"Keep `{visible}/`",
                action="keep",
                status="manual" if dirty else "ok",
                detail=f"Visible layer already exists with {stats['files']} files and {stats['dirs']} directories.{dirty_detail}",
            ))
        else:
            steps.append(MigrationStep(
                title=f"Create `{visible}/`",
                action="create",
                status="ready",
                detail="Layer is absent. `contextkit init --with-layers` creates empty project body layers; `contextkit init --with-template` also creates starter context files.",
            ))
    return steps


def _bootstrap_steps(root: Path, sources: dict[str, str]) -> list[MigrationStep]:
    steps: list[MigrationStep] = []
    required = {
        ".contextkit/config.toml": root / CONFIG_REL,
        ".contextkit/README.md": root / README_REL,
        ".env.local": root / ".env.local",
    }
    for label, path in required.items():
        if path.exists():
            steps.append(MigrationStep(label, "keep", "ok", "Required bootstrap file already exists."))
        else:
            steps.append(MigrationStep(label, "create", "ready", "Missing required bootstrap file.", "contextkit adopt"))

    capabilities_dir = _capabilities_dir_from_sources(sources)
    settings_rel = capabilities_dir / "settings.json"
    settings = root / settings_rel
    legacy_settings = root / ".capabilities" / "settings.json"
    if settings.exists():
        steps.append(MigrationStep(settings_rel.as_posix(), "keep", "ok", "Capability gate already exists."))
    elif capabilities_dir.as_posix() != ".capabilities" and legacy_settings.exists():
        steps.append(MigrationStep(
            settings_rel.as_posix(),
            "move",
            "ready",
            "Capability gate exists under `.capabilities/` and will move with the visible layer migration.",
            "git mv .capabilities capabilities",
        ))
    else:
        steps.append(MigrationStep(settings_rel.as_posix(), "create", "ready", "Missing capability gate file.", "contextkit adopt --with-layers"))

    patterns = _gitignore_patterns(root)
    missing = [line for line in _required_gitignore_lines(capabilities_dir) if line not in patterns]
    if not (root / ".gitignore").exists():
        steps.append(MigrationStep(".gitignore", "create", "ready", "Missing .gitignore with ContextKit local/generated guards.", "contextkit adopt"))
    elif missing:
        steps.append(MigrationStep(
            ".gitignore guards",
            "update",
            "ready",
            "Missing guards: " + ", ".join(f"`{line}`" for line in missing),
            "contextkit adopt",
        ))
    else:
        steps.append(MigrationStep(".gitignore guards", "keep", "ok", "All ContextKit local/generated guards are present."))
    return steps


def _file_contains(path: Path, needle: str) -> bool:
    try:
        return needle in path.read_text()
    except OSError:
        return False


def _host_steps(root: Path) -> list[MigrationStep]:
    steps: list[MigrationStep] = []
    codex_build = root / ".codex" / "hooks" / "build-context.sh"
    if codex_build.exists():
        if _file_contains(codex_build, "contextkit build --target codex"):
            steps.append(MigrationStep("Codex build adapter", "keep", "ok", "`build-context.sh` already calls ContextKit."))
        else:
            steps.append(MigrationStep(
                "Codex build adapter",
                "replace",
                "ready",
                "Existing `.codex/hooks/build-context.sh` is a project-local compiler; ContextKit owns this adapter.",
                "contextkit install-hooks --target codex",
            ))
    else:
        steps.append(MigrationStep(
            "Codex build adapter",
            "create",
            "ready",
            "No Codex ContextKit adapter found.",
            "contextkit install-hooks --target codex",
        ))

    codex_hooks = root / ".codex" / "hooks.json"
    if codex_hooks.exists():
        if _file_contains(codex_hooks, ".codex/hooks/build-context.sh"):
            steps.append(MigrationStep("Codex SessionStart hook", "keep", "ok", "`hooks.json` already calls the build adapter."))
        else:
            steps.append(MigrationStep("Codex SessionStart hook", "update", "ready", "`hooks.json` does not call the ContextKit build adapter.", "contextkit install-hooks --target codex"))
    else:
        steps.append(MigrationStep("Codex SessionStart hook", "create", "ready", "No Codex hook file found.", "contextkit install-hooks --target codex"))

    codex_config = root / ".codex" / "config.toml"
    if codex_config.exists() and _file_contains(codex_config, ".codex/generated/context.md"):
        steps.append(MigrationStep("Codex fallback config", "keep", "ok", "Codex fallback reads `.codex/generated/context.md`."))
    else:
        steps.append(MigrationStep("Codex fallback config", "update", "ready", "Codex fallback includes `.codex/generated/context.md`.", "contextkit install-hooks --target codex"))

    claude_settings = root / ".claude" / "settings.json"
    if claude_settings.exists():
        if _file_contains(claude_settings, "contextkit build --target claude"):
            steps.append(MigrationStep("Claude SessionStart hook", "keep", "ok", "Claude hook already calls ContextKit."))
        else:
            steps.append(MigrationStep(
                "Claude SessionStart hook",
                "review",
                "manual",
                "Existing Claude hooks are present but do not call ContextKit; review before replacing or augmenting them.",
                "contextkit install-hooks --target claude",
            ))
    else:
        steps.append(MigrationStep("Claude SessionStart hook", "create", "ready", "No Claude settings hook found.", "contextkit install-hooks --target claude"))

    for rel in (".codex/generated/context.md", ".claude/rules/CONTEXT.md"):
        path = root / rel
        if path.exists():
            steps.append(MigrationStep(rel, "regenerate", "ready", "Generated output exists; rebuild after migration.", "contextkit build --target all"))
        else:
            steps.append(MigrationStep(rel, "create", "ready", "Generated output will be created by the ContextKit compiler.", "contextkit build --target all"))
    return steps


def _instruction_file_steps(root: Path) -> list[MigrationStep]:
    steps: list[MigrationStep] = []
    for rel in ("CLAUDE.md", "AGENTS.md"):
        path = root / rel
        if path.exists():
            steps.append(MigrationStep(
                rel,
                "review",
                "manual",
                "Root instruction file exists. Delete only if it duplicates compiled ContextKit output.",
            ))
    if not steps:
        steps.append(MigrationStep("Root instruction files", "keep", "ok", "No root `CLAUDE.md` or `AGENTS.md` found."))
    return steps


def _migration_plan(root: Path) -> dict[str, Any]:
    sources = _config(root)["sources"]
    sections = {
        "Project body layers": _visible_layer_steps(root, sources),
        "Bootstrap files": _bootstrap_steps(root, sources),
        "Host bindings": _host_steps(root),
        "Instruction files": _instruction_file_steps(root),
    }
    all_steps = [step for steps in sections.values() for step in steps]
    blockers = [step for step in all_steps if step.status == "blocked"]
    manual = [step for step in all_steps if step.status == "manual"]
    ready = [step for step in all_steps if step.status == "ready"]
    return {
        "project": str(root),
        "git": _git_state(root),
        "summary": {
            "ok": len(blockers) == 0,
            "ready": len(ready),
            "manual": len(manual),
            "blocked": len(blockers),
        },
        "rule_sources": ["contextkit guide migration"],
        "sections": {
            name: [step.as_dict() for step in steps]
            for name, steps in sections.items()
        },
    }


def _format_migration_plan(plan: dict[str, Any]) -> str:
    lines = ["# ContextKit Migration Plan", "", f"Project: `{plan['project']}`", ""]
    summary = plan["summary"]
    git = plan["git"]
    lines += [
        "Rule source:",
        "",
        "- `contextkit guide migration`",
        "",
        "Summary:",
        "",
        f"- Git present: {git.get('present')}",
        f"- Git dirty: {git.get('dirty')}",
        f"- Ready steps: {summary['ready']}",
        f"- Manual review steps: {summary['manual']}",
        f"- Blocked steps: {summary['blocked']}",
        "",
    ]
    for section, steps in plan["sections"].items():
        lines += [f"## {section}", ""]
        for step in steps:
            status = step["status"]
            lines += [
                f"### {step['title']}",
                "",
                f"- Action: `{step['action']}`",
                f"- Status: `{status}`",
                f"- Detail: {step['detail']}",
            ]
            if step.get("command"):
                lines.append(f"- Command: `{step['command']}`")
            lines.append("")
    lines += [
        "## Verification After Migration",
        "",
        "1. Load `contextkit guide migration`.",
        "2. Run `contextkit doctor`.",
        "3. Run `contextkit build --target all`.",
        "4. Run `contextkit audit` and follow its rule-source guide routing.",
        "5. Review generated `.codex/generated/context.md` and `.claude/rules/CONTEXT.md` before removing old project-local compilers.",
        "",
    ]
    return "\n".join(lines)


def cmd_migrate(args: argparse.Namespace) -> None:
    root = _find_project_root()
    if args.apply:
        _require_git_for_mutation(root)
        _die("contextkit migrate --apply is not implemented in v0; use --plan first", 6)
    plan = _migration_plan(root)
    if args.json:
        _emit(plan, True)
    else:
        _emit(_format_migration_plan(plan))


def cmd_guide(args: argparse.Namespace) -> None:
    topic = args.topic or "authoring"
    if topic not in GUIDE_TOPICS:
        _die(f"unknown guide topic: {topic}\nAvailable: {', '.join(GUIDE_TOPICS)}", 6)
    _emit(_read_guide(f"{topic}.md"))


def cmd_templates(_: argparse.Namespace) -> None:
    template_root = _template_root()
    lines = [
        "# ContextKit Templates",
        "",
        "Starter context gallery. Copy or adapt templates that fit the project; `--with-template` creates the current starter set.",
        "",
    ]
    files = _template_files()
    if not files:
        lines.append("No context templates are available.")
    for path in files:
        rel = path.relative_to(template_root).as_posix()
        fm, _body = _parse_frontmatter(path.read_text())
        title = fm.get("title", path.stem)
        description = fm.get("description", "").strip()
        suffix = f" - {description}" if description else ""
        lines.append(f"- `{rel}` - {title}{suffix}")
    lines += [
        "",
        "Run `contextkit init --with-template` to create missing binding, layers, and starter context files.",
        "Run `contextkit global-context init <path>` to create the separate global-context starter.",
    ]
    _emit("\n".join(lines) + "\n")


